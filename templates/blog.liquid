{%- comment -%}
  News feed (list) — Shopify blog convention at /blogs/news.

  Rendered client-side by news.js (legacy AICO content) which delegates to
  news-neo.js (window.NewsNeo) for articles authored in the new AICO Neo
  content builder. Data comes from the same-origin proxy
  /blogs/news/feed.js + /blogs/news/categories.js (shopper session auth).

  The container ids/classes below are the mount points news.js writes into:
    #news-container        — the rendered article cards
    #filter-container      — category filter buttons
    #news-pagination .pagination__list — pager
    #status / #preloader / .page-wrapper — loading shell (faded/removed on load)
{%- endcomment -%}

<style>
  .aico-news--list { max-width: 1280px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
  .aico-news-header { margin-bottom: 1.5rem; }
  .aico-news-title { font-size: 2rem; font-weight: 700; margin: 0; }
  .aico-news-filter { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 2rem; }
  .aico-news-filter .btn { border: 1px solid #d4d4d4; background: #fff; border-radius: 999px;
    padding: .4rem 1rem; font-size: .9rem; cursor: pointer; line-height: 1.2; }
  .aico-news-filter .btn.active { background: #111; color: #fff; border-color: #111; }
  .aico-news .grid { list-style: none; display: grid; gap: 1.5rem; padding: 0; margin: 0;
    grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .aico-news .grid__item { margin: 0; }
  .aico-news .news-wrapper { display: flex; flex-direction: column; height: 100%;
    border: 1px solid #ececec; border-radius: 12px; overflow: hidden; background: #fff;
    transition: box-shadow .2s ease; }
  .aico-news .news-wrapper:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); }
  .aico-news .image-wrapper { aspect-ratio: 16 / 10; overflow: hidden; background: #f2f2f2; }
  .aico-news .image-wrapper img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .aico-news .content-wrapper { padding: 1rem 1.1rem 0; flex: 1 1 auto; }
  .aico-news .newsblock__date { font-size: .8rem; color: #888; margin-bottom: .4rem; }
  .aico-news .newsblock__title { font-size: 1.1rem; font-weight: 600; margin: 0 0 .5rem; line-height: 1.3; }
  .aico-news .newsblock__details { font-size: .9rem; color: #555; line-height: 1.5; }
  .aico-news .link-wrapper { padding: .75rem 1.1rem 1.1rem; }
  .aico-news .block-btn { display: inline-flex; align-items: center; justify-content: center;
    width: 2.25rem; height: 2.25rem; border-radius: 999px; background: #111; }
  .aico-news .block-btn svg { width: 1rem; height: 1rem; fill: #fff; }
  .aico-news-pagination { margin-top: 2.5rem; }
  .aico-news-pagination .pagination__list { display: flex; flex-wrap: wrap; gap: .4rem;
    justify-content: center; list-style: none; padding: 0; align-items: center; }
  .aico-news-pagination .pagination__item { display: inline-flex; min-width: 2.25rem; height: 2.25rem;
    align-items: center; justify-content: center; padding: 0 .6rem; border: 1px solid #d4d4d4;
    border-radius: 8px; text-decoration: none; color: #111; }
  .aico-news-pagination .pagination__item--current,
  .aico-news-pagination .pagination__item[aria-current="page"] { background: #111; color: #fff; border-color: #111; }
  .aico-news .center { text-align: center; margin-top: 2rem; }
  @media (max-width: 990px) { .aico-news .grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
  @media (max-width: 600px) { .aico-news .grid { grid-template-columns: 1fr; } }
</style>

<section class="aico-news aico-news--list" data-aico-news="list">
  <div id="status" class="aico-news-status" aria-hidden="true"></div>
  <div id="preloader" class="aico-news-preloader" aria-hidden="true"></div>
  <div class="page-wrapper"></div>

  <header class="aico-news-header">
    <h1 class="aico-news-title">News</h1>
  </header>

  <div id="filter-container" class="aico-news-filter"></div>
  <div id="news-container" class="aico-news-grid"></div>

  <nav id="news-pagination" class="aico-news-pagination" aria-label="Pagination">
    <ul class="pagination__list"></ul>
  </nav>
</section>

{%- comment -%} jQuery + slick are dependencies of the ported news.js renderer. {%- endcomment -%}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css">
<script src="https://code.jquery.com/jquery-3.6.4.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js" defer></script>
<script src="{{ 'news-neo.js' | asset_url }}" defer></script>
<script src="{{ 'news.js' | asset_url }}" defer></script>
