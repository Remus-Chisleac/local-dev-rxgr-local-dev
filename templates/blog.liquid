{%- comment -%}
  News feed (list) — Shopify blog convention at /blogs/news.

  Server-rendered: LiquidRendererService binds the `blog` drop (articles for
  the requested ?page, category filter, pagination) via NewsLoader, so the
  HTML arrives populated. No client fetch, no empty/loading state. Pagination
  and the category filter are plain links (?page=N / ?category=ID), so the
  page works without JavaScript.

  Articles authored in the AICO Neo content builder still render their full
  body via news-neo.js on the article page — this list only needs the card
  fields (image, date, title, excerpt), which are server-rendered here.
{%- endcomment -%}

<style>
  .aico-news--list { max-width: 1280px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
  .aico-news-header { margin-bottom: 1.5rem; }
  .aico-news-title { font-size: 2rem; font-weight: 700; margin: 0; }
  .aico-news-grid { list-style: none; display: grid; gap: 1.5rem; padding: 0; margin: 0;
    grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .aico-news-card { display: flex; flex-direction: column; height: 100%; border: 1px solid #ececec;
    border-radius: 0.125rem; overflow: hidden; background: #fff; text-decoration: none; color: inherit;
    transition: box-shadow .2s ease; }
  .aico-news-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); }
  .aico-news-card-image { aspect-ratio: 16 / 10; overflow: hidden; background: #f2f2f2; }
  .aico-news-card-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .aico-news-card-body { padding: 1rem 1.1rem 1.25rem; flex: 1 1 auto; display: flex; flex-direction: column; }
  .aico-news-card-meta { font-size: .8rem; color: #888; margin-bottom: .4rem; }
  .aico-news-card-title { font-size: 1.1rem; font-weight: 600; margin: 0 0 .5rem; line-height: 1.3; }
  .aico-news-card-excerpt { font-size: .9rem; color: #555; line-height: 1.5; margin: 0; }
  .aico-news-empty { color: #666; }
  .aico-news-pagination { margin-top: 2.5rem; }
  .aico-news-pagination ul { display: flex; flex-wrap: wrap; gap: .4rem; justify-content: center;
    list-style: none; padding: 0; align-items: center; }
  .aico-news-pagination a, .aico-news-pagination span { display: inline-flex; min-width: 2.25rem;
    height: 2.25rem; align-items: center; justify-content: center; padding: 0 .6rem;
    border: 1px solid #d4d4d4; border-radius: 8px; text-decoration: none; color: #111; }
  .aico-news-pagination .is-current { background: #111; color: #fff; border-color: #111; }
  @media (max-width: 990px) { .aico-news-grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
  @media (max-width: 600px) { .aico-news-grid { grid-template-columns: 1fr; } }
</style>

<section class="aico-news aico-news--list" data-aico-news="list">
  <header class="aico-news-header">
    <h1 class="aico-news-title">News</h1>
  </header>

  {%- if blog.size > 0 -%}
    <div class="aico-news-grid">
      {%- for article in blog.articles -%}
        <a class="aico-news-card" href="{{ article.url }}">
          <div class="aico-news-card-image">
            {%- if article.image -%}
              <img src="{{ article.image }}" alt="{{ article.title | escape }}" loading="lazy" style="object-position: {{ article.aico_object_position }};">
            {%- endif -%}
          </div>
          <div class="aico-news-card-body">
            {%- if article.published_at -%}<div class="aico-news-card-meta">{{ article.published_at }}{% if article.aico_category_name %} · {{ article.aico_category_name }}{% endif %}</div>{%- endif -%}
            <h2 class="aico-news-card-title">{{ article.title }}</h2>
            {%- if article.excerpt -%}<p class="aico-news-card-excerpt">{{ article.excerpt }}</p>{%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- assign pagination = blog.aico_pagination -%}
    {%- if pagination.pages > 1 -%}
      <nav class="aico-news-pagination" aria-label="Pagination">
        <ul>
          {%- if pagination.previous -%}<li><a href="{{ pagination.previous.url }}" rel="prev">{{ pagination.previous.title }}</a></li>{%- endif -%}
          {%- for part in pagination.parts -%}
            <li>
              {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}<span class="is-current" aria-current="page">{{ part.title }}</span>{%- endif -%}
            </li>
          {%- endfor -%}
          {%- if pagination.next -%}<li><a href="{{ pagination.next.url }}" rel="next">{{ pagination.next.title }}</a></li>{%- endif -%}
        </ul>
      </nav>
    {%- endif -%}
  {%- else -%}
    <p class="aico-news-empty">{% if request.locale contains 'de' %}Keine News verfügbar.{% else %}No news available.{% endif %}</p>
  {%- endif -%}
</section>
