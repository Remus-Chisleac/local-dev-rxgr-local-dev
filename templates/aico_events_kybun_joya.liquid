<link rel="stylesheet" href="{{ 'eventtool.css' | asset_url }}">

{%- assign et_address = '' -%}
{%- for address in customer.aico_delivery_addresses -%}
  {%- if address.name == 'Hauptadresse' -%}
    {%- assign et_address = address.country | append: ' ' | append: address.city | append: ' ' | append: address.address1 | append: ' ' | append: address.address2 | append: ' ' | append: address.zip -%}
  {%- endif -%}
{%- endfor -%}

<main class="et-page" data-aico-eventtool="events-kybun-joya">
  <img class="et-header-img" src="{% render 'aico-image-src', image: settings.aico_et_kj_events_header, fallback: 'et-kj-events-header-de_CH.jpg' %}" alt="{{ settings.aico_et_kj_events_header.alt }}">
  <div data-et-mount></div>
</main>

<script id="aico-eventtool-config" type="application/json">
{
  "locale": {{ request.locale.iso_code | json }},
  "formName": "kj-events-form",
  "endpoint": {{ routes.aico_forms_url | json }},
  "productsUrl": {{ routes.aico_form_products_url | json }},
  "maxSelectable": { "q5": 3, "q6": 3 },
  "email": {{ customer.email | default: '' | json }},
  "address": {{ et_address | json }},
  "images": {
    "q3": ["{% render 'aico-image-src', image: settings.aico_et_kj_events_question3_image1, fallback: 'et-kj-events-question3-image1.jpg' %}","{% render 'aico-image-src', image: settings.aico_et_kj_events_question3_image2, fallback: 'et-kj-events-question3-image2.jpg' %}","{% render 'aico-image-src', image: settings.aico_et_kj_events_question3_image3, fallback: 'et-kj-events-question3-image3.jpg' %}"],
    "q4": ["{% render 'aico-image-src', image: settings.aico_et_kj_events_question4_image1, fallback: 'et-kj-events-question4-image1.jpg' %}","{% render 'aico-image-src', image: settings.aico_et_kj_events_question4_image2, fallback: 'et-kj-events-question4-image2.jpg' %}","{% render 'aico-image-src', image: settings.aico_et_kj_events_question4_image3, fallback: 'et-kj-events-question4-image3.jpg' %}"],
    "q10": ["{% render 'aico-image-src', image: settings.aico_et_kj_events_question10_image1, fallback: 'et-kj-events-question10-image1.jpg' %}","{% render 'aico-image-src', image: settings.aico_et_kj_events_question10_image2, fallback: 'et-kj-events-question10-image2.jpg' %}","{% render 'aico-image-src', image: settings.aico_et_kj_events_question10_image3, fallback: 'et-kj-events-question10-image3.jpg' %}","{% render 'aico-image-src', image: settings.aico_et_kj_events_question10_image4, fallback: 'et-kj-events-question10-image4.jpg' %}"]
  }
}
</script>

<script src="{{ 'aico-events-kybun-joya.js' | asset_url }}" defer></script>
<script src="{{ 'eventtool-lightbox.js' | asset_url }}" defer></script>
