{% comment %}
  Order-confirmation page for ONE order, addressed by its ecommerce order
  number in the path: `/checkout/thank-you/16220039`.

  Nothing monetary is passed in the URL. The `aicoCheckoutThankYouPage`
  Alpine component fetches the PERSISTED totals from
  /checkout/order-summary, so the amounts shown are always what the aico
  order actually charged — not client-supplied numbers a shopper could
  edit in the address bar.

  The order save runs asynchronously (queued SaveAicoShopOrder), so the
  card has three states:
    - `pending`  — the order exists but is still saving. The component
                   subscribes to the AicoShopOrderCreatedEvent broadcast
                   for this order and swaps in the totals the moment it
                   lands (polling only when pusher is unavailable).
    - `summary`  — confirmed: the persisted breakdown, discount included.
    - `notFound` — no such order, or one outside this shopper's
                   organisation. Enforced server-side by the endpoint.
  A reload, or a link opened later by a colleague on the same debtor,
  lands straight in the `summary` state.

  The legacy `?order_number=` / `?orderRef=` form still renders: Adyen's
  returnUrl is built from a single app-wide ADYEN_BASE_REDIRECT_URL that
  the legacy b2b-shop thank-you page also consumes, so it keeps the old
  dialect (orderRef + sessionId/sessionResult). The component verifies the
  payment session via /checkout/payment-status before showing the success
  card, then rewrites the URL to the canonical path form.

  Background color: the page gutters take the current selected brand's
  `color_schema.checkoutConfirmation.bg` (exposed on
  `customer.aico_selected_brand.aico_checkout_confirmation_bg_color`), applied at
  render time as `--aico-confirmation-bg` so there is no flash. Same treatment as
  the preorder confirmation; the centered white card stays readable on any brand
  color and falls back to the default page background when the brand sets none.
{% endcomment %}

{%- assign aico_confirmation_bg = customer.aico_selected_brand.aico_checkout_confirmation_bg_color -%}

{%- comment -%} The order number is the route's captured `:handle` — resolved by
  the server, exactly like `products/:handle` gives the product page its handle.
  Never derive it by matching a literal path segment: the theme route map lets
  this page's URL be renamed, and the JS reads the number back off the element
  below rather than re-parsing the address bar. Falls back to the legacy query
  params for in-flight Adyen returns and old bookmarks. {%- endcomment -%}
{%- assign ty_order_number = aico_route.handle | default: request.query.order_number | default: request.query.orderRef -%}

{% capture ty_success_card %}
    <div class="aico-checkout-thank-you-card">
      <div class="aico-checkout-thank-you-icon" aria-hidden="true">&#10003;</div>
      <h1 class="aico-checkout-thank-you-title">{{ 'checkout.thank_you.title' | t }}</h1>

      <p class="aico-checkout-thank-you-order" x-show="orderNumber && !notFound">
        {{ 'checkout.thank_you.order_number' | t }}:
        <strong x-text="orderNumber">{{ ty_order_number }}</strong>
      </p>

      {%- comment -%} Still saving: the totals are not trustworthy yet, so show
        the wait state rather than a half-filled or query-supplied breakdown. {%- endcomment -%}
      <p class="aico-checkout-thank-you-confirming" x-show="pending && !notFound" x-cloak>
        {{ 'checkout.thank_you.confirming' | t }}
      </p>

      {%- comment -%} Authoritative totals read back from the persisted aico
        order (aico_shop_orders + the ecommerce order's discount line item) —
        exactly what the backend charged, including the promo-code discount. {%- endcomment -%}
      <dl class="aico-checkout-thank-you-totals" x-show="summary" x-cloak>
        <div class="aico-checkout-summary-row">
          <dt>{{ 'checkout.summary.subtotal' | t }}</dt>
          <dd x-text="formatSummary('subtotal')"></dd>
        </div>
        <div class="aico-checkout-summary-row aico-checkout-summary-row-discount"
             x-show="summaryValue('discount_value') > 0">
          <dt>
            {{ 'checkout.summary.discount' | t }}<template x-if="summary && summary.discount_code"><span> (<span x-text="summary.discount_code"></span>)</span></template>
          </dt>
          <dd x-text="'−' + formatSummary('discount_value')"></dd>
        </div>
        <div class="aico-checkout-summary-row" x-show="summaryValue('shipping') > 0">
          <dt>{{ 'checkout.summary.shipping' | t }}</dt>
          <dd x-text="formatSummary('shipping')"></dd>
        </div>
        <div class="aico-checkout-summary-row" x-show="summaryValue('vat') > 0">
          <dt>{{ 'checkout.summary.vat' | t }}</dt>
          <dd x-text="formatSummary('vat')"></dd>
        </div>
        <div class="aico-checkout-summary-row" x-show="summaryValue('cc_fee') > 0">
          <dt>{{ 'checkout.summary.cc_fee' | t }}</dt>
          <dd x-text="formatSummary('cc_fee')"></dd>
        </div>
        <div class="aico-checkout-summary-row aico-checkout-summary-row-grand">
          <dt>{{ 'checkout.summary.total' | t }}</dt>
          <dd x-text="formatSummary('total')"></dd>
        </div>
      </dl>

      <p class="aico-checkout-thank-you-email" x-show="!notFound">{{ 'checkout.thank_you.email_confirmation' | t }}</p>

      {%- comment -%} Unknown order number, or one belonging to another
        organisation — /checkout/order-summary answers 404 either way and never
        says which, so the page cannot be used to probe for orders. {%- endcomment -%}
      <p class="aico-checkout-thank-you-not-found" x-show="notFound" x-cloak>
        {{ 'checkout.thank_you.not_found' | t }}
      </p>

      <a href="{{ routes.products_url }}" class="aico-button aico-button-primary">
        {{ 'checkout.thank_you.continue' | t }}
      </a>
    </div>
{% endcapture %}

<main class="aico-checkout-thank-you"{% if aico_confirmation_bg %} style="--aico-confirmation-bg: {{ aico_confirmation_bg | escape }};"{% endif %}>
  <div class="aico-page-container">
    {%- comment -%} The component is mounted for EVERY confirmation (not just the
      Adyen return leg): it also fetches the persisted order totals via
      /checkout/order-summary. Without session params init() resolves the state
      to 'success' immediately. {%- endcomment -%}
      <div data-aico-order-number="{{ ty_order_number | escape }}"
           x-data="aicoCheckoutThankYouPage" x-init="init()">
        <template x-if="state === 'verifying'">
          <div class="aico-checkout-thank-you-card">
            <div class="aico-checkout-processing-spinner" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              </svg>
            </div>
            <p class="aico-checkout-thank-you-email">{{ 'checkout.thank_you.verifying' | t }}</p>
          </div>
        </template>

        <template x-if="state === 'success'">
          {{ ty_success_card }}
        </template>

        <template x-if="state === 'cancelled'">
          <div class="aico-checkout-thank-you-card aico-checkout-payment-error">
            <h1 class="aico-checkout-thank-you-title">{{ 'checkout.payment_error.title' | t }}</h1>
            <p>{{ 'checkout.payment_error.cancelled' | t }}</p>
            {% if ty_order_number %}
              <p>
                {{ 'checkout.payment_error.reference_number' | t }}
                <strong>{{ ty_order_number }}</strong>{{ 'checkout.payment_error.customer_service' | t }}
              </p>
            {% endif %}
            <p>{{ 'checkout.payment_error.order_not_placed' | t }}</p>
            <p>{{ 'checkout.payment_error.no_reservation' | t }}</p>
            <p>
              {{ 'checkout.payment_error.questions_before_email' | t }}
              <a href="mailto:partner@kybunjoya.swiss"><strong>partner@kybunjoya.swiss</strong></a>{{ 'checkout.payment_error.questions_after_email' | t }}
            </p>
            <p>{{ 'checkout.payment_error.thank_you' | t }}</p>
          </div>
        </template>

        <template x-if="state === 'unverified'">
          <div class="aico-checkout-thank-you-card aico-checkout-payment-error">
            <h1 class="aico-checkout-thank-you-title">{{ 'checkout.payment_error.unverified_title' | t }}</h1>
            <p>{{ 'checkout.payment_error.unverified' | t }}</p>
            {% if ty_order_number %}
              <p>
                {{ 'checkout.payment_error.reference_number' | t }}
                <strong>{{ ty_order_number }}</strong>{{ 'checkout.payment_error.customer_service' | t }}
              </p>
            {% endif %}
            <p>
              {{ 'checkout.payment_error.questions_before_email' | t }}
              <a href="mailto:partner@kybunjoya.swiss"><strong>partner@kybunjoya.swiss</strong></a>{{ 'checkout.payment_error.questions_after_email' | t }}
            </p>
          </div>
        </template>
      </div>
  </div>
</main>
