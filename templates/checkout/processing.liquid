{% comment %}
  Pre-payment waiting page for credit-card orders whose save runs async
  (large carts: the submit response has no hosted_page_url yet). The URL
  query carries `?order_id=...` only. checkout.js subscribes via Pusher
  (`window.__AICO_PUSHER__`, emitted by the layout when the backend has
  Pusher configured) to `AicoShopOrderCreatedEvent` for that order; the
  event's `url` is the Adyen hosted payment page and the shopper is
  redirected there. Without Pusher it polls /checkout/payment-status,
  whose response carries `hosted_page_url` once the order is saved.
  Only URL-less events/orders go straight to /checkout/thank-you.
{% endcomment %}

<main class="aico-checkout-processing"
      x-data="aicoCheckoutProcessingPage"
      x-init="init()">
  <div class="aico-page-container aico-checkout-processing-inner">
    <div class="aico-checkout-processing-card">
      <div class="aico-checkout-processing-spinner" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
      </div>
      <h1 class="aico-checkout-processing-title">{{ 'checkout.processing_page.title' | t }}</h1>
      <p class="aico-checkout-processing-body">{{ 'checkout.processing_page.body' | t }}</p>
      <p class="aico-checkout-processing-fallback" x-show="elapsed > 30" x-cloak>
        {{ 'checkout.processing_page.fallback' | t }}
      </p>
    </div>
  </div>
</main>
