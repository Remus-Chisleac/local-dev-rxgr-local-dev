{% comment %}
  Post-Adyen-redirect waiting page. Subscribes via Pusher to the
  `AicoShopOrderCreatedEvent` for the order id passed in the URL query
  (`?order_id=...&session_id=...&session_result=...`), and navigates
  to /checkout/thank-you when the event lands.

  Falls back to the b2b-shop's plain Pusher pattern — no defensive
  polling layer in v1 (per your "make it like b2b-shop" call).
{% endcomment %}

<main class="aico-checkout-processing"
      x-data="aicoCheckoutProcessingPage"
      x-init="init()">
  <div class="aico-page-container aico-checkout-processing-inner">
    <div class="aico-checkout-processing-card">
      <div class="aico-checkout-processing-spinner" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
      </div>
      <h1 class="aico-checkout-processing-title">{{ 'checkout.processing_page.title' | t }}</h1>
      <p class="aico-checkout-processing-body">{{ 'checkout.processing_page.body' | t }}</p>
      <p class="aico-checkout-processing-fallback" x-show="elapsed > 30" x-cloak>
        {{ 'checkout.processing_page.fallback' | t }}
      </p>
    </div>
  </div>
</main>
