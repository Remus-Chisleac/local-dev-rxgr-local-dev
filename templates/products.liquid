{% comment %}
  Products listing — server-renders the first page of Meilisearch
  results plus the top filter bar (search pill + Filters dropdown +
  sort selector). The mega-panel beneath the bar shows facets in a
  multi-column grid (subcategory, color swatches, materials, sole
  technology, fitting, production status) and sizes as a row of
  EU-grouped chips at the bottom. Layout mirrors aico-commerce's
  ProductsFilterBar / ProductsFilterOptions.

  The vanilla controller in `assets/products-page.js` then takes
  over: live search, panel toggle, instant facet toggles, infinite
  scroll. URL state syncs via replaceState so listings stay shareable.
{% endcomment %}

<main class="aico-products" role="main" data-aico-products-controller>
  <div class="aico-page-container aico-products-shell">
    <h1 class="aico-sr-only">{{ 'products.title' | t }}</h1>

    <div class="aico-filterbar">
      <div class="aico-filterbar-row">
        <p class="aico-filterbar-heading" data-aico-category-heading>{{ 'products.all_categories' | t }}</p>

        <label class="aico-filterbar-search">
          <span class="aico-sr-only">{{ 'products.search_label' | t }}</span>
          <svg class="aico-filterbar-search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <input
            type="search"
            class="aico-filterbar-search-input"
            name="q"
            placeholder="{{ 'products.search_placeholder' | t }}"
            value="{{ aico_products.query }}"
            autocomplete="off"
            data-aico-search-input>
        </label>

        <div class="aico-filterbar-actions">
          <button
            type="button"
            class="aico-filterbar-toggle"
            data-aico-panel-toggle
            aria-controls="aico-products-filter-panel"
            aria-expanded="false">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="4" x2="20" y1="6" y2="6"></line><line x1="7" x2="7" y1="3" y2="9"></line>
              <line x1="4" x2="20" y1="12" y2="12"></line><line x1="14" x2="14" y1="9" y2="15"></line>
              <line x1="4" x2="20" y1="18" y2="18"></line><line x1="10" x2="10" y1="15" y2="21"></line>
            </svg>
            <span>{{ 'products.filters_title' | t }}</span>
            <span class="aico-filterbar-badge" data-aico-filter-count>
              {{ aico_products.applied_facet_count }}
            </span>
            <svg class="aico-filterbar-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </button>

          {% assign aico_sort = aico_products.sort | default: '-date' %}
          <div class="aico-sortmenu" data-aico-sortmenu>
            <label class="aico-sr-only" for="aico-products-sort">{{ 'products.sort_label' | t }}</label>

            <button
              type="button"
              class="aico-sortmenu-button"
              data-aico-sortmenu-button
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="aico-products-sort-list">
              <svg class="aico-filterbar-sort-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 6h13"></path><path d="M3 12h9"></path><path d="M3 18h5"></path><path d="m17 8 4 4-4 4"></path><path d="M21 12H10"></path>
              </svg>
              <span class="aico-sortmenu-label" data-aico-sortmenu-label></span>
              <svg class="aico-sortmenu-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </button>

            <ul class="aico-sortmenu-list" id="aico-products-sort-list" role="listbox" data-aico-sortmenu-list tabindex="-1" hidden>
              <li class="aico-sortmenu-option" role="option" data-value="-date"{% if aico_sort == '-date' %} aria-selected="true"{% endif %}>{{ 'products.sort_newest' | t }}</li>
              <li class="aico-sortmenu-option" role="option" data-value="date"{% if aico_sort == 'date' %} aria-selected="true"{% endif %}>{{ 'products.sort_oldest' | t }}</li>
              <li class="aico-sortmenu-option" role="option" data-value="name"{% if aico_sort == 'name' %} aria-selected="true"{% endif %}>{{ 'products.sort_name_asc' | t }}</li>
              <li class="aico-sortmenu-option" role="option" data-value="-name"{% if aico_sort == '-name' %} aria-selected="true"{% endif %}>{{ 'products.sort_name_desc' | t }}</li>
            </ul>

            {% comment %} Hidden native select stays the source of truth; the controller
                          syncs it + dispatches change so the existing sort logic is untouched. {% endcomment %}
            <select id="aico-products-sort" class="aico-sr-only" data-aico-sort-select tabindex="-1" aria-hidden="true">
              <option value="-date" {% if aico_sort == '-date' %}selected{% endif %}>{{ 'products.sort_newest' | t }}</option>
              <option value="date" {% if aico_sort == 'date' %}selected{% endif %}>{{ 'products.sort_oldest' | t }}</option>
              <option value="name" {% if aico_sort == 'name' %}selected{% endif %}>{{ 'products.sort_name_asc' | t }}</option>
              <option value="-name" {% if aico_sort == '-name' %}selected{% endif %}>{{ 'products.sort_name_desc' | t }}</option>
            </select>
          </div>
        </div>
      </div>

      <div id="aico-products-filter-panel" class="aico-filterbar-panel" data-aico-panel hidden>
        <div class="aico-filterbar-panel-clip">
        <div class="aico-filterbar-panel-inner">
          <div class="aico-filterbar-panel-head">
            <label class="aico-filterbar-sale">
              <input
                type="checkbox"
                class="aico-filterbar-sale-input"
                data-aico-facet-checkbox
                data-facet-id="sale"
                data-facet-value="on"
                {% if aico_products.is_sale_active %}checked{% endif %}>
              <span>{{ 'products.facet_sale' | t }}</span>
            </label>

            <button type="button" class="aico-filterbar-clear" data-aico-clear-all>
              {{ 'products.clear_all' | t }}
            </button>
          </div>

          <div class="aico-filterbar-columns" data-aico-facet-columns>
            {% for facet in aico_products.facets %}
              <section class="aico-filtercol" data-facet-id="{{ facet.id }}">
                <h3 class="aico-filtercol-title">{{ facet.label_key | t }}</h3>
                {% if facet.id == 'color' %}
                  <div class="aico-filtercol-swatches" data-aico-facet-values>
                    {% for value in facet %}
                      <button
                        type="button"
                        class="aico-swatch{% if value.active %} aico-swatch-active{% endif %}"
                        title="{{ value.label }} ({{ value.count }})"
                        data-aico-facet-checkbox
                        data-facet-id="{{ facet.id }}"
                        data-facet-value="{{ value.value }}"
                        data-checked="{% if value.active %}1{% else %}0{% endif %}">
                        <span class="aico-swatch-dot" style="background:{{ value.value }}"></span>
                      </button>
                    {% endfor %}
                  </div>
                {% else %}
                  <ul class="aico-filtercol-list" data-aico-facet-values>
                    {% for value in facet %}
                      <li>
                        <button
                          type="button"
                          class="aico-filtercol-item{% if value.active %} aico-filtercol-item-active{% endif %}"
                          data-aico-facet-checkbox
                          data-facet-id="{{ facet.id }}"
                          data-facet-value="{{ value.value }}"
                          data-checked="{% if value.active %}1{% else %}0{% endif %}">
                          <span class="aico-filtercol-item-label">{{ value.label }}</span>
                          <span class="aico-filtercol-item-count">({{ value.count }})</span>
                        </button>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </section>
            {% endfor %}
          </div>

          {% assign aico_size_chip_count = aico_products.size_chips | size %}
          <section class="aico-filterbar-sizes" data-aico-sizes-section{% if aico_size_chip_count == 0 %} hidden{% endif %}>
            <h3 class="aico-filtercol-title">{{ 'products.facet_sizes' | t }}</h3>
            <div class="aico-filterbar-sizes-row" data-aico-size-chips>
              {% for chip in aico_products.size_chips %}
                <button
                  type="button"
                  class="aico-size-chip{% if chip.active %} aico-size-chip-active{% endif %}"
                  title="{{ chip.display }} ({{ chip.total_count }})"
                  data-aico-size-chip
                  data-size-display="{{ chip.display }}"
                  data-checked="{% if chip.active %}1{% else %}0{% endif %}">
                  {{ chip.display }}
                </button>
              {% endfor %}
            </div>
          </section>
        </div>
        </div>
      </div>
    </div>

    <div class="aico-products-meta">
      <p class="aico-products-count" data-aico-results-count data-singular="{{ 'products.result_count_singular' | t }}" data-plural="{{ 'products.result_count_plural' | t }}">
        {% if aico_products.total_hits == 1 %}
          {{ 'products.result_count_singular' | t | replace: '{count}', aico_products.total_hits }}
        {% else %}
          {{ 'products.result_count_plural' | t | replace: '{count}', aico_products.total_hits }}
        {% endif %}
      </p>
    </div>

    <p class="aico-products-empty" role="status" data-aico-empty{% unless aico_products.empty? %} hidden{% endunless %}>
      {{ 'products.no_results' | t }}
    </p>

    <ul class="aico-products-grid" data-aico-products-grid{% if aico_products.empty? %} hidden{% endif %}>
      {% for product in aico_products %}
        <li class="aico-products-grid-item" data-aico-product-id="{{ product.id }}">
          {% render 'product-card',
            url: product.url,
            image: product.featured_image,
            title: product.title,
            sku: product.aico_sku,
            price_label: product.aico_price_label,
            compare_at_label: product.aico_compare_at_price_label,
            discount_percent: product.aico_discount_percent,
            on_sale: product.aico_is_on_sale?,
            is_new: product.aico_is_new?,
            discontinued: product.aico_is_discontinued?,
            eager: forloop.index0 < 8,
            show_reviews: false %}
        </li>
      {% endfor %}
    </ul>

    <div class="aico-products-loader" data-aico-loader hidden>
      <span class="aico-products-spinner" aria-hidden="true"></span>
      <span class="aico-sr-only">{{ 'products.loading' | t }}</span>
    </div>

    <div class="aico-products-end" data-aico-end hidden>
      <span>{{ 'products.end_of_results' | t }}</span>
    </div>

    <div class="aico-products-sentinel" data-aico-products-sentinel aria-hidden="true"></div>
  </div>

  <script id="aico-products-config" type="application/json">{{ aico_products_config.json }}</script>
  <script src="{{ 'products-page.js' | asset_url }}" defer></script>
</main>
