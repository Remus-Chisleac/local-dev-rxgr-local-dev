{% comment %}
  Product detail page — Shopify-canonical `templates/product.liquid`
  (singular). Server-side render of the `product` drop hydrated by
  `Modules\Storefront\Services\ProductDetailLoader`.

  The renderer currently uses `Keepsuit\Liquid\FileSystems\BlankFileSystem`,
  so `{% render 'snippet' %}` does NOT resolve to files on disk. Until a
  proper filesystem-backed loader lands, the section markup that would
  normally live in `snippets/product-*.liquid` is inlined below in a
  one-section-per-block layout. The snippet boundaries are kept as
  comments so a follow-up can lift each block into its own file
  verbatim.

  Naming follows Shopify's contract: `product.id`, `product.title`,
  `product.featured_image`, `product.price`, `product.compare_at_price`,
  `product.available?`, `product.variants`, `product.options`. Anything
  B2B-specific is `product.aico_*` so a Shopify-authored theme drops in
  cleanly.

  TODO follow-ups (see PDP plan §2 "Defer"):
    - 360° rotator (build a static gallery only for now).
    - Restock-reminder button (stub).
    - Reviews section.
    - "More colors" cross-product grid (the related strip lives here;
      the per-product color grid lands later).
    - Warehouse-level stock breakdown UI (we expose the indicator only).
    - Wishlist / save-for-later.
{% endcomment %}

<main class="aico-pdp" role="main">
  <div class="aico-page-container aico-pdp-shell">

    <a href="{{ routes.products_url }}" class="aico-pdp-back" data-aico-back>
      <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      <span>{{ 'product.back_to_products' | t }}</span>
    </a>

    <div class="aico-pdp-hero">

      {%- comment -%} ──── product-gallery (inline) ──── {%- endcomment -%}
      <section
        class="aico-pdp-gallery"
        data-aico-pdp-gallery
        {% if product.sku and product.sku != '' %}data-aico-product-sku="{{ product.sku }}"{% endif %}
        data-aico-360-aria="{{ 'product.gallery.three_sixty_aria' | t }}"
        data-aico-360-hint="{{ 'product.gallery.rotate_hint' | t }}"
        aria-label="{{ 'product.gallery.aria' | t }}"
      >
        {% if product.images.size > 0 %}
          <div class="aico-pdp-gallery-frame">
            {% for image in product.images %}
              <figure class="aico-pdp-gallery-slide{% if forloop.first %} aico-pdp-gallery-slide-active{% endif %}" data-aico-gallery-slide data-aico-gallery-index="{{ forloop.index0 }}">
                <img
                  src="{{ image }}"
                  alt="{{ product.title }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  decoding="async"
                >
              </figure>
            {% endfor %}

            {% if product.images.size > 1 %}
              <button type="button" class="aico-pdp-gallery-nav aico-pdp-gallery-nav-prev" data-aico-gallery-prev aria-label="{{ 'product.gallery.previous' | t }}">
                <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m15 18-6-6 6-6"></path>
                </svg>
              </button>
              <button type="button" class="aico-pdp-gallery-nav aico-pdp-gallery-nav-next" data-aico-gallery-next aria-label="{{ 'product.gallery.next' | t }}">
                <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </button>
            {% endif %}
          </div>

          {% if product.images.size > 1 %}
            <div class="aico-pdp-gallery-thumbs" role="tablist">
              {% for image in product.images %}
                <button
                  type="button"
                  class="aico-pdp-gallery-thumb{% if forloop.first %} aico-pdp-gallery-thumb-active{% endif %}"
                  data-aico-gallery-thumb
                  data-aico-gallery-index="{{ forloop.index0 }}"
                  aria-label="{{ 'product.gallery.thumb_aria' | t }}"
                >
                  <img src="{{ image }}" alt="" loading="lazy" decoding="async">
                </button>
              {% endfor %}
            </div>
          {% endif %}

          {% comment %} TODO: 360° rotator goes after the thumbs — defer per plan §2. {% endcomment %}
        {% else %}
          <div class="aico-pdp-gallery-empty" role="img" aria-label="{{ 'product.gallery.no_image' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10"></path>
              <path d="m3 21 9-9 4 4 8-8"></path>
              <line x1="2" x2="22" y1="2" y2="22"></line>
            </svg>
          </div>
        {% endif %}
      </section>

      <div class="aico-pdp-info">

        {%- comment -%} ──── product-header (inline) ──── {%- endcomment -%}
        <header class="aico-pdp-header">
          <div class="aico-pdp-header-row">
            <h1 class="aico-pdp-title">{{ product.title }}</h1>
            <div class="aico-pdp-header-meta">
              {% if product.sku %}
                <span class="aico-pdp-sku" aria-label="{{ 'product.sku_aria' | t }}">{{ product.sku }}</span>
              {% endif %}
              {% if product.aico_production_status_label %}
                <span class="aico-pdp-status-pill">{{ product.aico_production_status_label }}</span>
              {% endif %}
            </div>
          </div>

          {% if product.aico_brand %}
            <p class="aico-pdp-brand">
              <a href="{{ product.aico_brand.url }}">{{ product.aico_brand.label }}</a>
            </p>
          {% endif %}

          {%- comment -%} ──── product-price (inline) ──── {%- endcomment -%}
          <div class="aico-pdp-price-block">
            {% if product.aico_price_label %}
              <p class="aico-pdp-price">
                {% if product.aico_compare_at_price_label %}
                  <span class="aico-pdp-price-list">{{ product.aico_compare_at_price_label }}</span>
                {% endif %}
                <span class="aico-pdp-price-current">{{ product.aico_price_label }}</span>
                {% if product.aico_discount_percent %}
                  <span class="aico-pdp-discount">−{{ product.aico_discount_percent }}%</span>
                {% endif %}
              </p>
              {% if product.aico_retail_price_label %}
                <p class="aico-pdp-rrp">
                  <span class="aico-pdp-rrp-label">{{ 'product.rrp' | t }}</span>
                  <span class="aico-pdp-rrp-value">{{ product.aico_retail_price_label }}</span>
                </p>
              {% endif %}
            {% else %}
              <p class="aico-pdp-price aico-pdp-price-on-request">
                {{ 'product.price_on_request' | t }}
              </p>
            {% endif %}
          </div>

          {% if product.aico_small_description %}
            <p class="aico-pdp-small-description">{{ product.aico_small_description }}</p>
          {% endif %}
        </header>

        {%- comment -%} ──── product-buy-panel (inline) ──── {%- endcomment -%}
        <form
          class="aico-pdp-buy"
          method="post"
          action="{% if product.aico_has_size_matrix? %}{{ routes.cart_update_url }}{% else %}{{ routes.cart_add_url }}{% endif %}"
          data-aico-pdp-buy
          data-aico-cart-add
          data-aico-has-size-matrix="{% if product.aico_has_size_matrix? %}1{% else %}0{% endif %}"
        >
          <input type="hidden" name="_token" value="{{ aico_csrf_token }}">
          <input type="hidden" name="product_id" value="{{ product.id }}">
          <input type="hidden" name="return_url" value="{{ request.path }}">

          {%- comment -%} ──── product-options (radio chips for non-size options) ──── {%- endcomment -%}
          {% if product.aico_has_size_matrix? %}
            {%- comment -%}
              Matrix mode: render every non-size option as a radio chip group.
              The size option becomes the column header of the matrix below.
            {%- endcomment -%}
            {% for option in product.options %}
              {% if option.name != product.aico_size_option_name %}
                <fieldset class="aico-pdp-option-group" data-aico-option="{{ option.name | escape }}">
                  <legend class="aico-pdp-option-legend">{{ option.name }}</legend>
                  <div class="aico-pdp-option-chips">
                    {% for value in option.values %}
                      <label class="aico-pdp-chip">
                        <input
                          type="radio"
                          name="options[{{ option.name | escape }}]"
                          value="{{ value | escape }}"
                          {% if forloop.first %}checked{% endif %}
                          data-aico-option-input
                        >
                        <span class="aico-pdp-chip-label">{{ value }}</span>
                      </label>
                    {% endfor %}
                  </div>
                </fieldset>
              {% endif %}
            {% endfor %}

            {%- comment -%} ──── product-size-matrix (inline) ──── {%- endcomment -%}
            <section class="aico-pdp-size-matrix" data-aico-size-matrix aria-label="{{ 'product.size_matrix.aria' | t }}">
              <div class="aico-pdp-size-matrix-head">
                <div class="aico-pdp-size-matrix-toolbar" role="presentation">
                  <div class="aico-pdp-size-matrix-head-tabs-wrap">
                    {%- assign size_guide_url = settings.aico_pdp_size_guide_url | strip -%}
                    <div class="aico-pdp-size-region-tabs" role="tablist" aria-label="{{ 'product.size_region.aria' | t }}" data-aico-size-region-tabs>
                      {%- assign size_regions = 'EU,UK,US,MM' | split: ',' -%}
                      {% for region in size_regions %}
                    <button
                      type="button"
                      role="tab"
                      class="aico-pdp-size-region-tab{% if forloop.first %} aico-pdp-size-region-tab-active{% endif %}"
                      aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                      data-aico-size-region
                      data-region="{{ region }}"
                    >
                      {% case region %}
                        {% when 'EU' %}
                          {{ 'product.size_region.tab_eu' | t }}
                        {% when 'UK' %}
                          {{ 'product.size_region.tab_uk' | t }}
                        {% when 'US' %}
                          {{ 'product.size_region.tab_us' | t }}
                        {% when 'MM' %}
                          {{ 'product.size_region.tab_mm' | t }}
                        {% else %}
                          {{ region }}
                      {% endcase %}
                    </button>
                  {% endfor %}
                    </div>
                  </div>

                  <div class="aico-pdp-size-guide">
                    {% if size_guide_url != blank %}
                      <span class="aico-pdp-size-guide-wrap">
                        <a
                          href="{{ size_guide_url }}"
                          class="aico-pdp-size-guide-link"
                          target="_blank"
                          rel="noopener noreferrer"
                        >{{ 'product.size_guide.link' | t }}</a>
                        <span class="aico-pdp-size-guide-pop" role="tooltip">{{ 'product.size_guide.tooltip' | t }}</span>
                      </span>
                    {% else %}
                      <span class="aico-pdp-size-guide-wrap">
                        <span tabindex="0" class="aico-pdp-size-guide-link aico-pdp-size-guide-link--disabled" aria-disabled="true">{{ 'product.size_guide.soon' | t }}</span>
                        <span class="aico-pdp-size-guide-pop" role="tooltip">{{ 'product.size_guide.soon_tooltip' | t }}</span>
                      </span>
                    {% endif %}
                  </div>
                </div>
              </div>

              <div class="aico-pdp-size-grid">
                {% for variant in product.variants %}
                  {% if variant.aico_size_value %}
                    {%- comment -%}
                      Pre-fill each cell with the quantity already in the
                      cart for this variant, so the matrix mirrors the cart
                      on every visit (set-absolute semantics — see
                      routes.cart_update_url). `data-aico-initial` lets the
                      script tell "no change" from "zeroed to remove".
                    {%- endcomment -%}
                    {%- assign cart_qty = 0 -%}
                    {%- if cart -%}
                      {%- for line in cart.items -%}
                        {%- if line.variant_id == variant.id -%}
                          {%- assign cart_qty = line.quantity -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                    <label
                      class="aico-pdp-size-cell{% if variant.available? and variant.aico_stock_amount > 0 %} aico-pdp-size-cell-in-stock{% elsif variant.available? %} aico-pdp-size-cell-available{% else %} aico-pdp-size-cell-out{% endif %}{% if cart_qty > 0 %} aico-pdp-size-cell-in-cart{% endif %}"
                      data-aico-size-cell
                    >
                      <span
                        class="aico-pdp-size-cell-label"
                        data-aico-size-label
                        data-aico-label-eu="{{ variant.aico_size_label_eu | default: variant.aico_size_value | escape }}"
                        data-aico-label-uk="{{ variant.aico_size_label_uk | default: variant.aico_size_value | escape }}"
                        data-aico-label-us="{{ variant.aico_size_label_us | default: variant.aico_size_value | escape }}"
                        data-aico-label-mm="{{ variant.aico_size_label_mm | default: variant.aico_size_value | escape }}"
                      >{{ variant.aico_size_label_eu | default: variant.aico_size_value }}</span>
                      <span class="aico-pdp-qty-box" data-aico-stepper>
                        <input
                          type="number"
                          class="aico-pdp-size-cell-input"
                          name="updates[{{ variant.id }}]"
                          min="0"
                          max="{{ variant.aico_stock_amount }}"
                          step="1"
                          value="{{ cart_qty }}"
                          inputmode="numeric"
                          data-aico-size-qty
                          data-aico-variant-id="{{ variant.id }}"
                          data-aico-variant-stock="{{ variant.aico_stock_amount }}"
                          data-aico-initial="{{ cart_qty }}"
                          aria-label="{{ 'product.size_matrix.qty_aria' | t }}"
                          {% unless variant.available? %}disabled{% endunless %}
                        >
                        <span class="aico-pdp-qty-box__spinners" aria-hidden="true">
                          <button type="button" class="aico-pdp-qty-box__step" data-aico-step="1" tabindex="-1" aria-label="{{ 'product.size_matrix.increase' | t }}"{% unless variant.available? %} disabled{% endunless %}>
                            <svg viewBox="0 0 8 5" width="8" height="5" aria-hidden="true"><path d="M1 4 L4 1 L7 4" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                          </button>
                          <button type="button" class="aico-pdp-qty-box__step" data-aico-step="-1" tabindex="-1" aria-label="{{ 'product.size_matrix.decrease' | t }}"{% unless variant.available? %} disabled{% endunless %}>
                            <svg viewBox="0 0 8 5" width="8" height="5" aria-hidden="true"><path d="M1 1 L4 4 L7 1" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                          </button>
                        </span>
                      </span>
                      <span class="aico-pdp-size-cell-stock aico-sr-only">
                        {% if variant.aico_stock_amount > 0 %}
                          {{ variant.aico_stock_amount }}
                        {% else %}
                          —
                        {% endif %}
                      </span>
                    </label>
                  {% endif %}
                {% endfor %}
              </div>

              <p class="aico-pdp-size-total" data-aico-size-total>
                {{ 'product.size_matrix.total' | t }}
                <strong data-aico-size-total-value>0</strong>
              </p>
            </section>
          {% else %}
            {%- comment -%}
              Legacy mode: dropdown per option + a single quantity stepper.
              The variant id is resolved client-side from the selected options.
            {%- endcomment -%}
            {% for option in product.options %}
              <label class="aico-pdp-option-row">
                <span class="aico-pdp-option-legend">{{ option.name }}</span>
                <select name="options[{{ option.name | escape }}]" data-aico-option-input class="aico-pdp-select">
                  <option value="">{{ 'product.choose' | t }}</option>
                  {% for value in option.values %}
                    <option value="{{ value | escape }}">{{ value }}</option>
                  {% endfor %}
                </select>
              </label>
            {% endfor %}

            <label class="aico-pdp-option-row">
              <span class="aico-pdp-option-legend">{{ 'product.quantity' | t }}</span>
              <span class="aico-pdp-qty-box aico-pdp-qty-box--lg" data-aico-stepper>
                <input
                  type="number"
                  class="aico-pdp-qty-input"
                  name="quantity"
                  min="1"
                  step="1"
                  value="1"
                  inputmode="numeric"
                  data-aico-qty-input
                >
                <span class="aico-pdp-qty-box__spinners" aria-hidden="true">
                  <button type="button" class="aico-pdp-qty-box__step" data-aico-step="1" tabindex="-1" aria-label="{{ 'product.size_matrix.increase' | t }}">
                    <svg viewBox="0 0 8 5" width="8" height="5" aria-hidden="true"><path d="M1 4 L4 1 L7 4" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <button type="button" class="aico-pdp-qty-box__step" data-aico-step="-1" tabindex="-1" aria-label="{{ 'product.size_matrix.decrease' | t }}">
                    <svg viewBox="0 0 8 5" width="8" height="5" aria-hidden="true"><path d="M1 1 L4 4 L7 1" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </span>
              </span>
            </label>

            {% comment %}
              Hidden field for the resolved variant id. The vanilla JS
              fills this in when the user picks options; the server can
              also resolve it from the option map as a fallback.
              Products WITHOUT any option axis (e.g. single-variant sets)
              have nothing to pick, so prefill the resolved variant id —
              otherwise the client-side pre-flight misreads the blank id
              as "no size selected" and blocks add-to-cart.
            {% endcomment %}
            {% if product.options.size == 0 %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-aico-variant-id-input>
            {% else %}
              <input type="hidden" name="id" value="" data-aico-variant-id-input>
            {% endif %}
          {% endif %}

          {%- comment -%}
            The matrix submits ABSOLUTE quantities (routes.cart_update_url),
            but "Update cart" only reads right once the cart already holds
            this product — before that the action is an add. The server picks
            the initial label from the cart; product-detail.js re-syncs it
            after each successful bulk update via the data-label-* attributes.
          {%- endcomment -%}
          {%- assign product_cart_qty = 0 -%}
          {%- if cart -%}
            {%- for line in cart.items -%}
              {%- if line.product_id == product.id -%}
                {%- assign product_cart_qty = product_cart_qty | plus: line.quantity -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          <div class="aico-pdp-buy-actions">
            <button
              type="submit"
              class="aico-pdp-buy-button"
              data-aico-buy-button
              {% if product.aico_shipping_blocked? %}disabled{% endif %}
            >
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
                <path d="M3 6h18"></path>
                <path d="M16 10a4 4 0 0 1-8 0"></path>
              </svg>
              <span
                data-aico-buy-label
                data-label-add="{{ 'product.add_to_cart' | t | escape }}"
                data-label-update="{{ 'product.update_cart' | t | escape }}"
              >
                {% if product.aico_shipping_blocked? %}
                  {{ 'product.restricted' | t }}
                {% elsif product.aico_has_size_matrix? and product_cart_qty > 0 %}
                  {{ 'product.update_cart' | t }}
                {% else %}
                  {{ 'product.add_to_cart' | t }}
                {% endif %}
              </span>
            </button>

            {%- comment -%}
              Production-cockpit restock integration. The block is hydrated by
              assets/aico-production-cockpit.js from
              `account/aico-cockpit/products/{sku}.js` (same-origin, cookie-
              authorized). If the SKU has a restock date it shows the date + a
              Set/Update-reminder button opening the SAME shared modal as the
              cockpit page; otherwise the block stays hidden (no layout shift).
              SKU-scoped, so it only ever appears for B2B sessions whose debtor
              has the product in a restock feed match.
            {%- endcomment -%}
            <div
              class="aico-cockpit-restock"
              data-aico-cockpit-restock
              data-aico-cockpit-sku="{{ product.sku | escape }}"
              data-aico-cockpit-token="{{ aico_csrf_token }}"
              data-aico-cockpit-product-url="{{ routes.aico_production_cockpit_product_url }}"
              data-aico-cockpit-reminders-url="{{ routes.aico_production_cockpit_reminders_url }}"
              data-aico-cockpit-new-release-url="{{ routes.aico_production_cockpit_new_release_url }}"
              hidden>
              <script type="application/json" data-aico-cockpit-i18n>{
                "set_reminder": {{ 'aico_production_cockpit.set_reminder' | t | json }},
                "table": { "restock_date": {{ 'aico_production_cockpit.table.columns.restock_date' | t | json }} },
                "reminder_modal": {
                  "manage_for": {{ 'aico_production_cockpit.reminder_modal.manage_for' | t | json }},
                  "choose_size": {{ 'aico_production_cockpit.reminder_modal.choose_size' | t | json }},
                  "cancel": {{ 'aico_production_cockpit.reminder_modal.cancel' | t | json }},
                  "save": {{ 'aico_production_cockpit.reminder_modal.save' | t | json }},
                  "update": {{ 'aico_production_cockpit.reminder_modal.update' | t | json }},
                  "legend_active": {{ 'aico_production_cockpit.reminder_modal.legend_active' | t | json }},
                  "legend_add": {{ 'aico_production_cockpit.reminder_modal.legend_add' | t | json }},
                  "legend_remove": {{ 'aico_production_cockpit.reminder_modal.legend_remove' | t | json }},
                  "toast_updated": {{ 'aico_production_cockpit.reminder_modal.toast_updated' | t | json }},
                  "toast_error": {{ 'aico_production_cockpit.reminder_modal.toast_error' | t | json }}
                }
              }</script>
            </div>
          </div>

          {% if product.aico_shipping_blocked? %}
            <p class="aico-pdp-buy-hint aico-pdp-buy-hint-danger">{{ 'product.shipping_blocked_hint' | t }}</p>
          {% endif %}

          <p class="aico-pdp-stock-indicator" data-aico-stock-indicator data-aico-stock="{{ product.aico_stock_indicator }}">
            {% if product.aico_stock_indicator == 'in_stock' %}
              <span class="aico-pdp-stock-dot aico-pdp-stock-dot-ok"></span>
              {{ 'product.stock.in_stock' | t }}
            {% elsif product.aico_stock_indicator == 'low' %}
              <span class="aico-pdp-stock-dot aico-pdp-stock-dot-low"></span>
              {{ 'product.stock.low' | t }}
            {% else %}
              <span class="aico-pdp-stock-dot aico-pdp-stock-dot-out"></span>
              {{ 'product.stock.out' | t }}
            {% endif %}
          </p>
        </form>

        {%- comment -%} ──── product-more-colors (inline) ──── {%- endcomment -%}
        {%- comment -%}
          Colour siblings come from the PIM connected-products relation
          (`product.aico_color_siblings`) — the same source the legacy
          b2b-shop rendered. Like the legacy shop, the strip sits directly
          under the add-to-cart block: a single horizontal row that scrolls
          sideways with a hidden scrollbar (wheel/drag glue lives in
          product-detail.js; touch scrolls natively). The current product
          is NOT shown in the strip — the shopper is already on it, so the
          row lists only the *other* colours (the url guard below is
          belt-and-braces on top of the backend's own SKU exclusion).
        {%- endcomment -%}
        {% if product.aico_color_siblings.size > 0 %}
          <section class="aico-pdp-colors" aria-labelledby="aico-pdp-colors-heading">
            <h2 id="aico-pdp-colors-heading" class="aico-pdp-section-heading">{{ 'product.more_colors' | t }}</h2>
            <div class="aico-pdp-color-strip" data-aico-color-strip>
              {% for sibling in product.aico_color_siblings limit: 11 %}
                {% if sibling.url == product.url %}{% continue %}{% endif %}
                <a class="aico-pdp-color-tile" href="{{ sibling.url }}" title="{{ sibling.title }}" aria-label="{{ sibling.title }}">
                  {% if sibling.featured_image %}
                    <img src="{{ sibling.featured_image }}" alt="" loading="lazy" decoding="async">
                  {% endif %}
                </a>
              {% endfor %}
            </div>
          </section>
        {% endif %}
      </div>
    </div>

    {%- comment -%} ──── product-info-tabs (inline) ──── {%- endcomment -%}
    {%- comment -%}
      Specifications + description share one section behind a tab switcher.
      Specifications is the default tab; description is the second tab.
      The tab JS lives in `product-detail.js`; with JS off, both panels
      render (only the active one is un-hidden by CSS/markup) so the copy
      is never lost. Downloads stay in their own block below the tabs.
    {%- endcomment -%}
    {% if product.aico_specs.size > 0 or product.description %}
      <section class="aico-pdp-info-tabs" aria-label="{{ 'product.info_tabs_aria' | t }}">
        <div class="aico-pdp-tabs" role="tablist" aria-label="{{ 'product.info_tabs_aria' | t }}" data-aico-pdp-tabs>
          {% if product.aico_specs.size > 0 %}
            <button
              type="button"
              role="tab"
              id="aico-pdp-tab-specs"
              class="aico-pdp-tab aico-pdp-tab-active"
              aria-selected="true"
              aria-controls="aico-pdp-panel-specs"
              data-aico-pdp-tab="specs"
            >{{ 'product.specs' | t }}</button>
          {% endif %}
          {% if product.description %}
            <button
              type="button"
              role="tab"
              id="aico-pdp-tab-description"
              class="aico-pdp-tab{% unless product.aico_specs.size > 0 %} aico-pdp-tab-active{% endunless %}"
              aria-selected="{% if product.aico_specs.size > 0 %}false{% else %}true{% endif %}"
              aria-controls="aico-pdp-panel-description"
              data-aico-pdp-tab="description"
            >{{ 'product.about_product' | t }}</button>
          {% endif %}
        </div>

        {% if product.aico_specs.size > 0 %}
          <div
            role="tabpanel"
            id="aico-pdp-panel-specs"
            class="aico-pdp-tab-panel aico-pdp-tab-panel-active"
            aria-labelledby="aico-pdp-tab-specs"
            data-aico-pdp-panel="specs"
          >
            <dl class="aico-pdp-specs">
              {% for row in product.aico_specs %}
                <div class="aico-pdp-specs-row">
                  <dt>{% if row.label_key %}{{ row.label_key | t }}{% else %}{{ row.label }}{% endif %}</dt>
                  <dd>{% if row.value_key %}{{ row.value_key | t }}{% else %}{{ row.value }}{% endif %}</dd>
                </div>
              {% endfor %}
            </dl>
          </div>
        {% endif %}

        {% if product.description %}
          <div
            role="tabpanel"
            id="aico-pdp-panel-description"
            class="aico-pdp-tab-panel{% unless product.aico_specs.size > 0 %} aico-pdp-tab-panel-active{% endunless %}"
            aria-labelledby="aico-pdp-tab-description"
            data-aico-pdp-panel="description"
            {% if product.aico_specs.size > 0 %}hidden{% endif %}
          >
            <div class="aico-pdp-info-prose">{{ product.description }}</div>
          </div>
        {% endif %}
      </section>
    {% endif %}

    {% if product.aico_files.size > 0 %}
      <section class="aico-pdp-info-tabs aico-pdp-downloads-section" aria-label="{{ 'product.downloads' | t }}">
        <article class="aico-pdp-info-block">
          <h2 class="aico-pdp-section-heading">{{ 'product.downloads' | t }}</h2>
          <ul class="aico-pdp-files">
            {% for file in product.aico_files %}
              <li>
                <a href="{{ file.url }}" target="_blank" rel="noopener noreferrer">
                  {{ file.name }}
                  {% if file.size_label %}
                    <span class="aico-pdp-files-size">{{ file.size_label }}</span>
                  {% endif %}
                </a>
              </li>
            {% endfor %}
          </ul>
        </article>
      </section>
    {% endif %}

    {%- comment -%} ──── product-related-strip (inline) ──── {%- endcomment -%}
    {% if product.aico_related_products.size > 0 %}
      <section class="aico-pdp-related" aria-label="{{ 'product.you_may_also_like' | t }}">
        <h2 class="aico-pdp-section-heading">{{ 'product.you_may_also_like' | t }}</h2>
        <ul class="aico-products-grid aico-pdp-related-grid">
          {% for related in product.aico_related_products %}
            <li class="aico-products-grid-item">
              <article class="aico-product-card">
                <a href="{{ related.url }}" class="aico-product-card-link" aria-label="{{ related.title }}">
                  <div class="aico-product-card-image-wrap">
                    {% if related.featured_image %}
                      <img class="aico-product-card-image" src="{{ related.featured_image }}" alt="" loading="lazy" decoding="async">
                    {% else %}
                      <div class="aico-product-card-image-empty" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 15V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10"></path>
                          <path d="m3 21 9-9 4 4 8-8"></path>
                        </svg>
                      </div>
                    {% endif %}
                  </div>
                  <div class="aico-product-card-body">
                    <h3 class="aico-product-card-title">{{ related.title }}</h3>
                  </div>
                </a>
              </article>
            </li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}

    {%- comment -%}
      Product reviews (Yotpo). Replaces the previous static mock block. Shown
      only when reviews are configured (the same gate as the loader below:
      reviews enabled + a store App Key) so there's no empty section until
      then. product-id is the SKU, matching the per-card star widget
      (snippets/product-card); currency uses cart.currency_code.
    {%- endcomment -%}
    {% if settings.aico_reviews_enabled and settings.aico_yotpo_app_key and settings.aico_yotpo_app_key != '' and product.sku and product.sku != '' %}
      <section class="aico-pdp-reviews" aria-label="{{ 'product.reviews.title' | t }}">
        <div class="yotpo-widget-instance"
             data-yotpo-instance-id="639491"
             data-yotpo-product-id="{{ product.sku }}"
             data-yotpo-name="{{ product.title | escape }}"
             data-yotpo-url="{{ product.url }}"
             data-yotpo-image-url="{{ product.featured_image }}"
             data-yotpo-price="{{ product.price }}"
             data-yotpo-currency="{{ cart.currency_code | default: 'CHF' }}"></div>
      </section>
    {% endif %}
  </div>

  {%- comment -%} Yotpo widgets loader — hydrates the reviews widget above (gated on the reviews flag + store App Key). {%- endcomment -%}
  {% render 'yotpo-loader' %}

  {%- comment -%}
    Localised copy for product-detail.js's post-submit hints. Without this
    blob the script falls back to its hardcoded English strings.
  {%- endcomment -%}
  <script>
    window.AICO_PDP_LOCALE = {
      select_quantity: {{ 'product.aico_pdp_message.select_quantity' | t | json }},
      error: {{ 'product.aico_pdp_message.error' | t | json }}
    };
  </script>
  <script src="{{ 'product-detail.js' | asset_url }}" defer></script>
  {%- comment -%} Hydrates the production-cockpit restock block above (PDP integration). {%- endcomment -%}
  <script src="{{ 'aico-production-cockpit.js' | asset_url }}" defer></script>
</main>
