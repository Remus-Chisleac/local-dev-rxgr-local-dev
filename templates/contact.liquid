{% comment %}
  Contact page (`/contact`) — recreates the b2b shop's contact page: a heading
  and the company-info card (no form, matching the live b2b layout). Company
  details are inlined as in the b2b shop; a theme can edit them directly.
{% endcomment %}

<main class="aico-page-container aico-contact" aria-labelledby="aico-contact-heading">
  <h1 id="aico-contact-heading" class="aico-contact-heading">{{ 'contact.title' | t }}</h1>

  <aside class="aico-contact-card">
    <p class="aico-contact-company">kybun Joya</p>
    <p class="aico-contact-lines">
      kybun Joya Retail AG<br>
      kybun Tower<br>
      Mühleweg 4<br>
      CH-9325 Roggwil (TG)<br>
      Tel CH: +41 58 329 40 40<br>
      Tel DE: +49 7531 921 60 60<br>
      Email: <a href="mailto:partner@kybunjoya.swiss">partner@kybunjoya.swiss</a>
    </p>
    <p class="aico-contact-whatsapp">
      <svg class="aico-contact-whatsapp-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true">
        <path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm5.8 14.01c-.24.68-1.42 1.31-1.95 1.36-.5.05-1.13.07-1.83-.11-.42-.13-.96-.31-1.65-.61-2.9-1.25-4.79-4.17-4.94-4.36-.14-.19-1.18-1.57-1.18-2.99 0-1.42.75-2.12 1.01-2.41.26-.29.57-.36.76-.36.19 0 .38 0 .55.01.18.01.41-.07.64.49.24.57.81 1.97.88 2.11.07.14.12.31.02.5-.1.19-.14.31-.29.48-.14.17-.3.38-.43.51-.14.14-.29.29-.12.57.17.29.74 1.22 1.59 1.98 1.09.97 2.01 1.27 2.3 1.41.29.14.46.12.63-.07.17-.19.72-.84.91-1.13.19-.29.38-.24.64-.14.26.09 1.66.78 1.94.93.29.14.48.21.55.33.07.12.07.68-.17 1.36z"/>
      </svg>
      <a href="https://wa.me/41583294040" target="_blank" rel="noopener">{{ 'contact.whatsapp_chat' | t }}</a>
    </p>
  </aside>
</main>
