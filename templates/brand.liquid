{% comment %}
  Brand landing page (AICO storefront — Shopify-nonstandard `/brand/<handle>`).

  Server-rendered from per-brand theme settings (`aico_brand_campaigns[<handle>]`)
  plus live catalog + news data:

    • Hero banner  — campaign image / heading / CTA (falls back to the
      brand's own image + label when no campaign is configured).
    • Gender selector — Damen / Herren links into the brand-scoped products
      listing (`aico_brand_url_women` / `aico_brand_url_men`).
    • Featured products — the four SKUs pinned in the campaign, hydrated by
      the renderer into `aico_brand_products` (skeleton fallback when none).
    • Aktuelles — the latest three articles for this brand (`aico_brand_news`).

  Themes built before `brand.liquid` shipped still render: the PHP renderer
  falls back to this scaffold copy. Unknown PIM slugs synthesise a labelled
  placeholder so the layout is always previewable.
{% endcomment %}

<main class="aico-brand-page" role="main" aria-label="{{ 'brand_page.aria_main' | t }}">

  {%- comment -%} ── Hero banner ── {%- endcomment -%}
  <section class="aico-brand-hero" aria-labelledby="aico-brand-hero-heading">
    {% if aico_brand_hero.image_url %}
      <img class="aico-brand-hero-photo" src="{{ aico_brand_hero.image_url }}" alt="" loading="eager">
    {% else %}
      <div class="aico-brand-hero-bg-skeleton" aria-hidden="true"></div>
    {% endif %}
    <div class="aico-brand-hero-scrim"></div>

    <div class="aico-page-container aico-brand-hero-inner">
      <div class="aico-brand-hero-copy">
        <h1 id="aico-brand-hero-heading" class="aico-brand-hero-heading">
          {% if aico_brand_hero.title %}{{ aico_brand_hero.title }}{% else %}{{ aico_brand.label }}{% endif %}
        </h1>

        {% if aico_brand_hero.aico_has_cta? %}
          <a class="aico-button aico-button-primary aico-brand-hero-cta" href="{{ aico_brand_hero.cta_url }}">
            {{ aico_brand_hero.cta_label }}
          </a>
        {% endif %}

        {% if aico_brand.aico_placeholder? %}
          <p class="aico-brand-unknown-banner" role="status">{{ 'brand_page.unknown_brand_notice' | t }}</p>
        {% else %}
          {% unless aico_brand.aico_is_accessible? %}
            <p class="aico-brand-restricted-banner" role="status">{{ 'brand_page.restricted_notice' | t }}</p>
          {% endunless %}
        {% endif %}
      </div>
    </div>
  </section>

  {%- comment -%} ── Gender selector ── {%- endcomment -%}
  <nav class="aico-page-container aico-brand-gender" aria-label="{{ 'brand_page.categories_aria' | t }}">
    <a class="aico-brand-gender-link" href="{{ aico_brand_url_women }}">{{ 'brand_page.gender_women' | t }}</a>
    <span class="aico-brand-gender-sep" aria-hidden="true">–</span>
    <a class="aico-brand-gender-link" href="{{ aico_brand_url_men }}">{{ 'brand_page.gender_men' | t }}</a>
  </nav>

  {%- comment -%} ── Featured products (4 pinned SKUs) ── {%- endcomment -%}
  <section class="aico-page-container aico-brand-products" aria-labelledby="aico-brand-products-heading">
    <h2 id="aico-brand-products-heading" class="aico-brand-products-heading aico-visually-hidden">
      {{ 'brand_page.products_heading' | t }}
    </h2>

    {% if aico_brand_products.size > 0 %}
      <ul class="aico-products-grid aico-brand-product-grid" role="list">
        {% for product in aico_brand_products %}
          <li class="aico-products-grid-item" data-aico-product-id="{{ product.id }}">
            {% render 'product-card',
              url: product.url,
              image: product.featured_image,
              title: product.title,
              sku: product.aico_sku,
              price_label: product.aico_price_label,
              compare_at_label: product.aico_compare_at_price_label,
              discount_percent: product.aico_discount_percent,
              on_sale: product.aico_is_on_sale?,
              is_new: product.aico_is_new?,
              discontinued: product.aico_is_discontinued?,
              eager: forloop.index0 < 4,
              show_reviews: true %}
          </li>
        {% endfor %}
      </ul>
    {% else %}
      {%- comment -%} No SKUs pinned for this brand yet — deterministic skeleton keeps the layout previewable. {%- endcomment -%}
      <ul class="aico-products-grid aico-brand-product-grid" role="list">
        {% for iteration in (1..4) %}
          <li class="aico-products-grid-item">
            {% render 'product-card', skeleton: true, show_reviews: true %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </section>

  {%- comment -%} ── Aktuelles (latest 3 brand articles) ── {%- endcomment -%}
  {% if aico_brand_news.size > 0 %}
    <section class="aico-page-container aico-brand-news" aria-labelledby="aico-brand-news-heading">
      <h2 id="aico-brand-news-heading" class="aico-brand-news-heading">{{ 'brand_page.news_heading' | t }}</h2>
      <ul class="aico-brand-news-grid" role="list">
        {% for article in aico_brand_news %}
          <li class="aico-brand-news-card">
            <a class="aico-brand-news-link" href="{{ article.url }}">
              <div class="aico-brand-news-image">
                {% if article.image %}
                  <img src="{{ article.image }}" alt="" loading="lazy" style="object-position: {{ article.aico_object_position }};">
                {% endif %}
              </div>
              <h3 class="aico-brand-news-title">{{ article.title }}</h3>
            </a>
          </li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

  {% render 'yotpo-loader' %}
</main>
