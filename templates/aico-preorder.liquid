              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <input type="search" class="aico-preorder-search-input" name="q"
                   placeholder="{{ 'aico_preorder.filters.search_placeholder' | t }}"
                   data-aico-preorder-search>
          </span>
        </label>

        <div class="aico-preorder-field aico-preorder-field-dates" data-aico-field="dates">
          <span id="aico-preorder-dates-label" class="aico-preorder-field-label">{{ 'aico_preorder.catalog.dates_label' | t }}</span>
          <div class="aico-preorder-field-control aico-preorder-field-control-select">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4"></path><path d="M8 2v4"></path><path d="M3 10h18"></path>
            </svg>
            <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select data-aico-custom-select-managed>
              <select name="date_filter" class="aico-preorder-select-native" tabindex="-1" aria-hidden="true"
                      aria-labelledby="aico-preorder-dates-label" data-aico-preorder-date-select>
                <option value="__all__">{{ 'aico_preorder.catalog.dates_all' | t }}</option>
              </select>
              <button type="button" id="aico-preorder-dates-trigger" class="aico-preorder-custom-select-trigger"
