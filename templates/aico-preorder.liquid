{% comment %}
  AICO preorder landing page — slim hero variant.

  Layout intentionally trimmed back to the "above-the-fold" hero only
  (image / title / countdown) plus a compact filter row underneath
  (search · size region · billing · delivery · view toggle). The legacy
  items grid, checkout summary, and floating-cart sections are
  intentionally removed for this iteration — they land back when the
  preorder cart endpoint ships.

  Mock data:
    Title and countdown defaults live in theme settings
    (`config/settings_data.json` → `aico_preorder_mock_*`) so a
    merchant can override the demo session from the editor without
    touching the live `PreorderSession` model. The JS controller
    computes the deadline = now + (mock_weeks + mock_days + mock_hours
    + mock_minutes + mock_seconds) on first visit and stores it in
    sessionStorage so refreshes don't reset the countdown mid-session.

  Address loading:
    The billing + delivery dropdowns are hydrated by
    `PreorderContextLoader::load()`, which calls
    `IAicoShopAddressService::getAddressesForAicoShopUser()` —
    the same endpoint b2b-shop's `useGetAddressesPageQuery` hits
    (see `b2b-shop/src/lib/redux/slices/addressSlice.js:6`,
    URL pattern `/aico-shops/{id}/addresses?debtorId={id}`). When
    a real `PreorderSession` exists the existing `aico_preorder.*`
    drop wins; otherwise the mock theme-setting defaults render.

  Filter row contract for follow-ups:
    All cells live on one flex row. The view-toggle is intentionally
    `flex: 0 0 auto` (the last element does not grow) — it will drive
    the grid/list product display when the items grid lands again.
{% endcomment %}

{%- assign preorder_session = aico_preorder.session -%}
{%- assign mock_title = settings.aico_preorder_mock_title | default: 'PreOrder Ramadan 2027' -%}
{%- assign hero_title = preorder_session.title -%}
{%- if hero_title == blank -%}{%- assign hero_title = mock_title -%}{%- endif -%}
{%- assign hero_image = preorder_session.hero_image_url -%}
{%- assign hero_bg_asset = settings.aico_preorder_hero_bg_asset | default: 'preorder-hero-bg.png' -%}
{%- assign preorder_b2b_count = aico_preorder.b2b_choices | size -%}

{%- assign mock_weeks = settings.aico_preorder_mock_weeks | default: 5 -%}
{%- assign mock_days = settings.aico_preorder_mock_days | default: 16 -%}
{%- assign mock_hours = settings.aico_preorder_mock_hours | default: 0 -%}
{%- assign mock_minutes = settings.aico_preorder_mock_minutes | default: 10 -%}
{%- assign mock_seconds = settings.aico_preorder_mock_seconds | default: 11 -%}

<main class="aico-preorder" role="main"
      data-aico-preorder
      data-aico-preorder-user-id="{{ customer.id }}"
      data-aico-preorder-context-url="{{ routes.aico_account_preorder_context_url }}"
      {% if preorder_session.deadline_at %}data-aico-preorder-deadline="{{ preorder_session.deadline_at }}"{% endif %}
      data-aico-preorder-mock-weeks="{{ mock_weeks }}"
      data-aico-preorder-mock-days="{{ mock_days }}"
      data-aico-preorder-mock-hours="{{ mock_hours }}"
      data-aico-preorder-mock-minutes="{{ mock_minutes }}"
      data-aico-preorder-mock-seconds="{{ mock_seconds }}">

  {%- comment -%} ── Hero band ── {%- endcomment -%}
  <section class="aico-preorder-hero" style="--aico-preorder-hero-bg: url('{{ hero_bg_asset | asset_url }}');" aria-labelledby="aico-preorder-hero-title">
    <div class="aico-preorder-hero-overlay" aria-hidden="true"></div>
    <div class="aico-page-container aico-preorder-hero-inner">
      <div class="aico-preorder-hero-text">
        <h1 id="aico-preorder-hero-title" class="aico-preorder-hero-title">{{ hero_title }}</h1>
      </div>

      <div class="aico-preorder-hero-side">
        {% if hero_image %}
          <div class="aico-preorder-hero-product">
            <img class="aico-preorder-hero-image"
                 src="{{ hero_image }}"
                 alt=""
                 loading="eager"
                 decoding="async">
          </div>
        {% endif %}

        <div class="aico-preorder-countdown" data-aico-preorder-countdown role="group"
             aria-label="{{ 'aico_preorder.session.deadline_label' | t }}">
          <p class="aico-preorder-countdown-eyebrow">{{ 'aico_preorder.session.deadline_label' | t }}</p>
          <div class="aico-preorder-countdown-bar" role="presentation">
            <div class="aico-preorder-countdown-segment">
              <span class="aico-preorder-countdown-value" data-aico-countdown-days>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.days' | t }}</span>
            </div>
            <span class="aico-preorder-countdown-sep" aria-hidden="true">:</span>
            <div class="aico-preorder-countdown-segment">
              <span class="aico-preorder-countdown-value" data-aico-countdown-hours>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.hours' | t }}</span>
            </div>
            <span class="aico-preorder-countdown-sep" aria-hidden="true">:</span>
            <div class="aico-preorder-countdown-segment">
              <span class="aico-preorder-countdown-value" data-aico-countdown-minutes>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.minutes' | t }}</span>
            </div>
            <span class="aico-preorder-countdown-sep" aria-hidden="true">:</span>
            <div class="aico-preorder-countdown-segment">
              <span class="aico-preorder-countdown-value" data-aico-countdown-seconds>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.seconds' | t }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ── Compact filter row ── {%- endcomment -%}
  <section class="aico-preorder-filters-wrap" aria-labelledby="aico-preorder-filters-title">
    <div class="aico-page-container">
      <h2 id="aico-preorder-filters-title" class="aico-sr-only">{{ 'aico_preorder.filters.section_aria' | t }}</h2>

      <form class="aico-preorder-filters"
            data-aico-preorder-filters
            method="post"
            action="{{ routes.aico_account_preorder_context_url }}"
            autocomplete="off">
        <input type="hidden" name="_token" value="{{ aico_csrf_token }}">

        {%- comment -%} B2B (only when backend emits multiple choices) {%- endcomment -%}
        {% if preorder_b2b_count > 0 %}
          <div class="aico-preorder-field aico-preorder-field-b2b" data-aico-field="b2b">
            <span id="aico-preorder-b2b-label" class="aico-preorder-field-label">{{ 'aico_preorder.filters.b2b_label' | t }}</span>
            <div class="aico-preorder-field-control aico-preorder-field-control-select">
              <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select>
                <select name="b2b_id" class="aico-preorder-select-native" tabindex="-1" aria-hidden="true"
                        data-aico-preorder-select="b2b_id">
                  <option value="">{{ 'aico_preorder.filters.b2b_placeholder' | t }}</option>
                  {% for choice in aico_preorder.b2b_choices %}
                    <option value="{{ choice.id }}"{% if aico_preorder.selected_b2b_id == choice.id %} selected{% endif %}>
                      {{ choice.label }}
                    </option>
                  {% endfor %}
                </select>
                <button type="button"
                        id="aico-preorder-b2b-trigger"
                        class="aico-preorder-custom-select-trigger"
                        data-aico-custom-select-trigger
                        aria-haspopup="listbox"
                        aria-expanded="false"
                      aria-labelledby="aico-preorder-b2b-label">
                  <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                  <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </button>
                <div class="aico-preorder-custom-select-dropdown" data-aico-custom-select-dropdown hidden>
                  <div role="listbox" class="aico-preorder-custom-select-list" data-aico-custom-select-list></div>
                </div>
              </div>
            </div>
          </div>
        {% endif %}

        {%- comment -%} Search (placeholder until the items grid returns) {%- endcomment -%}
        <label class="aico-preorder-field aico-preorder-field-search" data-aico-field="search">
          <span class="aico-preorder-field-label">{{ 'aico_preorder.filters.search_label' | t }}</span>
          <span class="aico-preorder-field-control">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <input
              type="search"
              class="aico-preorder-search-input"
              name="q"
              placeholder="{{ 'aico_preorder.filters.search_placeholder' | t }}"
              data-aico-preorder-search>
          </span>
        </label>

        {%- assign size_selected = aico_preorder.size_region | default: 'EU' | upcase -%}
        <div class="aico-preorder-field aico-preorder-field-size" data-aico-field="size_region">
          <span id="aico-preorder-size-label" class="aico-preorder-field-label">{{ 'aico_preorder.filters.size_region_label' | t }}</span>
          <div class="aico-preorder-field-control aico-preorder-field-control-select">
            <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select>
              <select name="size_region" class="aico-preorder-select-native" tabindex="-1" aria-hidden="true"
                      data-aico-preorder-select="size_region">
                <option value="EU" {% if size_selected == 'EU' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_eu' | t }}</option>
                <option value="UK" {% if size_selected == 'UK' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_uk' | t }}</option>
                <option value="US" {% if size_selected == 'US' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_us' | t }}</option>
                <option value="KR" {% if size_selected == 'KR' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_mm' | t }}</option>
              </select>
              <button type="button"
                      id="aico-preorder-size-trigger"
                      class="aico-preorder-custom-select-trigger"
                      data-aico-custom-select-trigger
                      aria-haspopup="listbox"
                      aria-expanded="false"
                      aria-labelledby="aico-preorder-size-label">
                <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="aico-preorder-custom-select-dropdown" data-aico-custom-select-dropdown hidden>
                <div role="listbox" class="aico-preorder-custom-select-list" data-aico-custom-select-list></div>
              </div>
            </div>
          </div>
        </div>

        <div class="aico-preorder-field" data-aico-field="billing_address">
          <span id="aico-preorder-billing-label" class="aico-preorder-field-label">{{ 'aico_preorder.filters.billing_label' | t }}</span>
          <div class="aico-preorder-field-control aico-preorder-field-control-select">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 14V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v8"></path>
              <path d="M3 14h18"></path>
              <path d="M5 14v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6"></path>
            </svg>
            <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select>
              <select name="billing_address_id"
                      class="aico-preorder-select-native"
                      tabindex="-1"
                      aria-labelledby="aico-preorder-billing-label"
                      aria-hidden="true"
                      data-aico-preorder-select="billing_address_id"
                      {% if aico_preorder.billing_addresses == empty %}disabled{% endif %}>
                <option value="">{{ 'aico_preorder.filters.billing_placeholder' | t }}</option>
                {% for address in aico_preorder.billing_addresses %}
                  <option value="{{ address.id }}"{% if aico_preorder.selected_billing_address_id == address.id %} selected{% endif %}>
                    {{ address.label }}
                  </option>
                {% endfor %}
              </select>
              <button type="button"
                      id="aico-preorder-billing-trigger"
                      class="aico-preorder-custom-select-trigger"
                      data-aico-custom-select-trigger
                      aria-haspopup="listbox"
                      aria-expanded="false"
                      aria-labelledby="aico-preorder-billing-label"
                      {% if aico_preorder.billing_addresses == empty %}disabled{% endif %}>
                <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="aico-preorder-custom-select-dropdown" data-aico-custom-select-dropdown hidden>
                <div role="listbox" class="aico-preorder-custom-select-list" data-aico-custom-select-list></div>
              </div>
            </div>
          </div>
        </div>

        <div class="aico-preorder-field" data-aico-field="delivery_address">
          <span id="aico-preorder-delivery-label" class="aico-preorder-field-label">{{ 'aico_preorder.filters.delivery_label' | t }}</span>
          <div class="aico-preorder-field-control aico-preorder-field-control-select">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select>
              <select name="delivery_address_id"
                      class="aico-preorder-select-native"
                      tabindex="-1"
                      aria-labelledby="aico-preorder-delivery-label"
                      aria-hidden="true"
                      data-aico-preorder-select="delivery_address_id"
                      {% if aico_preorder.delivery_addresses == empty %}disabled{% endif %}>
                <option value="">{{ 'aico_preorder.filters.delivery_placeholder' | t }}</option>
                {% for address in aico_preorder.delivery_addresses %}
                  <option value="{{ address.id }}"{% if aico_preorder.selected_delivery_address_id == address.id %} selected{% endif %}>
                    {{ address.label }}
                  </option>
                {% endfor %}
              </select>
              <button type="button"
                      id="aico-preorder-delivery-trigger"
                      class="aico-preorder-custom-select-trigger"
                      data-aico-custom-select-trigger
                      aria-haspopup="listbox"
                      aria-expanded="false"
                      aria-labelledby="aico-preorder-delivery-label"
                      {% if aico_preorder.delivery_addresses == empty %}disabled{% endif %}>
                <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="aico-preorder-custom-select-dropdown" data-aico-custom-select-dropdown hidden>
                <div role="listbox" class="aico-preorder-custom-select-list" data-aico-custom-select-list></div>
              </div>
            </div>
          </div>
        </div>

        <div class="aico-preorder-view-toggle" role="group" aria-label="{{ 'aico_preorder.filters.view_grid' | t }}">
          <button type="button" class="aico-preorder-view-button aico-preorder-view-button-active"
                  data-aico-preorder-view="grid" aria-pressed="true" aria-label="{{ 'aico_preorder.filters.view_grid' | t }}">
            <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="7" height="7" x="3" y="3" rx="1"></rect>
              <rect width="7" height="7" x="14" y="3" rx="1"></rect>
              <rect width="7" height="7" x="14" y="14" rx="1"></rect>
              <rect width="7" height="7" x="3" y="14" rx="1"></rect>
            </svg>
          </button>
          <button type="button" class="aico-preorder-view-button"
                  data-aico-preorder-view="list" aria-pressed="false" aria-label="{{ 'aico_preorder.filters.view_list' | t }}">
            <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="8" x2="21" y1="6" y2="6"></line>
              <line x1="8" x2="21" y1="12" y2="12"></line>
              <line x1="8" x2="21" y1="18" y2="18"></line>
              <line x1="3" x2="3.01" y1="6" y2="6"></line>
              <line x1="3" x2="3.01" y1="12" y2="12"></line>
              <line x1="3" x2="3.01" y1="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </section>

  <script src="{{ 'preorder-page.js' | asset_url }}" defer></script>
</main>
