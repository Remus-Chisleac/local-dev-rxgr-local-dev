                <option value="EU" {% if size_selected == 'EU' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_eu' | t }}</option>
                <option value="UK" {% if size_selected == 'UK' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_uk' | t }}</option>
                <option value="US" {% if size_selected == 'US' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_us' | t }}</option>
                <option value="KR" {% if size_selected == 'KR' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_mm' | t }}</option>
              </select>
              <button type="button" id="aico-preorder-size-trigger" class="aico-preorder-custom-select-trigger"
                      data-aico-custom-select-trigger aria-haspopup="listbox" aria-expanded="false"
                      aria-labelledby="aico-preorder-size-label">
                <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="aico-preorder-custom-select-dropdown" data-aico-custom-select-dropdown hidden>
                <div role="listbox" class="aico-preorder-custom-select-list" data-aico-custom-select-list></div>
              </div>
            </div>
          </div>
        </div>
        </div>
      </form>
    </div>
  </section>

  <section class="aico-preorder-prompt aico-page-container" data-aico-preorder-prompt aria-live="polite">
    <h2 class="aico-preorder-prompt-title">{{ 'aico_preorder.catalog.select_addresses' | t }}</h2>
  </section>

  <section class="aico-preorder-reopen-notice aico-page-container" data-aico-preorder-reopen-notice hidden aria-live="polite" role="status">
    <div class="aico-preorder-reopen-notice-inner">
      <h2 class="aico-preorder-reopen-notice-title">{{ 'aico_preorder.reopen_notice.title' | t }}</h2>
      <p class="aico-preorder-reopen-notice-body">{{ 'aico_preorder.reopen_notice.body' | t }}</p>
      <button type="button" class="aico-preorder-reopen-notice-btn" data-aico-preorder-reopen-ack>{{ 'aico_preorder.reopen_notice.acknowledge' | t }}</button>
    </div>
  </section>

  <section class="aico-preorder-main-wrap aico-page-container" aria-labelledby="aico-preorder-main-title" hidden data-aico-preorder-main>
    <h2 id="aico-preorder-main-title" class="aico-sr-only">{{ 'aico_preorder.catalog.section_aria' | t }}</h2>
    <p class="aico-preorder-catalog-error" data-aico-preorder-error hidden role="alert">{{ 'aico_preorder.catalog.error' | t }}</p>

    <div class="aico-preorder-catalog" data-aico-preorder-catalog></div>
    <p class="aico-preorder-load-more" data-aico-preorder-load-more hidden>{{ 'aico_preorder.catalog.loading_more' | t }}</p>

    <section class="aico-preorder-flyers" data-aico-preorder-flyers hidden aria-label="{{ 'aico_preorder.flyers.section_aria' | t }}">
      <h3 class="aico-preorder-flyers-title">{{ 'aico_preorder.flyers.title' | t }}</h3>
      <div class="aico-preorder-flyers-grid" data-aico-preorder-flyers-grid></div>
    </section>
  </section>

  <section class="aico-preorder-checkout-wrap aico-page-container" hidden data-aico-preorder-checkout>
    <div class="aico-preorder-checkout-panel" data-aico-preorder-summary aria-label="{{ 'aico_preorder.summary.section_aria' | t }}">
      <div class="aico-preorder-checkout-addresses">
        <div class="aico-preorder-checkout-address">
          <p class="aico-preorder-checkout-address-label">{{ 'aico_preorder.summary.billing_address' | t }}</p>
          <p class="aico-preorder-checkout-address-value" data-aico-preorder-summary-billing>—</p>
        </div>
        <div class="aico-preorder-checkout-address">
          <p class="aico-preorder-checkout-address-label">{{ 'aico_preorder.summary.delivery_address' | t }}</p>
          <p class="aico-preorder-checkout-address-value" data-aico-preorder-summary-delivery>—</p>
        </div>
      </div>
      <hr class="aico-preorder-checkout-divider">
      <div class="aico-preorder-checkout-grid">
        <div class="aico-preorder-checkout-dates" data-aico-preorder-summary-lines></div>
        <div class="aico-preorder-checkout-totals-box">
          <div class="aico-preorder-checkout-total-row" data-aico-preorder-summary-subtotal-row></div>
          <div class="aico-preorder-checkout-total-row" data-aico-preorder-summary-discount-row hidden></div>
          <hr class="aico-preorder-checkout-divider">
          <div class="aico-preorder-checkout-grand-total" data-aico-preorder-summary-total></div>
        </div>
      </div>
      <p class="aico-preorder-checkout-alert" data-aico-preorder-stock-warning>
        <svg class="aico-preorder-checkout-alert__icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" focusable="false"><path fill="currentColor" d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm0 1.3a5.2 5.2 0 1 1 0 10.4 5.2 5.2 0 0 1 0-10.4ZM8 4.1a.95.95 0 1 0 0 1.9.95.95 0 0 0 0-1.9Zm-.8 3.05V11.9h1.6V7.15H7.2Z"/></svg>
        <span class="aico-preorder-checkout-alert__text">{{ 'aico_preorder.summary.stock_warning' | t }}</span>
      </p>
      <label class="aico-preorder-notes">
        <span class="aico-preorder-field-label">{{ 'aico_preorder.summary.notes_label' | t }}</span>
        <textarea name="notes" rows="3" data-aico-preorder-notes></textarea>
      </label>
      {% if preorder_session.terms_pdf_url != blank %}
        <label class="aico-preorder-terms">
          <input type="checkbox" data-aico-preorder-terms>
          <span>{{ 'aico_preorder.summary.terms_prefix' | t }}
            <a href="{{ preorder_session.terms_pdf_url }}" target="_blank" rel="noopener">{{ 'aico_preorder.summary.terms_link' | t }}</a>
          </span>
        </label>
      {% else %}
        <label class="aico-preorder-terms">
          <input type="checkbox" data-aico-preorder-terms>
          <span>{{ 'aico_preorder.summary.terms_checkbox' | t }}</span>
        </label>
      {% endif %}
      <p class="aico-preorder-summary-status" data-aico-preorder-summary-status hidden></p>
      <div class="aico-preorder-checkout-actions">
        <button type="button" class="aico-preorder-btn aico-preorder-btn-place" data-aico-preorder-submit disabled>{{ 'aico_preorder.summary.place_order' | t }}</button>
      </div>
    </div>
  </section>

  <div class="aico-preorder-gallery" data-aico-preorder-gallery hidden role="dialog" aria-modal="true" aria-labelledby="aico-preorder-gallery-title">
    <div class="aico-preorder-gallery-backdrop" data-aico-preorder-gallery-close></div>
    <div class="aico-preorder-gallery-dialog" role="document">
      <button type="button" class="aico-preorder-gallery-close" data-aico-preorder-gallery-close aria-label="{{ 'general.close' | t | default: 'Schliessen' }}">&times;</button>
      <h3 class="aico-preorder-gallery-title" id="aico-preorder-gallery-title" data-aico-preorder-gallery-title></h3>
      <div class="aico-preorder-gallery-stage">
        <button type="button" class="aico-preorder-gallery-nav aico-preorder-gallery-prev" data-aico-preorder-gallery-prev aria-label="Zurück" hidden>&lsaquo;</button>
        <div class="aico-preorder-gallery-main">
          <img class="aico-preorder-gallery-main-img" data-aico-preorder-gallery-main alt="" decoding="async">
          <p class="aico-preorder-gallery-empty" data-aico-preorder-gallery-empty hidden>{{ 'aico_preorder.catalog.error' | t }}</p>
        </div>
        <button type="button" class="aico-preorder-gallery-nav aico-preorder-gallery-next" data-aico-preorder-gallery-next aria-label="Weiter" hidden>&rsaquo;</button>
      </div>
      <div class="aico-preorder-gallery-thumbs" data-aico-preorder-gallery-thumbs></div>
    </div>
  </div>

  <script src="{{ 'preorder-catalog.js' | asset_url }}" defer></script>
  <script src="{{ 'preorder-stock.js' | asset_url }}" defer></script>
  <script src="{{ 'preorder-cart.js' | asset_url }}" defer></script>
  <script src="{{ 'preorder-page.js' | asset_url }}" defer></script>
</main>
