{% comment %}
  AICO preorder landing page — b2b-shop parity (catalog, cart, submit).

  Countdown:
    The countdown is driven solely by the active `PreorderSession`
    end date (`preorder_session.deadline_at`, server-rendered into
    `data-aico-preorder-deadline`, then refreshed from
    `preorder/session.js`). When no preorder session is active the
    countdown shows "--" placeholders — there is no hardcoded/mock fallback.

  Hero title:
    Falls back to `settings.aico_preorder_mock_title` only when no live
    session title is bound to the page.

  Address loading:
    The billing + delivery dropdowns are hydrated by
    `PreorderContextLoader::load()`, which calls
    `IAicoShopAddressService::getAddressesForAicoShopUser()` —
    the same endpoint b2b-shop's `useGetAddressesPageQuery` hits
    (see `b2b-shop/src/lib/redux/slices/addressSlice.js:6`,
    URL pattern `/aico-shops/{id}/addresses?debtorId={id}`). When
    a real `PreorderSession` exists the existing `aico_preorder.*`
    drop wins; otherwise the mock theme-setting defaults render.

  Filter row contract for follow-ups:
    All cells live on one flex row. The view-toggle is intentionally
    `flex: 0 0 auto` (the last element does not grow) — it will drive
    the grid/list product display when the items grid lands again.
{% endcomment %}

{%- assign preorder_session = aico_preorder.session -%}
{%- comment -%} The active session (title, banner image, gradient colors, deadline)
   is resolved per buyer/debtor and hydrated CLIENT-SIDE from
   `preorder/session.js` — it is not bound to the Liquid drop at first render
   (same as the countdown). The hero is therefore a shell that `preorder-page.js`
   fills in: title from `welcomeMessage`, image from `collectionImage`, and the
   full-bleed vertical gradient from `gradientColorStart/End`. No hardcoded asset. {%- endcomment -%}

<main class="aico-preorder" role="main"
      data-aico-preorder
      data-aico-preorder-user-id="{{ customer.id }}"
      data-aico-preorder-context-url="{{ routes.aico_account_preorder_context_url }}"
      data-aico-preorder-session-url="{{ routes.aico_preorder_session_url }}"
      data-aico-preorder-products-url="{{ routes.aico_preorder_products_url }}"
      data-aico-preorder-product-images-url="{{ routes.aico_preorder_product_images_url }}"
      data-aico-preorder-cart-url="{{ routes.aico_preorder_cart_url }}"
      data-aico-preorder-cart-add-url="{{ routes.aico_preorder_cart_add_url }}"
      data-aico-preorder-cart-change-url="{{ routes.aico_preorder_cart_change_url }}"
      data-aico-preorder-cart-clear-url="{{ routes.aico_preorder_cart_clear_url }}"
      data-aico-preorder-cart-submit-url="{{ routes.aico_preorder_cart_submit_url }}"
      data-aico-preorder-thank-you-url="{{ routes.aico_preorder_thank_you_url }}"
      data-aico-preorder-addresses-url="{{ routes.aico_preorder_addresses_url }}"
      data-aico-preorder-eligibility-url="{{ routes.aico_preorder_eligibility_url }}"
      data-aico-preorder-b2bs-url="{{ routes.aico_preorder_b2bs_url }}"
      data-aico-preorder-is-manager="{% if aico_preorder.is_manager %}1{% else %}0{% endif %}"
      data-aico-preorder-selected-debtor-id="{{ aico_preorder.selected_debtor_id }}"
      data-aico-preorder-enable-cart="1"
      data-aico-preorder-copy-select-debtor="{{ 'aico_preorder.catalog.select_debtor' | t | escape }}"
      data-aico-preorder-is-stock-relevant="{% if preorder_session.is_stock_relevant %}1{% else %}0{% endif %}"
      data-aico-preorder-copy-empty="{{ 'aico_preorder.catalog.empty' | t | escape }}"
      data-aico-preorder-copy-loading="{{ 'aico_preorder.catalog.loading' | t | escape }}"
      data-aico-preorder-copy-error="{{ 'aico_preorder.catalog.error' | t | escape }}"
      data-aico-preorder-copy-select-addresses="{{ 'aico_preorder.catalog.select_addresses' | t | escape }}"
      data-aico-preorder-copy-total="{{ 'aico_preorder.summary.total' | t | escape }}"
      data-aico-preorder-copy-discount="{{ 'aico_preorder.summary.discount' | t | escape }}"
      data-aico-preorder-copy-saving="{{ 'aico_preorder.summary.saving' | t | escape }}"
      data-aico-preorder-copy-saved="{{ 'aico_preorder.summary.saved' | t | escape }}"
      data-aico-preorder-copy-submitting="{{ 'aico_preorder.summary.submitting' | t | escape }}"
      data-aico-preorder-copy-submitted="{{ 'aico_preorder.summary.submitted' | t | escape }}"
      data-aico-preorder-copy-committed="{{ 'aico_preorder.summary.committed_warning' | t | escape }}"
      data-aico-preorder-copy-products-heading="{{ 'aico_preorder.catalog.products_heading' | t | escape }}"
      data-aico-preorder-copy-row-total="{{ 'aico_preorder.catalog.row_total' | t | escape }}"
      data-aico-preorder-copy-product-total="{{ 'aico_preorder.catalog.product_total' | t | escape }}"
      data-aico-preorder-copy-pcs="{{ 'aico_preorder.catalog.pcs' | t | escape }}"
      data-aico-preorder-copy-flyer-total="{{ 'aico_preorder.flyers.total' | t | escape }}"
      data-aico-preorder-copy-billing="{{ 'aico_preorder.summary.billing_address' | t | escape }}"
      data-aico-preorder-copy-delivery="{{ 'aico_preorder.summary.delivery_address' | t | escape }}"
      data-aico-preorder-copy-excl-vat="{{ 'aico_preorder.summary.excl_vat' | t | escape }}"
      data-aico-preorder-copy-subtotal="{{ 'aico_preorder.summary.subtotal' | t | escape }}"
      data-aico-preorder-copy-stock-warning="{{ 'aico_preorder.summary.stock_warning' | t | escape }}"
      {% if preorder_session.deadline_at %}data-aico-preorder-deadline="{{ preorder_session.deadline_at }}"{% endif %}>

  {%- comment -%} SSR-embedded session payload — the exact shape preorder/session.js
       returns in `data`. preorder-page.js hydrates from this at first paint and only
       falls back to fetching session.js when it is null/absent. {%- endcomment -%}
  <script type="application/json" data-aico-preorder-session-json>{{ aico_preorder.session_payload | json }}</script>

  {%- comment -%} ── Hero band: full-bleed vertical gradient (session colors) behind the
       session banner image + title text, with the countdown on the side. The
       image/title/gradient are filled in by preorder-page.js once the session
       resolves (data hooks below); empty shell until then. {%- endcomment -%}
  <section class="aico-preorder-hero" data-aico-preorder-hero aria-labelledby="aico-preorder-hero-title">
    <div class="aico-page-container aico-preorder-hero-inner">
      <div class="aico-preorder-hero-left">
        <h1 id="aico-preorder-hero-title" class="aico-preorder-hero-title" data-aico-preorder-hero-title></h1>
        <p class="aico-preorder-no-session" data-aico-preorder-no-session hidden>{{ 'aico_preorder.session.no_active' | t }}</p>
        {%- comment -%} Collection book: explicit labelled download (replaces the old
           b2b-shop affordance of clicking the hero banner image). Hidden until
           preorder-page.js resolves the session and finds a collectionBookUrl. {%- endcomment -%}
        <a class="aico-preorder-hero-book" data-aico-preorder-hero-book href="#" target="_blank" rel="noopener" hidden>
          <svg class="aico-preorder-hero-book-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          <span class="aico-preorder-hero-book-label">{{ 'aico_preorder.session.collection_book' | t }}</span>
        </a>
      </div>

      <div class="aico-preorder-hero-side">

        <img
          class="aico-preorder-banner-img"
          data-aico-preorder-hero-img
          src=""
          alt=""
          loading="eager"
          decoding="async"
          hidden>

        <div class="aico-preorder-countdown" data-aico-preorder-countdown role="group"
             aria-label="{{ 'aico_preorder.session.deadline_label' | t }}">
          <p class="aico-preorder-countdown-eyebrow">{{ 'aico_preorder.session.deadline_label' | t }}</p>
          <div class="aico-preorder-countdown-bar" role="presentation">
            <div class="aico-preorder-countdown-segment">
              <span class="aico-preorder-countdown-value" data-aico-countdown-days>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.days' | t }}</span>
            </div>
            <span class="aico-preorder-countdown-sep" aria-hidden="true">:</span>
            <div class="aico-preorder-countdown-segment">
              <span class="aico-preorder-countdown-value" data-aico-countdown-hours>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.hours' | t }}</span>
            </div>
            <span class="aico-preorder-countdown-sep" aria-hidden="true">:</span>
            <div class="aico-preorder-countdown-segment">
              <span class="aico-preorder-countdown-value" data-aico-countdown-minutes>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.minutes' | t }}</span>
            </div>
            <span class="aico-preorder-countdown-sep" aria-hidden="true">:</span>
            <div class="aico-preorder-countdown-segment">
              <span class="aico-preorder-countdown-value" data-aico-countdown-seconds>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.seconds' | t }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ── Compact filter row ── {%- endcomment -%}
  <section class="aico-preorder-filters-wrap" aria-labelledby="aico-preorder-filters-title" data-aico-preorder-filters-wrap>
    <div class="aico-page-container">
      <h2 id="aico-preorder-filters-title" class="aico-sr-only">{{ 'aico_preorder.filters.section_aria' | t }}</h2>

      <form class="aico-preorder-filters"
            data-aico-preorder-filters
            method="post"
            action="{{ routes.aico_account_preorder_context_url }}"
            autocomplete="off">
        <input type="hidden" name="_token" value="{{ aico_csrf_token }}">

        {%- comment -%} Setup row: billing + delivery (b2b-shop SortFilterControl, no B2B picker). {%- endcomment -%}
        <div class="aico-preorder-setup-filters" data-aico-preorder-setup-filters>
        {%- if aico_preorder.is_manager -%}
        <div class="aico-preorder-field aico-preorder-field-b2b" data-aico-field="b2b" data-aico-preorder-b2b-field>
          <span id="aico-preorder-b2b-label" class="aico-preorder-field-label">{{ 'aico_preorder.filters.b2b_label' | t }}</span>
          <div class="aico-preorder-field-control aico-preorder-field-control-select">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path><path d="M9 9v.01"></path><path d="M9 12v.01"></path><path d="M9 15v.01"></path>
            </svg>
            <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select>
              <select name="b2b_id" class="aico-preorder-select-native" tabindex="-1"
                      aria-labelledby="aico-preorder-b2b-label" aria-hidden="true"
                      data-aico-preorder-select="b2b_id" data-aico-preorder-b2b
                      data-placeholder="{{ 'aico_preorder.filters.b2b_placeholder' | t }}" disabled>
                <option value="">{{ 'aico_preorder.filters.b2b_placeholder' | t }}</option>
              </select>
              <button type="button" id="aico-preorder-b2b-trigger" class="aico-preorder-custom-select-trigger"
                      data-aico-custom-select-trigger aria-haspopup="listbox" aria-expanded="false"
                      aria-labelledby="aico-preorder-b2b-label" disabled>
                <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="aico-preorder-custom-select-dropdown" data-aico-custom-select-dropdown hidden>
                <div class="aico-preorder-b2b-search-wrap">
                  <input type="text" class="aico-preorder-b2b-search-input" data-aico-preorder-b2b-search
                         placeholder="{{ 'aico_preorder.filters.b2b_search_placeholder' | t }}" autocomplete="off">
                </div>
                <div role="listbox" class="aico-preorder-custom-select-list" data-aico-custom-select-list></div>
              </div>
            </div>
          </div>
        </div>

        <div class="aico-preorder-field aico-preorder-field-debtor" data-aico-field="debtor" data-aico-preorder-debtor-field hidden>
          <span id="aico-preorder-debtor-label" class="aico-preorder-field-label">{{ 'aico_preorder.filters.debtor_label' | t }}</span>
          <div class="aico-preorder-field-control aico-preorder-field-control-select">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>
            </svg>
            <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select>
              <select name="debtor_id" class="aico-preorder-select-native" tabindex="-1"
                      aria-labelledby="aico-preorder-debtor-label" aria-hidden="true"
                      data-aico-preorder-select="debtor_id" data-aico-preorder-debtor
                      data-placeholder="{{ 'aico_preorder.filters.debtor_placeholder' | t }}" disabled>
                <option value="">{{ 'aico_preorder.filters.debtor_placeholder' | t }}</option>
              </select>
              <button type="button" id="aico-preorder-debtor-trigger" class="aico-preorder-custom-select-trigger"
                      data-aico-custom-select-trigger aria-haspopup="listbox" aria-expanded="false"
                      aria-labelledby="aico-preorder-debtor-label" disabled>
                <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="aico-preorder-custom-select-dropdown" data-aico-custom-select-dropdown hidden>
                <div role="listbox" class="aico-preorder-custom-select-list" data-aico-custom-select-list></div>
              </div>
            </div>
          </div>
        </div>
        {%- endif -%}
        <div class="aico-preorder-field" data-aico-field="billing_address">
          <span id="aico-preorder-billing-label" class="aico-preorder-field-label">{{ 'aico_preorder.filters.billing_label' | t }}</span>
          <div class="aico-preorder-field-control aico-preorder-field-control-select">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 14V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v8"></path>
              <path d="M3 14h18"></path>
              <path d="M5 14v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6"></path>
            </svg>
            <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select>
              <select name="billing_address_id"
                      class="aico-preorder-select-native"
                      tabindex="-1"
                      aria-labelledby="aico-preorder-billing-label"
                      aria-hidden="true"
                      data-aico-preorder-select="billing_address_id"
                      data-placeholder="{{ 'aico_preorder.filters.billing_placeholder' | t }}"
                      {% if aico_preorder.billing_addresses == empty %}disabled{% endif %}>
                <option value="">{{ 'aico_preorder.filters.billing_placeholder' | t }}</option>
                {% for address in aico_preorder.billing_addresses %}
                  <option value="{{ address.id }}">{{ address.label }}</option>
                {% endfor %}
              </select>
              <button type="button"
                      id="aico-preorder-billing-trigger"
                      class="aico-preorder-custom-select-trigger"
                      data-aico-custom-select-trigger
                      aria-haspopup="listbox"
                      aria-expanded="false"
                      aria-labelledby="aico-preorder-billing-label"
                      {% if aico_preorder.billing_addresses == empty %}disabled{% endif %}>
                <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="aico-preorder-custom-select-dropdown" data-aico-custom-select-dropdown hidden>
                <div role="listbox" class="aico-preorder-custom-select-list" data-aico-custom-select-list></div>
              </div>
            </div>
          </div>
        </div>

        <div class="aico-preorder-field" data-aico-field="delivery_address">
          <span id="aico-preorder-delivery-label" class="aico-preorder-field-label">{{ 'aico_preorder.filters.delivery_label' | t }}</span>
          <div class="aico-preorder-field-control aico-preorder-field-control-select">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select>
              <select name="delivery_address_id"
                      class="aico-preorder-select-native"
                      tabindex="-1"
                      aria-labelledby="aico-preorder-delivery-label"
                      aria-hidden="true"
                      data-aico-preorder-select="delivery_address_id"
                      data-placeholder="{{ 'aico_preorder.filters.delivery_placeholder' | t }}"
                      {% if aico_preorder.delivery_addresses == empty %}disabled{% endif %}>
                <option value="">{{ 'aico_preorder.filters.delivery_placeholder' | t }}</option>
                {% for address in aico_preorder.delivery_addresses %}
                  <option value="{{ address.id }}" data-country="{{ address.country }}">{{ address.label }}</option>
                {% endfor %}
              </select>
              <button type="button"
                      id="aico-preorder-delivery-trigger"
                      class="aico-preorder-custom-select-trigger"
                      data-aico-custom-select-trigger
                      aria-haspopup="listbox"
                      aria-expanded="false"
                      aria-labelledby="aico-preorder-delivery-label"
                      {% if aico_preorder.delivery_addresses == empty %}disabled{% endif %}>
                <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
