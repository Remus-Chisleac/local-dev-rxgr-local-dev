          </div>
        </div>

        {%- assign size_selected = aico_preorder.size_region | default: 'EU' | upcase -%}
        <div class="aico-preorder-field aico-preorder-field-size" data-aico-field="size_region">
          <span id="aico-preorder-size-label" class="aico-preorder-field-label">{{ 'aico_preorder.filters.size_region_label' | t }}</span>
          <div class="aico-preorder-field-control aico-preorder-field-control-select">
            <div class="aico-preorder-custom-select aico-preorder-custom-select-grow" data-aico-custom-select>
              <select name="size_region" class="aico-preorder-select-native" tabindex="-1" aria-hidden="true"
                      data-aico-preorder-select="size_region">
                <option value="EU" {% if size_selected == 'EU' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_eu' | t }}</option>
                <option value="UK" {% if size_selected == 'UK' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_uk' | t }}</option>
                <option value="US" {% if size_selected == 'US' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_us' | t }}</option>
                <option value="KR" {% if size_selected == 'KR' %}selected{% endif %}>{{ 'aico_preorder.filters.size_region_option_mm' | t }}</option>
              </select>
              <button type="button" id="aico-preorder-size-trigger" class="aico-preorder-custom-select-trigger"
                      data-aico-custom-select-trigger aria-haspopup="listbox" aria-expanded="false"
                      aria-labelledby="aico-preorder-size-label">
                <span class="aico-preorder-custom-select-label" data-aico-custom-select-label></span>
                <svg class="aico-preorder-custom-select-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="aico-preorder-custom-select-dropdown" data-aico-custom-select-dropdown hidden>
                <div role="listbox" class="aico-preorder-custom-select-list" data-aico-custom-select-list></div>
              </div>
            </div>
          </div>
        </div>

        {%- comment -%} Display options: a gear that opens a small popover controlling
           how compact the catalog renders. Pure client-side view state (persisted in
           localStorage), applied as a class/attribute on the .aico-preorder root so it
           survives catalog re-renders. {%- endcomment -%}
        <div class="aico-preorder-field aico-preorder-field-display" data-aico-field="display" data-aico-preorder-display>
          <button type="button" class="aico-preorder-display-trigger" data-aico-preorder-display-trigger
                  aria-haspopup="true" aria-expanded="false" title="{{ 'aico_preorder.display.button_label' | t }}"
                  aria-label="{{ 'aico_preorder.display.button_label' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
          </button>
          <div class="aico-preorder-display-panel" data-aico-preorder-display-panel hidden role="dialog" aria-label="{{ 'aico_preorder.display.button_label' | t }}">
            <p class="aico-preorder-display-heading">{{ 'aico_preorder.display.heading' | t }}</p>

            <label class="aico-preorder-display-toggle">
              <input type="checkbox" data-aico-preorder-display-strip checked>
              <span class="aico-preorder-display-toggle-text">{{ 'aico_preorder.display.show_strip' | t }}</span>
            </label>

            <div class="aico-preorder-display-group" role="radiogroup" aria-label="{{ 'aico_preorder.display.size_labels_label' | t }}">
              <p class="aico-preorder-display-group-label">{{ 'aico_preorder.display.size_labels_label' | t }}</p>
              <label class="aico-preorder-display-radio">
                <input type="radio" name="aico-preorder-size-labels" value="all" data-aico-preorder-display-sizes checked>
                <span>{{ 'aico_preorder.display.size_labels_all' | t }}</span>
              </label>
              <label class="aico-preorder-display-radio">
                <input type="radio" name="aico-preorder-size-labels" value="first" data-aico-preorder-display-sizes>
                <span>{{ 'aico_preorder.display.size_labels_first' | t }}</span>
              </label>
              <label class="aico-preorder-display-radio">
                <input type="radio" name="aico-preorder-size-labels" value="none" data-aico-preorder-display-sizes>
                <span>{{ 'aico_preorder.display.size_labels_none' | t }}</span>
              </label>
            </div>
          </div>
        </div>
        </div>
      </form>
    </div>
  </section>

  <section class="aico-preorder-prompt aico-page-container" data-aico-preorder-prompt aria-live="polite">
    <h2 class="aico-preorder-prompt-title">{{ 'aico_preorder.catalog.select_addresses' | t }}</h2>
  </section>

  <section class="aico-preorder-reopen-notice aico-page-container" data-aico-preorder-reopen-notice hidden aria-live="polite" role="status">
    <div class="aico-preorder-reopen-notice-inner">
      <div class="aico-preorder-reopen-skeleton" aria-hidden="true">
        <span class="aico-preorder-reopen-skeleton-bar aico-preorder-reopen-skeleton-title"></span>
        <span class="aico-preorder-reopen-skeleton-bar aico-preorder-reopen-skeleton-line"></span>
        <span class="aico-preorder-reopen-skeleton-bar aico-preorder-reopen-skeleton-btn"></span>
      </div>
      <h2 class="aico-preorder-reopen-notice-title">{{ 'aico_preorder.reopen_notice.title' | t }}</h2>
      <p class="aico-preorder-reopen-notice-body">{{ 'aico_preorder.reopen_notice.body' | t }}</p>
      <button type="button" class="aico-preorder-reopen-notice-btn" data-aico-preorder-reopen-ack>{{ 'aico_preorder.reopen_notice.acknowledge' | t }}</button>
    </div>
  </section>

  {%- comment -%}
    Eligibility hard-block: shown (red) when the selected (customer, delivery,
    billing) context is not configured to place a preorder — e.g. a debtor with
    no seller/currency, a missing price list, or an incomplete address. The
    catalog + checkout stay hidden until the configuration is fixed; there is no
    acknowledge button (unlike the reopen notice) — only support can clear it.
    The per-problem sentence is selected client-side by the problem `code` from
    the data-aico-elig-msg-* templates below ({label} = the affected
    address/customer), so copy lives in locales and stays Shopify-compatible.
  {%- endcomment -%}
  <section
    class="aico-preorder-eligibility-notice aico-page-container"
    data-aico-preorder-eligibility-notice
    hidden
    aria-live="assertive"
    role="alert"
    data-aico-elig-msg-debtor-missing="{{ 'aico_preorder.eligibility.debtor_missing' | t }}"
    data-aico-elig-msg-debtor-missing-seller="{{ 'aico_preorder.eligibility.debtor_missing_seller' | t }}"
    data-aico-elig-msg-debtor-missing-currency="{{ 'aico_preorder.eligibility.debtor_missing_currency' | t }}"
    data-aico-elig-msg-missing-price-list="{{ 'aico_preorder.eligibility.missing_price_list' | t }}"
    data-aico-elig-msg-delivery-address-invalid="{{ 'aico_preorder.eligibility.delivery_address_invalid' | t }}"
    data-aico-elig-msg-billing-address-invalid="{{ 'aico_preorder.eligibility.billing_address_invalid' | t }}"
    data-aico-elig-msg-tax-not-configured="{{ 'aico_preorder.eligibility.tax_not_configured' | t }}"
    data-aico-elig-msg-fallback="{{ 'aico_preorder.eligibility.fallback' | t }}"
  >
    <div class="aico-preorder-eligibility-notice-inner">
      <h2 class="aico-preorder-eligibility-notice-title">{{ 'aico_preorder.eligibility.title' | t }}</h2>
      <p class="aico-preorder-eligibility-notice-intro">{{ 'aico_preorder.eligibility.intro' | t }}</p>
      <ul class="aico-preorder-eligibility-notice-list" data-aico-preorder-eligibility-list></ul>
      <p class="aico-preorder-eligibility-notice-support">{{ 'aico_preorder.eligibility.contact_support' | t }}</p>
    </div>
  </section>

  <section class="aico-preorder-main-wrap aico-page-container" aria-labelledby="aico-preorder-main-title" hidden data-aico-preorder-main>
    <h2 id="aico-preorder-main-title" class="aico-sr-only">{{ 'aico_preorder.catalog.section_aria' | t }}</h2>
    <p class="aico-preorder-catalog-error" data-aico-preorder-error hidden role="alert">{{ 'aico_preorder.catalog.error' | t }}</p>

    <div class="aico-preorder-catalog" data-aico-preorder-catalog></div>

    <section class="aico-preorder-flyers" data-aico-preorder-flyers hidden aria-label="{{ 'aico_preorder.flyers.section_aria' | t }}">
      <h3 class="aico-preorder-flyers-title">{{ 'aico_preorder.flyers.title' | t }}</h3>
      <div class="aico-preorder-flyers-grid" data-aico-preorder-flyers-grid></div>
    </section>
  </section>

  <section class="aico-preorder-checkout-wrap aico-page-container" hidden data-aico-preorder-checkout>
    <div class="aico-preorder-checkout-panel" data-aico-preorder-summary aria-label="{{ 'aico_preorder.summary.section_aria' | t }}">
      <div class="aico-preorder-checkout-addresses">
        <div class="aico-preorder-checkout-address">
          <p class="aico-preorder-checkout-address-label">{{ 'aico_preorder.summary.billing_address' | t }}</p>
          <p class="aico-preorder-checkout-address-value" data-aico-preorder-summary-billing>—</p>
        </div>
        <div class="aico-preorder-checkout-address">
          <p class="aico-preorder-checkout-address-label">{{ 'aico_preorder.summary.delivery_address' | t }}</p>
          <p class="aico-preorder-checkout-address-value" data-aico-preorder-summary-delivery>—</p>
        </div>
      </div>
      <hr class="aico-preorder-checkout-divider">
      <div class="aico-preorder-checkout-grid">
        <div class="aico-preorder-checkout-dates" data-aico-preorder-summary-lines></div>
        <div class="aico-preorder-checkout-totals-box">
          <div class="aico-preorder-checkout-total-row" data-aico-preorder-summary-subtotal-row></div>
          <div class="aico-preorder-checkout-total-row" data-aico-preorder-summary-discount-row hidden></div>
          <hr class="aico-preorder-checkout-divider">
          <div class="aico-preorder-checkout-grand-total" data-aico-preorder-summary-total></div>
        </div>
      </div>
      <p class="aico-preorder-checkout-alert" data-aico-preorder-stock-warning>
        <svg class="aico-preorder-checkout-alert__icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" focusable="false"><path fill="currentColor" d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm0 1.3a5.2 5.2 0 1 1 0 10.4 5.2 5.2 0 0 1 0-10.4ZM8 4.1a.95.95 0 1 0 0 1.9.95.95 0 0 0 0-1.9Zm-.8 3.05V11.9h1.6V7.15H7.2Z"/></svg>
        <span class="aico-preorder-checkout-alert__text">{{ 'aico_preorder.summary.stock_warning' | t }}</span>
      </p>
      <label class="aico-preorder-notes">
        <span class="aico-preorder-field-label">{{ 'aico_preorder.summary.notes_label' | t }}</span>
        <textarea name="notes" rows="3" data-aico-preorder-notes></textarea>
      </label>
      {% if preorder_session.terms_pdf_url != blank %}
        <label class="aico-preorder-terms">
          <input type="checkbox" data-aico-preorder-terms>
          <span>{{ 'aico_preorder.summary.terms_prefix' | t }}
            <a href="{{ preorder_session.terms_pdf_url }}" target="_blank" rel="noopener">{{ 'aico_preorder.summary.terms_link' | t }}</a>
          </span>
        </label>
      {% else %}
        <label class="aico-preorder-terms">
          <input type="checkbox" data-aico-preorder-terms>
          <span>{{ 'aico_preorder.summary.terms_checkbox' | t }}</span>
        </label>
      {% endif %}
      <p class="aico-preorder-summary-status" data-aico-preorder-summary-status hidden></p>
      <div class="aico-preorder-checkout-actions">
        <button type="button" class="aico-preorder-btn aico-preorder-btn-place" data-aico-preorder-submit disabled>{{ 'aico_preorder.summary.place_order' | t }}</button>
      </div>
    </div>
  </section>

  {%- comment -%} Sticky cart-summary panel — read-only live totals + a colour
       legend for the qty cells. Docks in the page gutter on wide (1080p+)
       screens (default right; the user can flip the side, persisted), and
       collapses to an edge tab on narrower screens. Ordering stays in the
       checkout section above; this panel has no action button. Visibility
       tracks the checkout section (shown once a session + addresses are set). {%- endcomment -%}
  <aside class="aico-preorder-cart-panel" data-aico-preorder-cart-panel data-side="right" hidden
         aria-label="{{ 'aico_preorder.cart_panel.title' | t }}">
    <button type="button" class="aico-preorder-cart-panel-tab" data-aico-preorder-cart-panel-tab
            aria-expanded="false" aria-label="{{ 'aico_preorder.cart_panel.show' | t }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
      </svg>
      <span class="aico-preorder-cart-panel-tab-qty" data-aico-preorder-cart-panel-tab-qty>0</span>
    </button>

    <div class="aico-preorder-cart-panel-body">
      <div class="aico-preorder-cart-panel-head">
        <h3 class="aico-preorder-cart-panel-title">{{ 'aico_preorder.cart_panel.title' | t }}</h3>
        <div class="aico-preorder-cart-panel-head-actions">
          <button type="button" class="aico-preorder-cart-panel-side" data-aico-preorder-cart-panel-side
                  title="{{ 'aico_preorder.cart_panel.toggle_side' | t }}" aria-label="{{ 'aico_preorder.cart_panel.toggle_side' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="17 1 21 5 17 9"></polyline><path d="M3 11V9a4 4 0 0 1 4-4h14"></path>
              <polyline points="7 23 3 19 7 15"></polyline><path d="M21 13v2a4 4 0 0 1-4 4H3"></path>
            </svg>
          </button>
          <button type="button" class="aico-preorder-cart-panel-close" data-aico-preorder-cart-panel-close
                  aria-label="{{ 'aico_preorder.cart_panel.hide' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>

      <dl class="aico-preorder-cart-panel-rows">
        <div class="aico-preorder-cart-panel-row">
          <dt class="aico-preorder-cart-panel-info" data-aico-cart-panel-info>
            <span>{{ 'aico_preorder.cart_panel.placed_orders' | t }}</span>
            <button type="button" class="aico-preorder-cart-panel-info-trigger" data-aico-cart-panel-info-trigger
                    aria-haspopup="dialog" aria-expanded="false" aria-controls="aico-preorder-cart-panel-placed-info"
                    aria-label="{{ 'aico_preorder.cart_panel.placed_orders' | t | escape }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line>
              </svg>
            </button>
            <span class="aico-preorder-cart-panel-info-pop" id="aico-preorder-cart-panel-placed-info" role="dialog" aria-label="{{ 'aico_preorder.cart_panel.placed_orders' | t | escape }}">{{ 'aico_preorder.cart_panel.placed_orders_info' | t }}</span>
          </dt>
          <dd data-aico-preorder-cart-panel-placed>—</dd>
        </div>
        <div class="aico-preorder-cart-panel-row">
          <dt>{{ 'aico_preorder.cart_panel.total_qty' | t }}</dt>
          <dd data-aico-preorder-cart-panel-total-qty>—</dd>
        </div>
        <div class="aico-preorder-cart-panel-row">
          <dt>{{ 'aico_preorder.cart_panel.discount' | t }}</dt>
          <dd data-aico-preorder-cart-panel-discount>—</dd>
        </div>
        <div class="aico-preorder-cart-panel-row">
          <dt>{{ 'aico_preorder.cart_panel.next_tier' | t }}</dt>
          <dd data-aico-preorder-cart-panel-next-tier>—</dd>
        </div>
        <div class="aico-preorder-cart-panel-row aico-preorder-cart-panel-row--subtotal">
          <dt>{{ 'aico_preorder.cart_panel.total' | t }}</dt>
          <dd data-aico-preorder-cart-panel-subtotal>—</dd>
        </div>
      </dl>

      <div class="aico-preorder-cart-panel-legend" data-aico-preorder-cart-panel-legend>
        <button type="button" class="aico-preorder-cart-panel-legend-trigger" data-aico-preorder-cart-panel-legend-trigger
                aria-haspopup="dialog" aria-expanded="false" aria-controls="aico-preorder-cart-panel-legend-pop">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
          <span>{{ 'aico_preorder.cart_panel.legend_title' | t }}</span>
        </button>
        <div class="aico-preorder-cart-panel-legend-pop" id="aico-preorder-cart-panel-legend-pop" role="dialog" aria-label="{{ 'aico_preorder.cart_panel.legend_title' | t }}">
          <p class="aico-preorder-cart-panel-legend-pop-title">{{ 'aico_preorder.cart_panel.legend_title' | t }}</p>
          <div class="aico-preorder-cart-panel-legend-row"><span class="aico-preorder-cart-panel-swatch aico-preorder-cart-panel-swatch--available"></span>{{ 'aico_preorder.cart_panel.legend_available' | t }}</div>
          <div class="aico-preorder-cart-panel-legend-row"><span class="aico-preorder-cart-panel-swatch aico-preorder-cart-panel-swatch--editing"></span>{{ 'aico_preorder.cart_panel.legend_editing' | t }}</div>
          <div class="aico-preorder-cart-panel-legend-row"><span class="aico-preorder-cart-panel-swatch aico-preorder-cart-panel-swatch--selected"></span>{{ 'aico_preorder.cart_panel.legend_selected' | t }}</div>
          <div class="aico-preorder-cart-panel-legend-row"><span class="aico-preorder-cart-panel-swatch aico-preorder-cart-panel-swatch--committed"></span>{{ 'aico_preorder.cart_panel.legend_committed' | t }}</div>
          <div class="aico-preorder-cart-panel-legend-row"><span class="aico-preorder-cart-panel-swatch aico-preorder-cart-panel-swatch--unavailable"></span>{{ 'aico_preorder.cart_panel.legend_unavailable' | t }}</div>
        </div>
      </div>
    </div>
  </aside>

  {%- comment -%} Inline preorder confirmation (no thank-you-url path): hidden until
       preorder-page.js reveals it on a successful submit and calls
       AicoPreorderConfirmation.start(). When a thank-you-url IS set, the submit
       flow redirects to templates/aico-preorder-thank-you.liquid instead and this
       panel stays hidden. Markup mirrors that template (no shared snippet because
       {% render %} does not resolve to files here). {%- endcomment -%}
  <section
    class="aico-preorder-confirmation aico-page-container"
    data-aico-preorder-confirmation
    hidden
    data-aico-confirmation-url="{{ routes.aico_preorder_cart_confirmation_url }}"
    data-aico-confirmation-title="{{ 'aico_preorder.confirmation.title' | t | escape }}"
    data-aico-confirmation-message="{{ 'aico_preorder.confirmation.message' | t | escape }}"
    data-aico-confirmation-update-title="{{ 'aico_preorder.confirmation.update_title' | t | escape }}"
    data-aico-confirmation-update-message="{{ 'aico_preorder.confirmation.update_message' | t | escape }}"
    data-aico-confirmation-number-pending="{{ 'aico_preorder.confirmation.number_pending' | t | escape }}"
    data-aico-confirmation-pcs="{{ 'aico_preorder.catalog.pcs' | t | escape }}"
    data-aico-confirmation-pdf-generating="{{ 'aico_preorder.confirmation.pdf_generating' | t | escape }}"
    data-aico-confirmation-pdf-download="{{ 'aico_preorder.confirmation.pdf_download' | t | escape }}"
    data-aico-confirmation-pdf-unavailable="{{ 'aico_preorder.confirmation.pdf_unavailable' | t | escape }}">

    <header class="aico-preorder-confirmation-head">
      <span class="aico-preorder-confirmation-check" aria-hidden="true">&#10003;</span>
      <h2 class="aico-preorder-confirmation-title" data-aico-confirmation-header>{{ 'aico_preorder.confirmation.title' | t }}</h2>
      <p class="aico-preorder-confirmation-message" data-aico-confirmation-message>{{ 'aico_preorder.confirmation.message' | t }}</p>
    </header>

    <div class="aico-preorder-confirmation-number-box">
      <span class="aico-preorder-confirmation-number-label">{{ 'aico_preorder.confirmation.number_label' | t }}</span>
      <span class="aico-preorder-confirmation-number" data-aico-confirmation-number>…</span>
      <span class="aico-preorder-confirmation-reference">
        {{ 'aico_preorder.confirmation.reference_label' | t }}
        <span data-aico-confirmation-reference></span>
      </span>
    </div>

    <div class="aico-preorder-confirmation-summary">
      <div class="aico-preorder-confirmation-address">
        <span class="aico-preorder-confirmation-summary-label">{{ 'aico_preorder.confirmation.delivery_address' | t }}</span>
        <div class="aico-preorder-confirmation-address-value" data-aico-confirmation-address>—</div>
      </div>
      <dl class="aico-preorder-confirmation-totals">
        <div class="aico-preorder-confirmation-total-row">
          <dt>{{ 'aico_preorder.confirmation.item_count' | t }}</dt>
          <dd data-aico-confirmation-item-count>0</dd>
        </div>
        <div class="aico-preorder-confirmation-total-row" data-aico-confirmation-discount-row>
          <dt>{{ 'aico_preorder.confirmation.discount' | t }}</dt>
          <dd data-aico-confirmation-discount>&ndash;</dd>
        </div>
        <div class="aico-preorder-confirmation-total-row aico-preorder-confirmation-total-row--grand">
          <dt>{{ 'aico_preorder.confirmation.total' | t }}</dt>
          <dd data-aico-confirmation-total>&mdash;</dd>
        </div>
      </dl>
    </div>

    <div class="aico-preorder-confirmation-dates-wrap">
      <h3 class="aico-preorder-confirmation-dates-title">{{ 'aico_preorder.confirmation.delivery_dates' | t }}</h3>
      <div class="aico-preorder-confirmation-dates" data-aico-confirmation-dates></div>
    </div>

    <div class="aico-preorder-confirmation-pdf-area" data-aico-confirmation-pdf aria-live="polite" aria-busy="true">
      <span class="aico-preorder-confirmation-pdf-spinner" aria-hidden="true"></span>
      <span>{{ 'aico_preorder.confirmation.pdf_generating' | t }}</span>
    </div>

    <p class="aico-preorder-confirmation-links">
      <a class="aico-btn aico-btn-secondary" href="{{ routes.root_url }}">{{ 'aico_preorder.thank_you.continue_shopping' | t }}</a>
    </p>
  </section>

  <div class="aico-preorder-gallery" data-aico-preorder-gallery hidden role="dialog" aria-modal="true" aria-labelledby="aico-preorder-gallery-title">
    <div class="aico-preorder-gallery-backdrop" data-aico-preorder-gallery-close></div>
    <div class="aico-preorder-gallery-dialog" role="document">
      <button type="button" class="aico-preorder-gallery-close" data-aico-preorder-gallery-close aria-label="{{ 'general.close' | t | default: 'Schliessen' }}">&times;</button>
      <h3 class="aico-preorder-gallery-title" id="aico-preorder-gallery-title" data-aico-preorder-gallery-title></h3>
      <div class="aico-preorder-gallery-stage">
        <button type="button" class="aico-preorder-gallery-nav aico-preorder-gallery-prev" data-aico-preorder-gallery-prev aria-label="Zurück" hidden>&lsaquo;</button>
        <div class="aico-preorder-gallery-main">
          <img class="aico-preorder-gallery-main-img" data-aico-preorder-gallery-main alt="" decoding="async">
          <p class="aico-preorder-gallery-empty" data-aico-preorder-gallery-empty hidden>{{ 'aico_preorder.catalog.error' | t }}</p>
        </div>
        <button type="button" class="aico-preorder-gallery-nav aico-preorder-gallery-next" data-aico-preorder-gallery-next aria-label="Weiter" hidden>&rsaquo;</button>
      </div>
      <div class="aico-preorder-gallery-thumbs" data-aico-preorder-gallery-thumbs></div>
    </div>
  </div>

  <script src="{{ 'preorder-catalog.js' | asset_url }}" defer></script>
  <script src="{{ 'preorder-stock.js' | asset_url }}" defer></script>
  <script src="{{ 'preorder-cart.js' | asset_url }}" defer></script>
  <script src="{{ 'preorder-confirmation.js' | asset_url }}" defer></script>
  <script src="{{ 'preorder-page.js' | asset_url }}" defer></script>
</main>
