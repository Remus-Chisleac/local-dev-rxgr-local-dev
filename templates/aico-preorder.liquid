{% comment %}
  AICO preorder page (step 1 of 3 — addresses & filters).

  This template lays down the full visual shell of the preorder page
  (hero band, filter row, sticky sub-header, floating cart button) and
  wires up section 1 (the addresses + filters). Sections 2 (item grid +
  flyer pickers) and 3 (checkout summary) are placeholder seams marked
  with `data-aico-preorder-step-{2,3}-placeholder` for the next agent.

  Non-Shopify route — the filename's `aico-` prefix flags the template
  as a backend-specific extension that won't clash with a Shopify
  upgrade. Globals: `aico_preorder.*`. URL helpers: `routes.aico_preorder_url`
  and `routes.aico_account_preorder_context_url`. Locale namespace:
  `aico_preorder.*`.
{% endcomment %}

{%- assign preorder_session = aico_preorder.session -%}
{%- assign has_session = false -%}
{%- if preorder_session.id -%}{%- assign has_session = true -%}{%- endif -%}
{%- assign hero_title = preorder_session.title | default: 'aico_preorder.session.title_fallback' -%}
{%- if preorder_session.title == blank -%}
  {%- assign hero_title = 'aico_preorder.session.title_fallback' | t -%}
{%- endif -%}

<main class="aico-preorder" role="main"
      data-aico-preorder
      data-aico-preorder-user-id="{{ customer.id }}"
      data-aico-preorder-context-url="{{ routes.aico_account_preorder_context_url }}"
      data-aico-preorder-cart-url="{{ routes.cart_url }}"
      {% if preorder_session.deadline_at %}data-aico-preorder-deadline="{{ preorder_session.deadline_at }}"{% endif %}>

  {%- comment -%} ── Hero band ── {%- endcomment -%}
  <section class="aico-preorder-hero" aria-labelledby="aico-preorder-hero-title">
    <div class="aico-page-container aico-preorder-hero-inner">
      <div class="aico-preorder-hero-text">
        <h1 id="aico-preorder-hero-title" class="aico-preorder-hero-title">{{ hero_title }}</h1>
      </div>

      <div class="aico-preorder-hero-media">
        {% if preorder_session.hero_image_url %}
          <img class="aico-preorder-hero-image"
               src="{{ preorder_session.hero_image_url }}"
               alt=""
               loading="eager"
               decoding="async">
        {% else %}
          <div class="aico-preorder-hero-image-empty" aria-hidden="true"></div>
        {% endif %}

        <div class="aico-preorder-countdown" data-aico-preorder-countdown role="group"
             aria-label="{{ 'aico_preorder.session.deadline_label' | t }}">
          <span class="aico-preorder-countdown-eyebrow">{{ 'aico_preorder.session.deadline_label' | t }}</span>
          <div class="aico-preorder-countdown-grid">
            <div class="aico-preorder-countdown-cell">
              <span class="aico-preorder-countdown-value" data-aico-countdown-days>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.days' | t }}</span>
            </div>
            <div class="aico-preorder-countdown-cell">
              <span class="aico-preorder-countdown-value" data-aico-countdown-hours>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.hours' | t }}</span>
            </div>
            <div class="aico-preorder-countdown-cell">
              <span class="aico-preorder-countdown-value" data-aico-countdown-minutes>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.minutes' | t }}</span>
            </div>
            <div class="aico-preorder-countdown-cell">
              <span class="aico-preorder-countdown-value" data-aico-countdown-seconds>--</span>
              <span class="aico-preorder-countdown-label">{{ 'aico_preorder.session.deadline_units.seconds' | t }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ── Filter row ── {%- endcomment -%}
  <section class="aico-preorder-filters-wrap" aria-labelledby="aico-preorder-filters-title">
    <div class="aico-page-container">
      <h2 id="aico-preorder-filters-title" class="aico-sr-only">{{ 'aico_preorder.filters.b2b_label' | t }}</h2>

      {% unless has_session %}
        <p class="aico-preorder-empty-state" role="status">
          {{ 'aico_preorder.session.no_active' | t }}
        </p>
      {% endunless %}

      <form class="aico-preorder-filters{% unless has_session %} aico-preorder-filters-disabled{% endunless %}"
            data-aico-preorder-filters
            method="post"
            action="{{ routes.aico_account_preorder_context_url }}"
            autocomplete="off"
            {% unless has_session %}aria-disabled="true"{% endunless %}>
        <input type="hidden" name="_token" value="{{ aico_csrf_token }}">

        {%- comment -%} ── B2B picker (hidden if user has a single B2B) ── {%- endcomment -%}
        {% if aico_preorder.b2b_choices.size > 0 %}
          <label class="aico-preorder-field" data-aico-field="b2b">
            <span class="aico-preorder-field-label">{{ 'aico_preorder.filters.b2b_label' | t }}</span>
            <span class="aico-preorder-field-control">
              <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
              </svg>
              <select name="b2b_id" data-aico-preorder-select="b2b_id" {% unless has_session %}disabled{% endunless %}>
                <option value="">{{ 'aico_preorder.filters.b2b_placeholder' | t }}</option>
                {% for choice in aico_preorder.b2b_choices %}
                  <option value="{{ choice.id }}"{% if aico_preorder.selected_b2b_id == choice.id %} selected{% endif %}>
                    {{ choice.label }}
                  </option>
                {% endfor %}
              </select>
            </span>
          </label>
        {% endif %}

        {%- comment -%} ── Size region ── {%- endcomment -%}
        <label class="aico-preorder-field" data-aico-field="size_region">
          <span class="aico-preorder-field-label">{{ 'aico_preorder.filters.size_region_label' | t }}</span>
          <span class="aico-preorder-field-control">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="8" x2="21" y1="6" y2="6"></line>
              <line x1="8" x2="21" y1="12" y2="12"></line>
              <line x1="8" x2="21" y1="18" y2="18"></line>
              <line x1="3" x2="3.01" y1="6" y2="6"></line>
              <line x1="3" x2="3.01" y1="12" y2="12"></line>
              <line x1="3" x2="3.01" y1="18" y2="18"></line>
            </svg>
            {%- assign current_region = customer.aico_preorder_size_region | default: aico_preorder.size_region -%}
            <select name="size_region" data-aico-preorder-select="size_region" {% unless has_session %}disabled{% endunless %}>
              <option value="EU"{% if current_region == 'EU' %} selected{% endif %}>EU</option>
              <option value="UK"{% if current_region == 'UK' %} selected{% endif %}>UK</option>
              <option value="US"{% if current_region == 'US' %} selected{% endif %}>US</option>
              <option value="KR"{% if current_region == 'KR' %} selected{% endif %}>KR</option>
            </select>
          </span>
        </label>

        {%- comment -%} ── Billing address ── {%- endcomment -%}
        <label class="aico-preorder-field" data-aico-field="billing_address">
          <span class="aico-preorder-field-label">{{ 'aico_preorder.filters.billing_label' | t }}</span>
          <span class="aico-preorder-field-control">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <select name="billing_address_id" data-aico-preorder-select="billing_address_id"
                    {% if aico_preorder.billing_addresses == empty or has_session == false %}disabled{% endif %}>
              <option value="">{{ 'aico_preorder.filters.billing_placeholder' | t }}</option>
              {% for address in aico_preorder.billing_addresses %}
                <option value="{{ address.id }}"{% if aico_preorder.selected_billing_address_id == address.id %} selected{% endif %}>
                  {{ address.label }}
                </option>
              {% endfor %}
            </select>
          </span>
        </label>

        {%- comment -%} ── Delivery address ── {%- endcomment -%}
        <label class="aico-preorder-field" data-aico-field="delivery_address">
          <span class="aico-preorder-field-label">{{ 'aico_preorder.filters.delivery_label' | t }}</span>
          <span class="aico-preorder-field-control">
            <svg class="aico-preorder-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <select name="delivery_address_id" data-aico-preorder-select="delivery_address_id"
                    {% if aico_preorder.delivery_addresses == empty or has_session == false %}disabled{% endif %}>
              <option value="">{{ 'aico_preorder.filters.delivery_placeholder' | t }}</option>
              {% for address in aico_preorder.delivery_addresses %}
                <option value="{{ address.id }}"{% if aico_preorder.selected_delivery_address_id == address.id %} selected{% endif %}>
                  {{ address.label }}
                </option>
              {% endfor %}
            </select>
          </span>
        </label>

        {%- comment -%} ── View toggle (grid / list) — localStorage only ── {%- endcomment -%}
        <div class="aico-preorder-view-toggle" role="group" aria-label="{{ 'aico_preorder.filters.view_grid' | t }}">
          <button type="button" class="aico-preorder-view-button aico-preorder-view-button-active"
                  data-aico-preorder-view="grid" aria-pressed="true" aria-label="{{ 'aico_preorder.filters.view_grid' | t }}">
            <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="7" height="7" x="3" y="3" rx="1"></rect>
              <rect width="7" height="7" x="14" y="3" rx="1"></rect>
              <rect width="7" height="7" x="14" y="14" rx="1"></rect>
              <rect width="7" height="7" x="3" y="14" rx="1"></rect>
            </svg>
          </button>
          <button type="button" class="aico-preorder-view-button"
                  data-aico-preorder-view="list" aria-pressed="false" aria-label="{{ 'aico_preorder.filters.view_list' | t }}">
            <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="8" x2="21" y1="6" y2="6"></line>
              <line x1="8" x2="21" y1="12" y2="12"></line>
              <line x1="8" x2="21" y1="18" y2="18"></line>
              <line x1="3" x2="3.01" y1="6" y2="6"></line>
              <line x1="3" x2="3.01" y1="12" y2="12"></line>
              <line x1="3" x2="3.01" y1="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </section>

  {%- comment -%}
    ── Step 2 seam ──
    Sticky "Men Sandals" sub-header frame + items grid placeholder.
    The next agent (preorder-step2) replaces the contents of
    `[data-aico-preorder-step-2-placeholder]` with the real item
    grid + flyer pickers (see plans/preorder.md §7). The sticky
    header lives outside the placeholder so the visual chrome is
    already in place.
    TODO(preorder-step2): hook in `aico_preorder_items` drop with the
    per-category list, size columns, and qty matrix.
  {%- endcomment -%}
  <section class="aico-preorder-items-wrap" aria-label="{{ 'aico_preorder.step2.section_aria' | t }}">
    <div class="aico-page-container">
      <header class="aico-preorder-category-header" data-aico-preorder-category-header>
        <span class="aico-preorder-category-title">{{ 'aico_preorder.step2.category_placeholder' | t }}</span>
        <div class="aico-preorder-category-sizes" aria-hidden="true">
          {%- comment -%} Empty for now; populated by step 2. {%- endcomment -%}
        </div>
      </header>

      <div class="aico-preorder-step2-placeholder" data-aico-preorder-step-2-placeholder>
        <p class="aico-preorder-step2-placeholder-text">{{ 'aico_preorder.step2.coming_soon' | t }}</p>
      </div>
    </div>
  </section>

  {%- comment -%}
    ── Step 3 seam ──
    Checkout summary section. The next agent (preorder-step3) replaces
    the contents of `[data-aico-preorder-step-3-placeholder]` with the
    address read-back, delivery date, totals, GTC checkbox, and the
    "Place Pre-order" CTA. Pre-rendered as an empty container so the
    floating cart button below can scroll to it (anchor stays stable).
    TODO(preorder-step3): hook in `aico_preorder_cart` drop and the
    `routes.aico_preorder_place_url` form action.
  {%- endcomment -%}
  <section class="aico-preorder-checkout-wrap" id="aico-preorder-checkout"
           aria-label="{{ 'aico_preorder.step3.section_aria' | t }}">
    <div class="aico-page-container">
      <div class="aico-preorder-step3-placeholder" data-aico-preorder-step-3-placeholder hidden>
        {%- comment -%} Empty until step 3 lands. {%- endcomment -%}
      </div>
    </div>
  </section>

  {%- comment -%}
    ── Floating cart button stub ──
    Wired to `/cart` for now so the orange CTA is at least functional.
    Step 2 swaps the href to `#aico-preorder-checkout` and step 3 wires
    the count badge to the preorder cart total.
    TODO(preorder-step2): when item count > 0, light up the button,
    show the badge, scroll to the checkout anchor on click.
  {%- endcomment -%}
  <a class="aico-preorder-floating-cart" href="{{ routes.cart_url }}"
     data-aico-preorder-cart-button
     aria-label="{{ 'aico_preorder.cart_button_aria' | t }}">
    <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="9" cy="21" r="1"></circle>
      <circle cx="20" cy="21" r="1"></circle>
      <path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"></path>
    </svg>
    <span class="aico-sr-only">{{ 'aico_preorder.cart_button_aria' | t }}</span>
    <span class="aico-preorder-floating-cart-badge" data-aico-preorder-cart-badge hidden>0</span>
  </a>

  {%- comment -%}
    Inline client glue — vanilla IIFE pattern matching
    `assets/theme.js`. Lives inline (not in an asset) so the
    countdown begins immediately without waiting for an extra round
    trip. When step 2 lands and this file grows beyond ~150 lines,
    extract into `assets/preorder-page.js` (the same way
    `assets/products-page.js` will land).

    TODO(preorder-step2): when the address-change-warning dialog
    becomes load-bearing (after the cart can hold items), port the
    confirmation flow from
    `b2b-shop/src/.../SortFilterControl.js:114`.
  {%- endcomment -%}
  <script>
    (function () {
      'use strict';

      var root = document.querySelector('[data-aico-preorder]');
      if (!root) return;

      // ── Countdown ───────────────────────────────────────────────
      var deadline = root.getAttribute('data-aico-preorder-deadline');
      var deadlineMs = deadline ? Date.parse(deadline) : NaN;
      var slots = {
        days: root.querySelector('[data-aico-countdown-days]'),
        hours: root.querySelector('[data-aico-countdown-hours]'),
        minutes: root.querySelector('[data-aico-countdown-minutes]'),
        seconds: root.querySelector('[data-aico-countdown-seconds]')
      };
      function pad(n) { return n < 10 ? '0' + n : '' + n; }
      function tick() {
        if (!slots.days) return;
        if (!deadline || isNaN(deadlineMs)) {
          slots.days.textContent = '--';
          slots.hours.textContent = '--';
          slots.minutes.textContent = '--';
          slots.seconds.textContent = '--';
          return;
        }
        var remaining = Math.max(0, deadlineMs - Date.now());
        var totalSeconds = Math.floor(remaining / 1000);
        var days = Math.floor(totalSeconds / 86400);
        var hours = Math.floor((totalSeconds % 86400) / 3600);
        var minutes = Math.floor((totalSeconds % 3600) / 60);
        var seconds = totalSeconds % 60;
        slots.days.textContent = pad(days);
        slots.hours.textContent = pad(hours);
        slots.minutes.textContent = pad(minutes);
        slots.seconds.textContent = pad(seconds);
      }
      tick();
      if (deadline && !isNaN(deadlineMs)) {
        setInterval(tick, 1000);
      }

      // ── Filter persistence ──────────────────────────────────────
      var userId = root.getAttribute('data-aico-preorder-user-id') || 'anon';
      var contextUrl = root.getAttribute('data-aico-preorder-context-url');
      var storageKey = 'aico_preorder_context:' + userId;

      function readStored() {
        try { return JSON.parse(localStorage.getItem(storageKey) || '{}'); }
        catch (_) { return {}; }
      }
      function writeStored(patch) {
        try {
          var current = readStored();
          Object.keys(patch).forEach(function (key) {
            if (patch[key] === null || patch[key] === '') {
              delete current[key];
            } else {
              current[key] = patch[key];
            }
          });
          localStorage.setItem(storageKey, JSON.stringify(current));
        } catch (_) { /* localStorage unavailable */ }
      }
      function applyStored() {
        var stored = readStored();
        Object.keys(stored).forEach(function (key) {
          var select = root.querySelector('[data-aico-preorder-select="' + key + '"]');
          if (select && stored[key] !== null && stored[key] !== undefined) {
            // Only restore if the value is still a valid option.
            var match = Array.prototype.some.call(select.options, function (opt) {
              return String(opt.value) === String(stored[key]);
            });
            if (match) {
              select.value = String(stored[key]);
            }
          }
        });
      }
      applyStored();

      var form = root.querySelector('[data-aico-preorder-filters]');
      var token = form ? form.querySelector('input[name="_token"]') : null;
      function persist(payload) {
        writeStored(payload);
        if (!contextUrl || !token || !token.value) return;
        var body = new FormData();
        body.append('_token', token.value);
        Object.keys(payload).forEach(function (key) {
          if (payload[key] !== null && payload[key] !== undefined && payload[key] !== '') {
            body.append(key, payload[key]);
          }
        });
        try {
          fetch(contextUrl, {
            method: 'POST',
            body: body,
            credentials: 'same-origin',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
          }).catch(function () { /* fire-and-forget */ });
        } catch (_) { /* network unavailable; localStorage still updated */ }
      }

      var selects = root.querySelectorAll('[data-aico-preorder-select]');
      selects.forEach(function (select) {
        select.addEventListener('change', function () {
          var key = select.getAttribute('data-aico-preorder-select');
          if (!key) return;
          var patch = {};
          patch[key] = select.value;
          persist(patch);
        });
      });

      // Disable form's default POST submit — the filter row is not a
      // form submit, only the per-select change persistence above.
      if (form) {
        form.addEventListener('submit', function (event) { event.preventDefault(); });
      }

      // ── View toggle (visual only) ───────────────────────────────
      var viewKey = 'aico_preorder_view:' + userId;
      var viewButtons = root.querySelectorAll('[data-aico-preorder-view]');
      function applyView(value) {
        viewButtons.forEach(function (button) {
          var active = button.getAttribute('data-aico-preorder-view') === value;
          button.classList.toggle('aico-preorder-view-button-active', active);
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
        root.setAttribute('data-aico-preorder-view-mode', value);
      }
      var initialView = 'grid';
      try { initialView = localStorage.getItem(viewKey) || 'grid'; } catch (_) {}
      applyView(initialView);
      viewButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          var next = button.getAttribute('data-aico-preorder-view');
          if (!next) return;
          try { localStorage.setItem(viewKey, next); } catch (_) {}
          applyView(next);
        });
      });
    })();
  </script>
</main>
