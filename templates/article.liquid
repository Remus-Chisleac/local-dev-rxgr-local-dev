{%- comment -%}
  Single news article — Shopify blog convention at /blogs/news/<handle>.

  Server-rendered: LiquidRendererService binds the `article` drop via
  NewsLoader, which renders the legacy contentBuilder body to HTML on the
  server (NewsContentRenderer). Header, hero image, body and the "more news"
  strip arrive in the HTML — no client fetch, no empty-state flash, no JS.

  Fallback: articles authored in the AICO Neo content builder (or using a
  content type the server renderer doesn't cover) have an empty
  `article.content`; the page then loads news.js / news-neo.js and renders
  the body client-side from the inline payload.
{%- endcomment -%}

<style>
  /* kj article design: the whole content column is anchored to the LEFT of the page
     (not centered) — header, hero media and body share the same left edge. */
  .aico-news--detail { max-width: 880px; margin: 0; padding: 2rem 1.25rem 4rem; }
  /* The renderer's generic full-bleed breakout (calc(50% - 50vw)) assumes a centered
     parent; with the left-anchored column the band's containing block starts at the
     container's 1.25rem padding, so pull back exactly that instead. */
  .aico-news--detail .neo-section--full { margin-left: -1.25rem; margin-right: 0; }
  /* Media aligns with the text column's left edge inside the band (no centering);
     the converter's section side-padding matches the container's 1.25rem. */
  .aico-news--detail .neo-section__inner { margin: 0; }

  /* kj article header: kicker → title → short rule + date (server-rendered). */
  .aico-article-header { margin: 0 0 1.75rem; }
  .aico-article-kicker { font-size: .78rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: #111; margin: 0 0 1.1rem; }
  .aico-article-kicker a { color: inherit; text-decoration: none; }
  .aico-article-title { font-size: 2.1rem; line-height: 1.2; margin: 0 0 1.4rem; }
  .aico-article-meta { font-size: .85rem; color: #444; }
  .aico-article-meta::before { content: ''; display: block; width: 2.5rem; border-top: 1px solid #111; margin-bottom: .8rem; }

  /* Neo hero band (first converted section): breathing room below the full-bleed color band. */
  .aico-news--detail .neo-section--full { margin-bottom: 2rem; }
  /* The shared page-renderer mount brings its own page paddings — the article container
     already provides them, so neutralise inside the article column. */
  .aico-news--detail .aico-neo-page { max-width: none; padding: 0; }

  /* Legacy client-rendered header (no article drop, e.g. presentation tenant). */
  .aico-news--detail .title-wrapper h1,
  .aico-news--detail .title-wrapper h2 { font-size: 2rem; line-height: 1.2; margin: 0 0 1rem; }
  .aico-news--detail .tag-wrapper { color: #888; font-size: .9rem; margin-bottom: 1.5rem; }
  .aico-news--detail .tag-wrapper a, .aico-news--detail .tag-wrapper .news-cat { color: #888; text-decoration: none; }
  .aico-news--detail .news-hero { margin: 0 0 2rem; }
  .aico-news--detail .news-hero img { width: 100%; height: auto; display: block; border-radius: var(--aico-radius, 2px); }
  .aico-news--detail .description-wrapper { font-size: 1.05rem; line-height: 1.65; color: #222; }
  .aico-news--detail .description-wrapper img,
  .aico-news--detail .image-wrapper img,
  .aico-news--detail .content img { max-width: 100%; height: auto; }
  .aico-news--detail .content-row { display: flex; flex-wrap: wrap; gap: 1.5rem; margin: 1.25rem 0; }
  .aico-news--detail .content-column { flex: 1 1 0; min-width: 0; }
  .aico-news--detail .content { margin: 0 0 1rem; }
  .aico-news--detail .content-type-title h1,
  .aico-news--detail .content-type-title h2,
  .aico-news--detail .content-type-title h3 { margin: 1.5rem 0 .75rem; line-height: 1.25; }
  .aico-news--detail .content-type-divider hr { border: 0; border-top: 1px solid #ececec; margin: 2rem 0; }
  .aico-news--detail .content-type-album { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; }
  .aico-news--detail .content-type-album img { width: 100%; height: 100%; object-fit: cover; border-radius: 8px; }
  .aico-news--detail .content-type-video iframe,
  .aico-news--detail .content-type-video video { width: 100%; aspect-ratio: 16 / 9; border: 0; border-radius: 8px; }
  .aico-news--detail blockquote.content-type-quote { border-left: 3px solid #111; margin: 1.5rem 0; padding: .25rem 0 .25rem 1rem; color: #444; font-style: italic; }
  .aico-news--detail .content-type-link .button--primary { display: inline-block; background: #111; color: #fff;
    text-decoration: none; padding: .65rem 1.4rem; border-radius: 8px; font-weight: 600; }

  /* Server-rendered "more news" strip. */
  .aico-related { margin-top: 3rem; border-top: 1px solid #ececec; padding-top: 2rem; }
  .aico-related-title { font-size: 1.4rem; margin: 0 0 1.25rem; }
  .aico-related-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.5rem; }
  .aico-related-card { display: flex; flex-direction: column; border: 1px solid #ececec; border-radius: 12px;
    overflow: hidden; background: #fff; text-decoration: none; color: inherit; transition: box-shadow .2s ease; }
  .aico-related-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); }
  .aico-related-image { aspect-ratio: 16 / 10; overflow: hidden; background: #f2f2f2; }
  .aico-related-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .aico-related-body { padding: .85rem 1rem 1.1rem; }
  .aico-related-date { font-size: .8rem; color: #888; margin-bottom: .35rem; }
  .aico-related-card-title { font-size: 1rem; font-weight: 600; margin: 0; line-height: 1.3; }

  .aico-news-back { margin-top: 2.5rem; }
  .aico-news-back-link { text-decoration: none; color: #111; font-weight: 600; }

  /* Client-fallback related-news strip (news.js). Without these the inline
     .block-btn SVG (no width/height) would fill its column. */
  .aico-news--detail .related-news-wrapper { margin-top: 3rem; border-top: 1px solid #ececec; padding-top: 2rem; }
  .aico-news--detail .related-news { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.5rem; }
  .aico-news--detail .related-news .content-container { display: flex; flex-direction: column; border: 1px solid #ececec; border-radius: 12px; overflow: hidden; background: #fff; }
  .aico-news--detail .news__image-wrapper { position: relative; aspect-ratio: 16 / 10; overflow: hidden; background: #f2f2f2; }
  .aico-news--detail .news__image { width: 100%; height: 100%; object-fit: cover; display: block; }
  .aico-news--detail .news__image-wrapper .badge { position: absolute; left: .5rem; bottom: .5rem; background: rgba(0,0,0,.7); color: #fff; font-size: .75rem; padding: .15rem .5rem; border-radius: 6px; }
  .aico-news--detail .news__info { padding: .9rem 1rem .25rem; flex: 1 1 auto; }
  .aico-news--detail .news__info h3 { font-size: 1rem; margin: 0 0 .4rem; line-height: 1.3; }
  .aico-news--detail .news__info .rte { font-size: .85rem; color: #555; line-height: 1.5; }
  .aico-news--detail .related-news .link-wrapper { padding: .5rem 1rem 1rem; }
  .aico-news--detail .block-btn { display: inline-flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 999px; background: #111; }
  .aico-news--detail .block-btn svg { width: 1rem; height: 1rem; fill: #fff; }
  .aico-news--detail .related-news-wrapper .center { text-align: center; margin-top: 2rem; }
  .aico-news--detail .button--primary { display: inline-block; background: #111; color: #fff; text-decoration: none; padding: .65rem 1.4rem; border-radius: 8px; font-weight: 600; }
  #news-details-container.hidden { display: none; }
  @media (max-width: 900px) { .aico-related-grid, .aico-news--detail .related-news { grid-template-columns: repeat(2, minmax(0,1fr)); } }
  @media (max-width: 600px) { .aico-related-grid, .aico-news--detail .related-news { grid-template-columns: 1fr; } .aico-news--detail .content-row { display: block; } }
</style>

<section class="aico-news aico-news--detail" data-aico-news="article">
  {%- if article -%}
    {%- comment -%}
      Server-rendered header for BOTH body paths (kj article design: kicker → title →
      rule + date). The client renderer (news.js) skips its own title/tag markup when
      window.__AICO_ARTICLE_HEADER_SSR__ is set below.
    {%- endcomment -%}
    <header class="aico-article-header" data-aico-article-header>
      <p class="aico-article-kicker">
        {%- if article.aico_category_name -%}
          <a href="{{ article.aico_category_url }}">{{ article.aico_category_name | upcase }}</a>
        {%- else -%}NEWS{%- endif -%}
      </p>
      <h1 class="aico-article-title">{{ article.title }}</h1>
      {%- if article.published_at or article.author -%}
        <div class="aico-article-meta">
          {%- if article.published_at -%}<span class="news-date">{{ article.published_at }}</span>{%- endif -%}
          {%- if article.author -%}<span class="news-author">{% if article.published_at %}, {% endif %}{{ article.author }}</span>{%- endif -%}
        </div>
      {%- endif -%}
    </header>
  {%- endif -%}

  {%- if article.content != blank -%}
    {%- comment -%} Server-rendered legacy body — no JS needed. {%- endcomment -%}
    <article class="news-content-wrapper">
      {%- if article.image -%}
        <div class="news-hero"><img src="{{ article.image }}" alt="{{ article.title | escape }}" style="object-position: {{ article.aico_object_position }};"></div>
      {%- endif -%}
      <div class="description-wrapper">{{ article.content }}</div>
    </article>
  {%- elsif article.aico_has_neo -%}
    {%- comment -%}
      Neo article — same complete renderer as /pages/<handle> (neo-content pattern):
      content-builder-neo.js finds the #aico-content mount + #aico-page-data JSON on
      DOMContentLoaded and paints every section/element type, including the full-bleed
      hero color band. The inline payload is the article attributes object, which
      carries `contentBuilderNeoJson` — exactly what the renderer's bootstrap expects.
      No jQuery / news.js on this path.
    {%- endcomment -%}
    <link rel="stylesheet" href="{{ 'content-builder.css' | asset_url }}">
    <div id="aico-content" class="aico-neo-page aico-neo-article"></div>
    <script>window.current_locale_code = {{ request.locale | default: shop.default_locale | json }};</script>
    <script id="aico-page-data" type="application/json">{{ aico_article_data }}</script>
    <script src="{{ 'content-builder-neo.js' | asset_url }}" defer></script>
  {%- else -%}
    {%- comment -%} Client fallback for unhandled legacy content / presentation tenant. {%- endcomment -%}
    {%- if article -%}
      <script>window.__AICO_ARTICLE_HEADER_SSR__ = true;</script>
    {%- endif -%}
    <div id="status" class="aico-news-status" aria-hidden="true"></div>
    <div id="preloader" class="aico-news-preloader" aria-hidden="true"></div>
    <div class="page-wrapper"></div>
    <div id="news-container" class="aico-news-detail">
      <div id="news-details-container" class="hidden"></div>
    </div>
  {%- endif -%}

  {%- comment -%} Server-rendered "more news" strip — legacy-server AND neo paths. {%- endcomment -%}
  {%- if article.content != blank or article.aico_has_neo -%}
    {%- assign related_count = aico_related_articles | size -%}
    {%- if related_count > 0 -%}
      <section class="aico-related">
        <h2 class="aico-related-title">{% if request.locale contains 'de' %}Weitere News{% else %}More news{% endif %}</h2>
        <div class="aico-related-grid">
          {%- for related in aico_related_articles -%}
            <a class="aico-related-card" href="{{ related.url }}">
              <div class="aico-related-image">
                {%- if related.image -%}<img src="{{ related.image }}" alt="{{ related.title | escape }}" loading="lazy" style="object-position: {{ related.aico_object_position }};">{%- endif -%}
              </div>
              <div class="aico-related-body">
                {%- if related.published_at -%}<div class="aico-related-date">{{ related.published_at }}</div>{%- endif -%}
                <h3 class="aico-related-card-title">{{ related.title }}</h3>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </section>
    {%- endif -%}
  {%- endif -%}

  <p class="aico-news-back">
    <a href="{{ aico_news_url | default: '/blogs/news' }}" class="aico-news-back-link">&larr; News</a>
  </p>
</section>

{%- comment -%}
  Legacy client-fallback assets — only when the body was neither server-rendered
  nor painted by the neo page renderer above.
{%- endcomment -%}
{%- if article.content == blank and article.aico_has_neo != true -%}
  {%- if aico_article_data -%}
    <script id="aico-article-data" type="application/json">{{ aico_article_data }}</script>
  {%- endif -%}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css">
  <script src="https://code.jquery.com/jquery-3.6.4.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js" defer></script>
  <script src="{{ 'news-neo.js' | asset_url }}" defer></script>
  <script src="{{ 'news.js' | asset_url }}" defer></script>
{%- endif -%}
