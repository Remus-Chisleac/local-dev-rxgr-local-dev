<link rel="stylesheet" href="{{ 'eventtool.css' | asset_url }}">

{%- assign et_header = 'et-joya-ads-header-en.jpg' -%}
{%- if request.locale contains 'de' -%}
  {%- assign et_header = 'et-joya-ads-header-de_CH.jpg' -%}
{%- endif -%}

<main class="et-page" data-aico-eventtool="ads-joya">
  <img class="et-header-img" src="{{ et_header | asset_url }}" alt="">
  <div data-et-mount></div>
</main>

<script id="aico-eventtool-config" type="application/json">
{
  "locale": {{ request.locale.iso_code | json }},
  "formName": "joya-form",
  "endpoint": {{ routes.aico_forms_url | json }},
  "productsUrl": {{ routes.aico_form_products_url | json }},
  "maxSelectable": { "shoes": 2 },
  "singleModelDesignIndex": 1,
  "email": {{ customer.email | default: '' | json }},
  "images": {
    "question3": ["{{ 'et-joya-ads-question3-image1.jpg' | asset_url }}","{{ 'et-joya-ads-question3-image2.jpg' | asset_url }}","{{ 'et-joya-ads-question3-image3.jpg' | asset_url }}"],
    "question5": ["{{ 'et-joya-ads-question5-image1.jpg' | asset_url }}","{{ 'et-joya-ads-question5-image2.jpg' | asset_url }}","{{ 'et-joya-ads-question5-image3.jpg' | asset_url }}"],
    "question6": ["{{ 'et-joya-ads-question6-image1.jpg' | asset_url }}"]
  },
  "optionText": {
    "question5": {
      "de_CH": { "Text1": "a. FOREVERFOAM® mit 2 Modellen", "Text2": "b. Medical Fersensporn mit FOREVERFOAM®", "Text3": "c. Medical Fersensporn mit 2 Modellen" },
      "en": { "Text1": "a. FOREVERFOAM® with 2 models", "Text2": "b. Medical heel spur with FOREVERFOAM®", "Text3": "c. Medical heel spur with 2 models" }
    },
    "question6": {
      "de_CH": { "Text1": "Nein", "Text2": "Werbegeschenk: Trinkflasche", "Text3": "Werbegeschenk: Regenschirm", "Text4": "Werbegeschenk: Schuhpflege-Set" },
      "en": { "Text1": "No", "Text2": "Promotional gift: Drinking bottle", "Text3": "Promotional gift: Umbrella", "Text4": "Promotional gift: Shoe care set" }
    }
  }
}
</script>

<script src="{{ 'aico-ads-joya.js' | asset_url }}" defer></script>
<script src="{{ 'eventtool-lightbox.js' | asset_url }}" defer></script>
