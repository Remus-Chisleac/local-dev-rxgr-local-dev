{% comment %}
  Shopify-shaped recover-password template. Posts to /account/recover
  with `customer[email]`. Success state surfaces via Shopify's
  `form.posted_successfully?` flag (driven by ?posted_successfully=1 on
  the redirect). Always shows the same success message regardless of
  whether the email exists, to avoid disclosing customer enumeration.
{% endcomment %}

<div class="aico-auth-shell" style="background-image: var(--aico-auth-bg-image);">
  <div class="aico-auth-overlay" aria-hidden="true"></div>

  <div class="aico-auth-card-wrap">
    <div class="aico-auth-locale-switcher">
      <a href="?locale=en">EN</a>
      <span aria-hidden="true">·</span>
      <a href="?locale=de_CH">DE</a>
    </div>

    <div class="aico-auth-card">
      <h1 class="aico-auth-title">{{ 'customer.recover_password.title' | t }}</h1>
      <p class="aico-auth-subtitle">{{ 'customer.recover_password.subtext' | t }}</p>

      {% if form.posted_successfully? and form.form_type == 'recover_customer_password' %}
        <p class="aico-auth-success" role="status">
          {{ 'customer.recover_password.success' | t }}
        </p>
      {% else %}
        <form action="{{ routes.account_recover_url }}" method="post" class="aico-auth-form">
          <input type="hidden" name="_token" value="{{ aico_csrf_token }}">

          <label class="aico-auth-field">
            <span class="aico-auth-field-label">{{ 'customer.recover_password.email' | t }}</span>
            <input type="email" name="customer[email]" autocomplete="email" required>
          </label>

          <button type="submit" class="aico-auth-button">
            {{ 'customer.recover_password.submit' | t }}
          </button>
        </form>
      {% endif %}

      <a href="{{ routes.account_login_url }}" class="aico-auth-button aico-auth-button-outline">
        {{ 'customer.recover_password.cancel' | t }}
      </a>
    </div>
  </div>
</div>
