{% comment %}
  Per-store editor page (AICO URL /account/store-locator?store=<crmAddressId>).

  Reached from the "Edit store details" button on each store-locator card on the
  profile page (customers/account.liquid). Replaces the old store-locator LIST
  page + 3-tab modal: this is now a single, full-page editor for ONE store, with
  the three groups laid out as stacked SECTIONS (no tabs, no resizing modal).

  The selected store is resolved server-side into the `aico_store` drop
  (LiquidRendererService — looked up in the shopper's own store bucket, so an id
  they don't own renders the not-found state). Its crm_address_id is emitted on
  the root for store-editor.js, which fetches/saves each section against the
  storefront-session endpoints under routes.aico_store_details_base_url
  (/account/store-details/...). A single "Save changes" button saves all three
  groups; a dirty-tracking leave-guard dialog protects unsaved edits.
{% endcomment %}

<main class="aico-account aico-store-editor" role="main"
      data-aico-store-editor
      {% if aico_store %}data-aico-crm-address-id="{{ aico_store.aico_crm_address_id }}"{% endif %}
      data-store-details-base="{{ routes.aico_store_details_base_url }}"
      data-account-url="{{ routes.account_url }}"
      data-copy-saving="{{ 'customer.addresses.saving' | t | escape }}"
      data-copy-saved="{{ 'customer.addresses.saved' | t | escape }}"
      data-copy-error="{{ 'customer.addresses.save_error' | t | escape }}">

  <input type="hidden" name="_token" value="{{ aico_csrf_token }}">

  {%- comment -%} Localized strings the JS-rendered rows need (Shopify-style t filter). {%- endcomment -%}
  <script type="application/json" data-aico-store-editor-i18n>
    {
      "loading": {{ 'customer.aico_store_locator.loading' | t | json }},
      "phones": {{ 'customer.aico_store_locator.phones' | t | json }},
      "emails": {{ 'customer.aico_store_locator.emails' | t | json }},
      "website": {{ 'customer.aico_store_locator.website' | t | json }},
      "addPhone": {{ 'customer.aico_store_locator.add_phone' | t | json }},
      "addEmail": {{ 'customer.aico_store_locator.add_email' | t | json }},
      "phonePlaceholder": {{ 'customer.aico_store_locator.phone_placeholder' | t | json }},
      "emailPlaceholder": {{ 'customer.aico_store_locator.email_placeholder' | t | json }},
      "labelPlaceholder": {{ 'customer.aico_store_locator.label_placeholder' | t | json }},
      "mainLabel": {{ 'customer.aico_store_locator.main_label' | t | json }},
      "calendarActive": {{ 'customer.aico_store_locator.calendar_active' | t | json }},
      "notice": {{ 'customer.aico_store_locator.notice' | t | json }},
      "addImage": {{ 'customer.aico_store_locator.add_image' | t | json }},
      "imageTitlePlaceholder": {{ 'customer.aico_store_locator.image_title_placeholder' | t | json }},
      "orderLabel": {{ 'customer.aico_store_locator.order_label' | t | json }},
      "noImages": {{ 'customer.aico_store_locator.no_images' | t | json }},
      "openLabel": {{ 'customer.aico_store_locator.open_label' | t | json }},
      "closeLabel": {{ 'customer.aico_store_locator.close_label' | t | json }},
      "days": {
        "monday": {{ 'customer.aico_store_locator.day_monday' | t | json }},
        "tuesday": {{ 'customer.aico_store_locator.day_tuesday' | t | json }},
        "wednesday": {{ 'customer.aico_store_locator.day_wednesday' | t | json }},
        "thursday": {{ 'customer.aico_store_locator.day_thursday' | t | json }},
        "friday": {{ 'customer.aico_store_locator.day_friday' | t | json }},
        "saturday": {{ 'customer.aico_store_locator.day_saturday' | t | json }},
        "sunday": {{ 'customer.aico_store_locator.day_sunday' | t | json }}
      }
    }
  </script>

  <div class="aico-page-container aico-store-editor-container">

    {%- comment -%} ── Top bar: back + title ──────────────────────────────── {%- endcomment -%}
    <div class="aico-store-editor-topbar">
      <a class="aico-store-editor-back" href="{{ routes.account_url }}" data-aico-store-back>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
        <span>{{ 'customer.aico_store_locator.back_to_profile' | t }}</span>
      </a>
    </div>

    {% if aico_store %}
      {%- comment -%} ── Store info header ────────────────────────────────── {%- endcomment -%}
      <header class="aico-store-editor-header">
        <h1 class="aico-store-editor-title">{{ 'customer.aico_store_locator.edit_title' | t }}</h1>
        <div class="aico-store-editor-store">
          {% if aico_store.name != '' %}<p class="aico-store-editor-store-name">{{ aico_store.name }}</p>{% endif %}
          {% if aico_store.company %}<p class="aico-store-editor-store-line">{{ aico_store.company }}</p>{% endif %}
          <p class="aico-store-editor-store-line">
            {% if aico_store.address1 != '' %}{{ aico_store.address1 }}{% if aico_store.address2 != '' %}, {{ aico_store.address2 }}{% endif %} · {% endif %}{{ aico_store.zip }} {{ aico_store.city }}{% if aico_store.country != '' %} · {{ aico_store.country }}{% endif %}
          </p>
        </div>
      </header>

      {%- comment -%} ── Section: Contact info ────────────────────────────── {%- endcomment -%}
      <section class="aico-store-editor-section" data-aico-store-section="contact">
        <h2 class="aico-store-editor-section-title">{{ 'customer.aico_store_locator.section_contact' | t }}</h2>
        <div class="aico-store-editor-section-body" data-aico-store-panel="contact">
          <p class="aico-store-editor-loading">{{ 'customer.aico_store_locator.loading' | t }}</p>
        </div>
      </section>

      {%- comment -%} ── Section: Opening hours ───────────────────────────── {%- endcomment -%}
      <section class="aico-store-editor-section" data-aico-store-section="hours">
        <h2 class="aico-store-editor-section-title">{{ 'customer.aico_store_locator.section_hours' | t }}</h2>
        <div class="aico-store-editor-section-body" data-aico-store-panel="hours">
          <p class="aico-store-editor-loading">{{ 'customer.aico_store_locator.loading' | t }}</p>
        </div>
      </section>

      {%- comment -%} ── Section: Images ──────────────────────────────────── {%- endcomment -%}
      <section class="aico-store-editor-section" data-aico-store-section="images">
        <h2 class="aico-store-editor-section-title">{{ 'customer.aico_store_locator.section_images' | t }}</h2>
        <div class="aico-store-editor-section-body" data-aico-store-panel="images">
          <p class="aico-store-editor-loading">{{ 'customer.aico_store_locator.loading' | t }}</p>
        </div>
      </section>

      {%- comment -%} ── Sticky save bar ──────────────────────────────────── {%- endcomment -%}
      <div class="aico-store-editor-savebar">
        <span class="aico-store-editor-dirty-hint" data-aico-store-dirty-hint hidden>{{ 'customer.aico_store_locator.unsaved_hint' | t }}</span>
        <button type="button" class="aico-store-editor-save" data-aico-store-save>{{ 'customer.aico_store_locator.save_changes' | t }}</button>
      </div>

    {% else %}
      {%- comment -%} No (or non-owned) store id → not-found state. {%- endcomment -%}
      <div class="aico-store-editor-notfound">
        <p class="aico-account-empty">{{ 'customer.aico_store_locator.store_not_found' | t }}</p>
        <a class="aico-address-card-btn" href="{{ routes.account_url }}">{{ 'customer.aico_store_locator.back_to_profile' | t }}</a>
      </div>
    {% endif %}

  </div>

  {%- comment -%}
    Unsaved-changes leave guard. store-editor.js shows this when the shopper
    tries to leave (back button / nav link) with a dirty form: Save & leave /
    Discard & leave / Cancel.
  {%- endcomment -%}
  <div class="aico-store-leave-modal" data-aico-store-leave-modal hidden aria-hidden="true">
    <div class="aico-store-leave-overlay" data-aico-store-leave-cancel></div>
    <div class="aico-store-leave-dialog" role="dialog" aria-modal="true" aria-labelledby="aico-store-leave-title">
      <h3 id="aico-store-leave-title" class="aico-store-leave-heading">{{ 'customer.aico_store_locator.unsaved_title' | t }}</h3>
      <p class="aico-store-leave-body">{{ 'customer.aico_store_locator.unsaved_body' | t }}</p>
      <div class="aico-store-leave-actions">
        <button type="button" class="aico-store-leave-btn aico-store-leave-cancel" data-aico-store-leave-cancel>{{ 'customer.aico_store_locator.leave_cancel' | t }}</button>
        <button type="button" class="aico-store-leave-btn aico-store-leave-discard" data-aico-store-leave-discard>{{ 'customer.aico_store_locator.leave_discard' | t }}</button>
        <button type="button" class="aico-store-leave-btn aico-store-leave-save" data-aico-store-leave-save>{{ 'customer.aico_store_locator.leave_save' | t }}</button>
      </div>
    </div>
  </div>

  {%- comment -%} Standard site toast (shared .aico-toast-wrap / .aico-toast). {%- endcomment -%}
  <div class="aico-toast-wrap" aria-live="polite" aria-atomic="true">
    <div class="aico-toast aico-store-editor-toast" data-aico-store-editor-toast></div>
  </div>

  <script src="{{ 'store-editor.js' | asset_url }}" defer></script>
</main>
