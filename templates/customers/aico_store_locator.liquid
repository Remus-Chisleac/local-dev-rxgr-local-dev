{% comment %}
  Dedicated store-locator page (AICO URL /account/store-locator → this template).

  Distinct from the generic /account/addresses profile page: this page is the
  home of the rich per-store editor. Each store-locator address is a card with
  an "Edit store details" button that opens the three-tab editor
  (contact info / opening hours / images) in store-details.js.

  Data: customer.aico_store_locator_addresses (AddressDrop[]) is hydrated for
  this template in LiquidRendererService::loadShopperContext.

  The store-details editor calls the storefront-session endpoints under
  routes.aico_store_details_base_url (/account/store-details/...), which proxy
  the existing AicoShop store-details operations via the shopper's session.
  (The legacy /api/v2/aico-shops/* routes are Bearer-only → 401 from here.)

  The "request address change" affordance is intentionally NOT on this page —
  it lives only on the profile addresses page (/account/addresses), per the
  v2 split. This page is purely the store-management surface.

  NOTE: BlankFileSystem means {% render %} does not resolve snippets; the card
  markup is inlined.
{% endcomment %}

<main class="aico-account aico-store-locator" role="main"
      data-aico-store-locator
      data-store-details-base="{{ routes.aico_store_details_base_url }}"
      data-aico-shop-id="{{ customer.aico_shop_id }}"
      data-copy-saving="{{ 'customer.addresses.saving' | t | escape }}"
      data-copy-saved="{{ 'customer.addresses.saved' | t | escape }}"
      data-copy-error="{{ 'customer.addresses.save_error' | t | escape }}">

  <input type="hidden" name="_token" value="{{ aico_csrf_token }}">

  <div class="aico-page-container">
    <div class="aico-account-content">

      <div class="aico-store-locator-head">
        <h1 class="aico-account-section-title aico-store-locator-title">{{ 'customer.aico_store_locator.title' | t }}</h1>
        <a class="aico-store-locator-nav-link" href="{{ routes.account_addresses_url }}">{{ 'customer.aico_store_locator.back_to_addresses' | t }}</a>
      </div>
      <p class="aico-store-locator-intro">{{ 'customer.aico_store_locator.intro' | t }}</p>

      <section class="aico-account-section">
        {% if customer.aico_store_locator_addresses.size > 0 %}
          <div class="aico-account-address-grid">
            {% for address in customer.aico_store_locator_addresses %}
              <div class="aico-account-card aico-account-address-card aico-store-locator-card"
                   data-aico-crm-address-id="{{ address.aico_crm_address_id }}">
                {% if address.name != '' %}<p class="aico-account-address-title">{{ address.name }}</p>{% endif %}
                {% if address.company %}<p class="aico-account-address-line">{{ address.company }}</p>{% endif %}
                <div class="aico-account-address-block">
                  {% if address.address1 != '' %}<p class="aico-account-address-line">{{ address.address1 }}</p>{% endif %}
                  {% if address.address2 != '' %}<p class="aico-account-address-line">{{ address.address2 }}</p>{% endif %}
                  <p class="aico-account-address-line">{{ address.zip }} {{ address.city }}</p>
                  {% if address.province != '' or address.country != '' %}
                    <p class="aico-account-address-line">{{ address.province }}{% if address.province != '' and address.country != '' %}, {% endif %}{{ address.country }}</p>
                  {% endif %}
                  {% if address.phone %}<p class="aico-account-address-line">{{ address.phone }}</p>{% endif %}
                </div>
                <div class="aico-address-card-actions">
                  <button type="button" class="aico-address-card-btn aico-store-details-open" data-aico-store-details-open>{{ 'customer.addresses.aico_edit_store_details' | t }}</button>
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="aico-account-empty">{{ 'customer.addresses.no_stores' | t }}</p>
        {% endif %}
      </section>

    </div>
  </div>

  {%- comment -%}
    Store-details editor modal (three tabs). store-details.js loads/saves each
    tab against the storefront /account/store-details/* endpoints.
  {%- endcomment -%}
  <div class="aico-store-details-modal" data-aico-store-details-modal hidden aria-hidden="true">
    <div class="aico-store-details-overlay" data-aico-store-details-close></div>
    <div class="aico-store-details-dialog" role="dialog" aria-modal="true" aria-labelledby="aico-store-details-title">
      <div class="aico-store-details-head">
        <h3 id="aico-store-details-title" class="aico-store-details-heading">{{ 'customer.addresses.store_details_title' | t }}</h3>
        <button type="button" class="aico-store-details-x" data-aico-store-details-close aria-label="{{ 'customer.addresses.close' | t | escape }}">&times;</button>
      </div>
      <div class="aico-store-details-tabs" role="tablist">
        <button type="button" class="aico-store-details-tab is-active" data-aico-store-details-tab="contact" role="tab">{{ 'customer.addresses.tab_contact' | t }}</button>
        <button type="button" class="aico-store-details-tab" data-aico-store-details-tab="hours" role="tab">{{ 'customer.addresses.tab_hours' | t }}</button>
        <button type="button" class="aico-store-details-tab" data-aico-store-details-tab="images" role="tab">{{ 'customer.addresses.tab_images' | t }}</button>
      </div>
      <div class="aico-store-details-panels">
        <div class="aico-store-details-panel is-active" data-aico-store-details-panel="contact"></div>
        <div class="aico-store-details-panel" data-aico-store-details-panel="hours"></div>
        <div class="aico-store-details-panel" data-aico-store-details-panel="images"></div>
      </div>
    </div>
  </div>

  {%- comment -%} Standard site toast (shared .aico-toast-wrap / .aico-toast). {%- endcomment -%}
  <div class="aico-toast-wrap" aria-live="polite" aria-atomic="true">
    <div class="aico-toast aico-store-locator-toast" data-aico-store-locator-toast></div>
  </div>

  <script src="{{ 'store-details.js' | asset_url }}" defer></script>
</main>
