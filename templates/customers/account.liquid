{% comment %}
  Customer profile page ("Mein Profil") — recreates the b2b-shop profile in
  the Liquid theme. Two columns:

    - Left sidebar: greeting + B2B preference dropdowns. Current values and
      option lists come from the AICO-only `aico_account` drop
      (AccountContextLoader). Each dropdown persists instantly via fetch()
      (assets/account-page.js → StorefrontAccountController), reusing the
      same backend services the v2 API uses. "Endkundenansicht" is
      localStorage-only (no backend consumer yet, matching b2b-shop).

    - Right column: contact person (KAM), billing addresses, delivery
      addresses, store-locator addresses. All server-rendered via drops. Each
      address card carries the same change-request control as the dedicated
      customers/addresses page (pending badge + request button + shared modal,
      driven by assets/address-change.js). The store-locator section also links
      to the dedicated store-locator page (routes.aico_account_store_locator_url).

  Address + contact data are hydrated only for this template (see
  LiquidRendererService::loadShopperContext) so other pages don't pay the cost.
{% endcomment %}

{%- assign account = aico_account -%}
{%- assign contact = customer.aico_account_contact -%}
{%- assign change_request_base = routes.aico_address_change_request_url -%}
{%- assign change_request_update_base = routes.aico_address_change_request_update_url -%}

<main class="aico-account" role="main"
      data-aico-account
      data-aico-addresses
      data-change-request-url="{{ change_request_base }}"
      data-change-request-update-url="{{ change_request_update_base }}"
      data-aico-shop-id="{{ customer.aico_shop_id }}"
      data-document-language-url="{{ routes.aico_account_document_language_url }}"
      data-email-language-url="{{ routes.aico_account_email_language_url }}"
      data-sizes-region-url="{{ routes.aico_account_sizes_region_url }}"
      data-exchange-subscription-url="{{ routes.aico_account_exchange_subscription_url }}"
      data-copy-saving="{{ 'customer.account.saving' | t | escape }}"
      data-copy-saved="{{ 'customer.account.saved' | t | escape }}"
      data-copy-error="{{ 'customer.account.save_error' | t | escape }}">

  <input type="hidden" name="_token" value="{{ aico_csrf_token }}">

  <div class="aico-page-container aico-account-grid">

    {%- comment -%} ── Left: settings sidebar ───────────────────────────── {%- endcomment -%}
    <aside class="aico-account-sidebar">
      <div class="aico-account-greeting">
        <p class="aico-account-greeting-hello">{{ 'customer.account.greeting' | t }}</p>
        <p class="aico-account-greeting-name">{{ customer.name }}</p>
        <p class="aico-account-greeting-email">{{ customer.email }}</p>
      </div>

      <div class="aico-account-settings">
        <label class="aico-account-field">
          <span class="aico-account-field-label">{{ 'customer.account.document_language' | t }}</span>
          <select class="aico-account-select" data-aico-pref="document_language">
            {% for option in account.language_options %}
              <option value="{{ option.id }}"{% if option.id == account.document_language_id %} selected{% endif %}>{{ option.name }}</option>
            {% endfor %}
          </select>
        </label>

        <label class="aico-account-field">
          <span class="aico-account-field-label">{{ 'customer.account.email_language' | t }}</span>
          <select class="aico-account-select" data-aico-pref="email_language">
            {% for option in account.language_options %}
              <option value="{{ option.id }}"{% if option.id == account.email_language_id %} selected{% endif %}>{{ option.name }}</option>
            {% endfor %}
          </select>
        </label>

        <label class="aico-account-field">
          <span class="aico-account-field-label">{{ 'customer.account.weekly_exchange_email' | t }}</span>
          <select class="aico-account-select" data-aico-pref="exchange_subscription">
            <option value="1"{% if account.exchange_email_subscribed %} selected{% endif %}>{{ 'customer.account.on' | t }}</option>
            <option value="0"{% unless account.exchange_email_subscribed %} selected{% endunless %}>{{ 'customer.account.off' | t }}</option>
          </select>
        </label>

        <label class="aico-account-field">
          <span class="aico-account-field-label">{{ 'customer.account.size_region' | t }}</span>
          <select class="aico-account-select" data-aico-pref="sizes_region">
            {% for region in account.size_region_options %}
              <option value="{{ region }}"{% if region == account.size_region %} selected{% endif %}>{{ region }}</option>
            {% endfor %}
          </select>
        </label>

        <label class="aico-account-field">
          <span class="aico-account-field-label">{{ 'customer.account.customer_view' | t }}</span>
          <select class="aico-account-select" data-aico-pref="customer_view">
            <option value="on">{{ 'customer.account.on' | t }}</option>
            <option value="off" selected>{{ 'customer.account.off' | t }}</option>
          </select>
        </label>

      </div>
    </aside>

    {%- comment -%} ── Right: contact + addresses ───────────────────────── {%- endcomment -%}
    <div class="aico-account-content">

      <section class="aico-account-section">
        <h2 class="aico-account-section-title">{{ 'customer.account.contact_person_title' | t }}</h2>
        <div class="aico-account-address-grid">
        {% if contact %}
          <div class="aico-account-card aico-account-contact-card">
            {% if contact.photo_url %}
              <img class="aico-account-contact-photo" src="{{ contact.photo_url }}" alt="{{ contact.full_name | escape }}" loading="lazy">
            {% endif %}
            <div class="aico-account-contact-body">
              <p class="aico-account-contact-name">{{ contact.full_name }}</p>
              {% if contact.job_title %}<p class="aico-account-contact-role">{{ contact.job_title }}</p>{% endif %}
              <div class="aico-account-contact-lines">
                {% if contact.phone %}
                  <a class="aico-account-contact-line" href="tel:{{ contact.phone | replace: ' ', '' }}" aria-label="{{ 'customer.account.call_label' | t }}">
                    <svg class="aico-account-contact-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"></path></svg>
                    <span>{{ contact.phone }}</span>
                  </a>
                {% endif %}
                {% if contact.email %}
                  <a class="aico-account-contact-line" href="mailto:{{ contact.email }}" aria-label="{{ 'customer.account.email_label' | t }}">
                    <svg class="aico-account-contact-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
                    <span>{{ contact.email }}</span>
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% else %}
          {%- comment -%}
            Placeholder card: the real KAM/Ansprechperson data source is not
            wired up yet (the B2B main_contact relation is NOT it). Renders the
            design slot with a neutral avatar + hint until the source is known.
          {%- endcomment -%}
          <div class="aico-account-card aico-account-contact-card aico-account-contact-card--placeholder">
            <div class="aico-account-contact-photo aico-account-contact-photo--placeholder" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </div>
            <div class="aico-account-contact-body">
              <p class="aico-account-contact-name">{{ 'customer.account.contact_placeholder_name' | t }}</p>
              <p class="aico-account-contact-placeholder-hint">{{ 'customer.account.contact_placeholder_hint' | t }}</p>
            </div>
          </div>
        {% endif %}
        </div>
      </section>

      <section class="aico-account-section">
        <h2 class="aico-account-section-title">{{ 'customer.account.billing_addresses_title' | t }}</h2>
        {% if customer.aico_billing_addresses.size > 0 %}
          <div class="aico-account-address-grid">
            {% for address in customer.aico_billing_addresses %}
              {%- assign card_bucket = 'billing' -%}
              {%- assign change = address.aico_change_request -%}
              <div class="aico-account-card aico-account-address-card aico-address-card"
                   data-aico-crm-address-id="{{ address.aico_crm_address_id }}"
                   {% if change %}data-aico-change-request-id="{{ change.id }}"{% endif %}
                   data-bucket="{{ card_bucket }}"
                   data-field-company="{{ address.company | escape }}"
                   data-field-first_name="{{ address.first_name | escape }}"
                   data-field-last_name="{{ address.last_name | escape }}"
                   data-field-address1="{{ address.address1 | escape }}"
                   data-field-address2="{{ address.address2 | escape }}"
                   data-field-zip="{{ address.zip | escape }}"
                   data-field-city="{{ address.city | escape }}"
                   data-field-province="{{ address.province | escape }}"
                   data-field-country="{{ address.country | escape }}"
                   data-field-phone="{{ address.phone | escape }}">
                {% if change %}<span class="aico-change-pending-badge" data-aico-change-pending>{{ 'customer.addresses.aico_change_pending' | t }}</span>{% endif %}
                {% if address.name != '' %}<p class="aico-account-address-title">{{ address.name }}</p>{% endif %}
                {% if address.company %}<p class="aico-account-address-line">{{ address.company }}</p>{% endif %}
                <div class="aico-account-address-block">
                  {% if address.address1 != '' %}<p class="aico-account-address-line">{{ address.address1 }}</p>{% endif %}
                  {% if address.address2 != '' %}<p class="aico-account-address-line">{{ address.address2 }}</p>{% endif %}
                  <p class="aico-account-address-line">{{ address.zip }} {{ address.city }}</p>
                  {% if address.province != '' or address.country != '' %}
                    <p class="aico-account-address-line">{{ address.province }}{% if address.province != '' and address.country != '' %}, {% endif %}{{ address.country }}</p>
                  {% endif %}
                  {% if address.phone %}<p class="aico-account-address-line">{{ address.phone }}</p>{% endif %}
                </div>
                <div class="aico-address-card-actions">
                  {% if change %}
                    <button type="button" class="aico-address-card-btn aico-address-change-open is-pending" data-aico-change-open>{{ 'customer.addresses.aico_edit_request' | t }}</button>
                  {% else %}
                    <button type="button" class="aico-address-card-btn aico-address-change-open" data-aico-change-open>{{ 'customer.addresses.aico_request_change' | t }}</button>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="aico-account-empty">{{ 'customer.account.no_addresses' | t }}</p>
        {% endif %}
      </section>

      <section class="aico-account-section">
        <h2 class="aico-account-section-title">{{ 'customer.account.delivery_addresses_title' | t }}</h2>
        {% if customer.aico_delivery_addresses.size > 0 %}
          <div class="aico-account-address-grid">
            {% for address in customer.aico_delivery_addresses %}
              {%- assign card_bucket = 'delivery' -%}
              {%- assign change = address.aico_change_request -%}
              <div class="aico-account-card aico-account-address-card aico-address-card"
                   data-aico-crm-address-id="{{ address.aico_crm_address_id }}"
                   {% if change %}data-aico-change-request-id="{{ change.id }}"{% endif %}
                   data-bucket="{{ card_bucket }}"
                   data-field-company="{{ address.company | escape }}"
                   data-field-first_name="{{ address.first_name | escape }}"
                   data-field-last_name="{{ address.last_name | escape }}"
                   data-field-address1="{{ address.address1 | escape }}"
                   data-field-address2="{{ address.address2 | escape }}"
                   data-field-zip="{{ address.zip | escape }}"
                   data-field-city="{{ address.city | escape }}"
                   data-field-province="{{ address.province | escape }}"
                   data-field-country="{{ address.country | escape }}"
                   data-field-phone="{{ address.phone | escape }}">
                {% if change %}<span class="aico-change-pending-badge" data-aico-change-pending>{{ 'customer.addresses.aico_change_pending' | t }}</span>{% endif %}
                {% if address.name != '' %}<p class="aico-account-address-title">{{ address.name }}</p>{% endif %}
                {% if address.company %}<p class="aico-account-address-line">{{ address.company }}</p>{% endif %}
                <div class="aico-account-address-block">
                  {% if address.address1 != '' %}<p class="aico-account-address-line">{{ address.address1 }}</p>{% endif %}
                  {% if address.address2 != '' %}<p class="aico-account-address-line">{{ address.address2 }}</p>{% endif %}
                  <p class="aico-account-address-line">{{ address.zip }} {{ address.city }}</p>
                  {% if address.province != '' or address.country != '' %}
                    <p class="aico-account-address-line">{{ address.province }}{% if address.province != '' and address.country != '' %}, {% endif %}{{ address.country }}</p>
                  {% endif %}
                  {% if address.phone %}<p class="aico-account-address-line">{{ address.phone }}</p>{% endif %}
                </div>
                <div class="aico-address-card-actions">
                  {% if change %}
                    <button type="button" class="aico-address-card-btn aico-address-change-open is-pending" data-aico-change-open>{{ 'customer.addresses.aico_edit_request' | t }}</button>
                  {% else %}
                    <button type="button" class="aico-address-card-btn aico-address-change-open" data-aico-change-open>{{ 'customer.addresses.aico_request_change' | t }}</button>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="aico-account-empty">{{ 'customer.account.no_addresses' | t }}</p>
        {% endif %}
      </section>

      <section class="aico-account-section">
        <div class="aico-addresses-store-head">
          <h2 class="aico-account-section-title">{{ 'customer.addresses.store_locator_title' | t }}</h2>
          {% if customer.aico_store_locator_addresses.size > 0 %}
            <a class="aico-addresses-store-manage" href="{{ routes.aico_account_store_locator_url }}">{{ 'customer.aico_store_locator.manage_link' | t }}</a>
          {% endif %}
        </div>
        {% if customer.aico_store_locator_addresses.size > 0 %}
          <div class="aico-account-address-grid">
            {% for address in customer.aico_store_locator_addresses %}
              {%- assign card_bucket = 'store_locator' -%}
              {%- assign change = address.aico_change_request -%}
              <div class="aico-account-card aico-account-address-card aico-address-card"
                   data-aico-crm-address-id="{{ address.aico_crm_address_id }}"
                   {% if change %}data-aico-change-request-id="{{ change.id }}"{% endif %}
                   data-bucket="{{ card_bucket }}"
                   data-field-company="{{ address.company | escape }}"
                   data-field-first_name="{{ address.first_name | escape }}"
                   data-field-last_name="{{ address.last_name | escape }}"
                   data-field-address1="{{ address.address1 | escape }}"
                   data-field-address2="{{ address.address2 | escape }}"
                   data-field-zip="{{ address.zip | escape }}"
                   data-field-city="{{ address.city | escape }}"
                   data-field-province="{{ address.province | escape }}"
                   data-field-country="{{ address.country | escape }}"
                   data-field-phone="{{ address.phone | escape }}">
                {% if change %}<span class="aico-change-pending-badge" data-aico-change-pending>{{ 'customer.addresses.aico_change_pending' | t }}</span>{% endif %}
                {% if address.name != '' %}<p class="aico-account-address-title">{{ address.name }}</p>{% endif %}
                {% if address.company %}<p class="aico-account-address-line">{{ address.company }}</p>{% endif %}
                <div class="aico-account-address-block">
                  {% if address.address1 != '' %}<p class="aico-account-address-line">{{ address.address1 }}</p>{% endif %}
                  {% if address.address2 != '' %}<p class="aico-account-address-line">{{ address.address2 }}</p>{% endif %}
                  <p class="aico-account-address-line">{{ address.zip }} {{ address.city }}</p>
                  {% if address.province != '' or address.country != '' %}
                    <p class="aico-account-address-line">{{ address.province }}{% if address.province != '' and address.country != '' %}, {% endif %}{{ address.country }}</p>
                  {% endif %}
                  {% if address.phone %}<p class="aico-account-address-line">{{ address.phone }}</p>{% endif %}
                </div>
                <div class="aico-address-card-actions">
                  {% if change %}
                    <button type="button" class="aico-address-card-btn aico-address-change-open is-pending" data-aico-change-open>{{ 'customer.addresses.aico_edit_request' | t }}</button>
                  {% else %}
                    <button type="button" class="aico-address-card-btn aico-address-change-open" data-aico-change-open>{{ 'customer.addresses.aico_request_change' | t }}</button>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="aico-account-empty">{{ 'customer.addresses.no_stores' | t }}</p>
        {% endif %}
      </section>

    </div>
  </div>

  {%- comment -%}
    Change-request form modal (single, reused). address-change.js fills the
    fields from the active card's data-attrs, sets the action URL, and toggles
    create vs. update mode. Same markup/behaviour as customers/addresses.
  {%- endcomment -%}
  <div class="aico-address-change-modal" data-aico-change-modal hidden aria-hidden="true">
    <div class="aico-address-change-overlay" data-aico-change-close></div>
    <div class="aico-address-change-dialog" role="dialog" aria-modal="true" aria-labelledby="aico-change-title">
      <div class="aico-address-change-head">
        <h3 id="aico-change-title" class="aico-address-change-heading">{{ 'customer.addresses.aico_request_change' | t }}</h3>
        <button type="button" class="aico-address-change-x" data-aico-change-close aria-label="{{ 'customer.addresses.close' | t | escape }}">&times;</button>
      </div>
      <form class="aico-address-change-form" data-aico-change-form>
        <div class="aico-address-change-grid">
          {% assign fields = 'company,first_name,last_name,address1,address2,zip,city,province,country,phone' | split: ',' %}
          {% for field in fields %}
            <label class="aico-address-change-field{% if field == 'address1' or field == 'address2' %} aico-address-change-field--wide{% endif %}">
              <span class="aico-address-change-label">{{ 'customer.addresses.field.' | append: field | t }}</span>
              <input class="aico-address-change-input" type="text" name="{{ field }}" data-field="{{ field }}">
            </label>
          {% endfor %}
        </div>
        <label class="aico-address-change-field aico-address-change-field--wide">
          <span class="aico-address-change-label">{{ 'customer.addresses.aico_explanation' | t }}</span>
          <textarea class="aico-address-change-input aico-address-change-textarea" name="aico_explanation" data-field="aico_explanation" rows="3" required></textarea>
        </label>
        <div class="aico-address-change-actions">
          <button type="button" class="aico-address-change-cancel" data-aico-change-close>{{ 'customer.addresses.cancel' | t }}</button>
          <button type="submit" class="aico-address-change-submit">{{ 'customer.addresses.submit' | t }}</button>
        </div>
      </form>
    </div>
  </div>

  {%- comment -%}
    Standard site toast (shared .aico-toast-wrap / .aico-toast, bottom-center).
    Carries both the account-settings and address-change toast hooks so the two
    scripts on this page (account-page.js, address-change.js) reuse one toast.
  {%- endcomment -%}
  <div class="aico-toast-wrap" aria-live="polite" aria-atomic="true">
    <div class="aico-toast aico-account-toast" data-aico-account-toast data-aico-addresses-toast></div>
  </div>

  <script src="{{ 'account-page.js' | asset_url }}" defer></script>
  <script src="{{ 'address-change.js' | asset_url }}" defer></script>
</main>
