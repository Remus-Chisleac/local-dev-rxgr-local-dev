{% comment %}
  Product block on a content page — renders the shared `product-card`
  snippet so a product placed on a CMS page matches the products listing
  and brand storefront exactly. Maps the block's `aico_data` shape
  (href/image/title/price/rrp, already formatted) onto the card params.
{% endcomment %}
{%- assign data = block.aico_data -%}
{% render 'product-card',
  url: data.href,
  image: data.image,
  title: data.title,
  sku: data.sku,
  price_label: data.price,
  compare_at_label: data.rrp,
  show_reviews: false %}
