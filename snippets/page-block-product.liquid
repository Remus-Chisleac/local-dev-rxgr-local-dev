{% comment %}
  Product card — reuses the brand page's `aico-brand-product-card` markup
  (badge, rating, image, title, price + RRP, cart icon) so a product block on a
  content page matches the brand storefront's card.
{% endcomment %}
{%- assign data = block.aico_data -%}
<div class="aico-brand-product-card">
  <a class="aico-brand-product-link" href="{{ data.href }}">
    <div class="aico-brand-product-card-top">
      <span class="aico-brand-product-badge aico-brand-product-badge-hidden" aria-hidden="true"></span>
      <span class="aico-brand-product-stars" aria-hidden="true">★★★★★</span>
    </div>
    <div class="aico-brand-product-image">
      {%- if data.image != '' -%}<img src="{{ data.image }}" alt="{{ data.title }}" loading="lazy">{%- endif -%}
    </div>
    <div class="aico-brand-product-meta">
      <span class="aico-brand-product-title">{{ data.title }}</span>
      <div class="aico-brand-product-price-row">
        {%- if data.price != '' -%}
          <span class="aico-brand-product-price">{{ data.price }}</span>
          {%- if data.rrp != '' -%}
            <span class="aico-brand-product-rrp">({{ 'product.rrp' | t }} {{ data.rrp }})</span>
          {%- endif -%}
        {%- else -%}
          <span class="aico-brand-product-price">{{ 'product.price_on_request' | t }}</span>
        {%- endif -%}
      </div>
    </div>
  </a>

  <a class="aico-brand-product-cart" href="{{ data.href }}" aria-label="{{ data.title }}">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="8" cy="21" r="1"></circle>
      <circle cx="19" cy="21" r="1"></circle>
      <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
    </svg>
  </a>
</div>
