{% comment %}
  Product card — reuses the brand page's `aico-brand-product-card` markup so a
  product block on a content page matches the brand storefront's card look.
{% endcomment %}
{%- assign data = block.aico_data -%}
<div class="aico-brand-product-card">
  <a class="aico-brand-product-link" href="{{ data.href }}">
    <div class="aico-brand-product-card-top">
      <span class="aico-brand-product-badge aico-brand-product-badge-hidden" aria-hidden="true"></span>
      <span class="aico-brand-product-stars" aria-hidden="true">★★★★★</span>
    </div>
    <div class="aico-brand-product-image">
      {%- if data.image != '' -%}<img src="{{ data.image }}" alt="{{ data.title }}" loading="lazy">{%- endif -%}
    </div>
    <div class="aico-brand-product-meta">
      <span class="aico-brand-product-title">{{ data.title }}</span>
      <div class="aico-brand-product-price-row">
        {%- if data.price != '' -%}
          <span class="aico-brand-product-price">{{ data.price }}</span>
        {%- endif -%}
      </div>
    </div>
  </a>
</div>
