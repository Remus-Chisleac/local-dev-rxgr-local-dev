{% comment %}
  Hotjar tracking loader. Gated on the tracking flag + a configured site id
  (a per-shop secret, aico://secrets/…), so it is inert until a merchant
  enables it and the environment has a site id — environments without the
  secret (local/preview) never load Hotjar. Rendered once from
  layout/theme.liquid so it covers every page.

  Two tag formats, detected from the secret's shape:
  - purely numeric (e.g. 3616738): a legacy Hotjar site id → classic hj()
    bootstrap from static.hotjar.com (redirects into Contentsquare infra).
  - anything else (e.g. ab97d49b8765a): a Contentsquare-platform tag id
    (Hotjar sites created after the Contentsquare migration) → the new
    t.contentsquare.net/uxa tag, exactly as Hotjar's install page emits it.
{% endcomment %}
{% if settings.aico_hotjar_enabled and settings.aico_hotjar_site_id and settings.aico_hotjar_site_id != '' %}
  {%- assign aico_hotjar_id = settings.aico_hotjar_site_id | strip -%}
  {%- assign aico_hotjar_id_as_number = aico_hotjar_id | plus: 0 -%}
  {%- assign aico_hotjar_id_roundtrip = aico_hotjar_id_as_number | append: '' -%}
  {%- if aico_hotjar_id_roundtrip == aico_hotjar_id -%}
    <script>
      (function (h, o, t, j, a, r) {
        h.hj = h.hj || function () { (h.hj.q = h.hj.q || []).push(arguments); };
        h._hjSettings = { hjid: {{ aico_hotjar_id | json }}, hjsv: 6 };
        a = o.getElementsByTagName('head')[0];
        r = o.createElement('script'); r.async = 1;
        r.src = t + h._hjSettings.hjid + j + h._hjSettings.hjsv;
        a.appendChild(r);
      })(window, document, 'https://static.hotjar.com/c/hotjar-', '.js?sv=');
    </script>
  {%- else -%}
    <script src="https://t.contentsquare.net/uxa/{{ aico_hotjar_id | url_encode }}.js" defer></script>
  {%- endif -%}
{% endif %}
