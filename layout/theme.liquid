<!doctype html>
<html lang="{{ request.locale | default: shop.default_locale }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }}</title>
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
  {% if template.directory == 'customers' %}
    <style>:root { --aico-auth-bg-image: url('{{ 'auth-background.webp' | asset_url }}'); }</style>
  {% else %}
    {% comment %}
      Bootstrap globals consumed by assets/cart.js + checkout.js. Keep
      this block tiny — only what the scripts need to format money,
      hit the right endpoints, and seed the initial Alpine store.
    {% endcomment %}
    <script>
      window.__AICO_CSRF__ = {{ aico_csrf_token | json }};
      window.__AICO_SHOP__ = {
        currency: {{ cart.currency_code | default: 'CHF' | json }},
        locale: {{ request.locale | default: shop.default_locale | json }}
      };
      window.__AICO_ROUTES__ = {
        cart: {
          url: {{ routes.cart_url | json }},
          addUrl: {{ routes.cart_add_url | json }},
          changeUrl: {{ routes.cart_change_url | json }},
          clearUrl: {{ routes.cart_clear_url | json }},
          discountUrl: {{ routes.aico_cart_discount_url | json }},
          jsonUrl: {{ routes.aico_cart_json_url | json }},
          addJsonUrl: {{ routes.aico_cart_add_json_url | json }},
          changeJsonUrl: {{ routes.aico_cart_change_json_url | json }}
        },
        checkout: {
          url: {{ routes.checkout_url | json }},
          processingUrl: {{ routes.aico_checkout_processing_url | json }},
          thankYouUrl: {{ routes.aico_checkout_thank_you_url | json }},
          paymentStatusUrl: {{ routes.aico_checkout_payment_status_url | json }}
        }
      };
      window.__AICO_T__ = {
        cart: {
          added: {{ 'cart.added' | t | json }},
          add_error: {{ 'cart.add_error' | t | json }},
          updated: {{ 'cart.updated' | t | json }},
          update_error: {{ 'cart.update_error' | t | json }},
          removed: {{ 'cart.removed' | t | json }},
          item_count_one: {{ 'cart.item_count_one' | t | json }},
          item_count_other: {{ 'cart.item_count_other' | t | json }},
          shipping_at_checkout: {{ 'cart.summary.shipping_at_checkout' | t | json }},
          out_of_stock: {{ 'cart.line.out_of_stock' | t | json }},
          quantity_exceeds_stock: {{ 'cart.line.quantity_exceeds_stock' | t | json }},
          quantity_exceeds_stock_generic: {{ 'cart.line.quantity_exceeds_stock_generic' | t | json }}
        }{% if template.name == 'checkout' or template.directory == 'checkout' %},
        checkout: {
          missing_fields: {{ 'checkout.errors.missing_fields' | t | json }},
          submit_failed: {{ 'checkout.errors.submit_failed' | t | json }},
          cart_modified: {{ 'checkout.errors.cart_modified' | t | json }},
          login_required: {{ 'checkout.login_required' | t | json }}
        }{% endif %}
      };
      window.__AICO_FLAGS__ = {
        {%- comment -%} Flip to true when B2B credit-limit gating should block checkout again. {%- endcomment -%}
        credit_limit_enforcement: false
      };
    </script>
    {% if cart %}
      {%- comment -%}
        SSR'd cart snapshot read by assets/cart.js on init so the header
        badge / mini-cart show the right contents on first paint without
        a follow-up /cart.js fetch. The `| json` filter walks the drop
        with reflection — sufficient for cart + line-item shapes.
      {%- endcomment -%}
      <script id="aico-cart-data" type="application/json">{{ cart | json }}</script>
    {% endif %}
    {%- comment -%}
      cart.js must execute before Alpine so its `alpine:init` listener is
      attached before Alpine.start() dispatches the event and registers the
      `$store.cart` global used by the header badge and mini-cart drawer.
      checkout.js must also load before Alpine on checkout routes so
      `x-data="aicoCheckout(...)"` is defined when Alpine.start() runs.
    {%- endcomment -%}
    <script src="{{ 'cart.js' | asset_url }}" defer></script>
    {% if template.name == 'checkout' or template.directory == 'checkout' %}
      <script src="{{ 'checkout.js' | asset_url }}" defer></script>
    {% endif %}
    <script defer src="https://unpkg.com/alpinejs@3.13.5/dist/cdn.min.js"></script>
  {% endif %}
</head>
<body class="{% if template.directory == 'customers' %}aico-template-customers{% endif %}">
  {% if template.directory == 'customers' %}
    <main class="aico-auth-main">
      {{ content_for_layout }}
    </main>
  {% else %}
    <div class="aico-chrome-sticky">
      <div class="aico-welcome-bar">
        <div class="aico-page-container">
          <p class="aico-welcome-text">
            {% if customer %}
              {{ 'nav.welcome_prefix' | t }} {{ customer.first_name }}
            {% else %}
              {{ 'nav.welcome_guest' | t }}
            {% endif %}
          </p>
        </div>
      </div>

      <header class="aico-header" role="banner">
        <div class="aico-page-container aico-header-row">
          <a href="{{ routes.root_url }}" class="aico-header-brand" aria-label="{{ shop.name }}">
            <span class="aico-header-brand-text">
              {%- if customer.aico_selected_brand -%}
                {{ customer.aico_selected_brand.label }}
              {%- else -%}
                {{ shop.name }}
              {%- endif -%}
            </span>
          </a>

          <div class="aico-header-actions">
            <button type="button" class="aico-icon-button" aria-label="{{ 'nav.search_aria' | t }}">
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
              </svg>
            </button>

            <a href="{{ routes.cart_url }}"
               class="aico-icon-button aico-cart-button"
               aria-label="{{ 'nav.cart_aria' | t }}"
               x-data
               @click="if (window.Alpine && Alpine.store('cart')) { $event.preventDefault(); $store.cart.openDrawer(); }">
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
                <path d="M3 6h18"></path>
                <path d="M16 10a4 4 0 0 1-8 0"></path>
              </svg>
              <span class="aico-cart-badge"
                    x-show="$store.cart && $store.cart.itemCount() > 0"
                    x-text="$store.cart && $store.cart.itemCount()"
                    x-cloak
                    aria-hidden="true"></span>
              <span class="aico-sr-only" x-text="$store.cart && $store.cart.itemCountLabel()"></span>
            </a>

            <button type="button" class="aico-menu-button" data-aico-menu-trigger aria-controls="aico-drawer" aria-expanded="false" aria-label="{{ 'nav.open_menu' | t }}">
              <span class="aico-menu-button-label">{{ 'nav.open_menu' | t }}</span>
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 12h16"></path>
                <path d="M4 6h16"></path>
                <path d="M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>
      </header>
    </div>

    <div class="aico-shell-body">
      <div class="aico-shell-grow">
        {{ content_for_layout }}
      </div>
      <footer class="aico-site-footer" role="contentinfo">
        <div class="aico-site-footer-inner">
          {% if linklists.footer.links.size > 0 %}
            <nav class="aico-home-footer-links" aria-label="{{ 'footer.tagline' | t }}">
              {% for link in linklists.footer.links %}
                <a href="{{ link.url }}" class="aico-home-footer-link">
                  {%- if link.title_key -%}
                    {{ link.title_key | t }}
                  {%- else -%}
                    {{ link.title }}
                  {%- endif -%}
                </a>
              {% endfor %}
            </nav>
          {% else %}
            <p class="aico-site-footer-fallback">{{ 'footer.tagline' | t }}</p>
          {% endif %}
        </div>
      </footer>

      {% comment %} Right-side drawer. Hidden by default; theme.js toggles it. {% endcomment %}
      <div id="aico-drawer" class="aico-drawer" data-aico-drawer hidden>
      <div class="aico-drawer-backdrop" data-aico-drawer-close></div>
      <aside class="aico-drawer-sheet" role="dialog" aria-modal="true" aria-labelledby="aico-drawer-title" tabindex="-1">
        <h2 id="aico-drawer-title" class="aico-sr-only">{{ 'nav.menu_title' | t }}</h2>

        <div class="aico-drawer-head">
          <div class="aico-drawer-head-main">
            {% if aico_brands.size > 0 %}
              <div class="aico-drawer-brand-picker aico-drawer-brand-picker--in-head">
                <details class="aico-disclosure">
                  <summary class="aico-disclosure-summary aico-drawer-brand-summary">
                    <span class="aico-drawer-brand-label">
                      {%- if customer.aico_selected_brand -%}
                        {{ customer.aico_selected_brand.label }}
                      {%- else -%}
                        {{ 'nav.brand_choose' | t }}
                      {%- endif -%}
                    </span>
                    <svg class="aico-icon aico-disclosure-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="m6 9 6 6 6-6"></path>
                    </svg>
                  </summary>
                  <ul class="aico-drawer-brand-list">
                    {% for brand in aico_brands %}
                      <li>
                        <form method="post" action="{{ routes.aico_account_select_brand_url }}" class="aico-drawer-brand-row-form">
                          <input type="hidden" name="_token" value="{{ aico_csrf_token }}">
                          <input type="hidden" name="brand_id" value="{{ brand.id }}">
                          <button type="submit" class="aico-drawer-row aico-drawer-brand-list-row">
                            {% if brand.image_url %}
                              <img src="{{ brand.image_url }}" alt="" class="aico-drawer-brand-thumb">
                            {% else %}
                              <span class="aico-drawer-brand-thumb aico-drawer-brand-thumb-empty" aria-hidden="true"></span>
                            {% endif %}
                            <span class="aico-drawer-row-label">{{ brand.label }}</span>
                          </button>
                        </form>
                      </li>
                    {% endfor %}
                    <li>
                      <a href="{{ routes.root_url }}" class="aico-drawer-row aico-drawer-brand-list-row aico-drawer-brand-overview-link">
                        <span class="aico-drawer-row-icon">
                          <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect width="7" height="7" x="3" y="3" rx="1"></rect>
                            <rect width="7" height="7" x="14" y="3" rx="1"></rect>
                            <rect width="7" height="7" x="14" y="14" rx="1"></rect>
                            <rect width="7" height="7" x="3" y="14" rx="1"></rect>
                          </svg>
                        </span>
                        <span class="aico-drawer-row-label">{{ 'nav.brands_overview' | t }}</span>
                      </a>
                    </li>
                  </ul>
                </details>
              </div>
            {% else %}
              <a href="{{ routes.root_url }}" class="aico-header-brand aico-drawer-head-brand-link" aria-label="{{ shop.name }}">
                <span class="aico-header-brand-text">{{ shop.name }}</span>
              </a>
            {% endif %}
          </div>
          <button type="button" class="aico-icon-button" data-aico-drawer-close aria-label="{{ 'nav.close_menu' | t }}">
            <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>

        <div class="aico-drawer-body">
          <div class="aico-drawer-body-scroll">
          {%- comment -%} ── Main nav ── {%- endcomment -%}
          <nav class="aico-drawer-nav" aria-label="{{ 'nav.menu_title' | t }}">
            {% if aico_shop_navigation.size > 0 %}
              {% for item in aico_shop_navigation %}
                {% if item.has_children? %}
                  <details class="aico-disclosure aico-drawer-nav-group">
                    <summary class="aico-disclosure-summary aico-drawer-row aico-drawer-row-zebra">
                      {% if item.custom_svg %}
                        <span class="aico-drawer-row-icon">{{ item.custom_svg }}</span>
                      {% else %}
                        <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                      {% endif %}
                      <span class="aico-drawer-row-label">{{ item.label }}</span>
                      <svg class="aico-icon aico-disclosure-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="m6 9 6 6 6-6"></path>
                      </svg>
                    </summary>
                    <div class="aico-drawer-nav-children">{{ item.subtree_html }}</div>
                  </details>
                {% else %}
                  <a href="{{ item.url }}" class="aico-drawer-row aico-drawer-row-zebra"{% if item.open_in_new_tab %} target="_blank" rel="noopener noreferrer"{% endif %}>
                    {% if item.custom_svg %}
                      <span class="aico-drawer-row-icon">{{ item.custom_svg }}</span>
                    {% else %}
                      <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                    {% endif %}
                    <span class="aico-drawer-row-label">{{ item.label }}</span>
                  </a>
                {% endif %}
              {% endfor %}
            {% else %}
              <a href="{{ routes.root_url }}" class="aico-drawer-row aico-drawer-row-zebra">
                <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                <span class="aico-drawer-row-label">{{ 'nav.fallback_shop' | t }}</span>
              </a>
              <a href="#" class="aico-drawer-row aico-drawer-row-zebra">
                <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                <span class="aico-drawer-row-label">{{ 'nav.fallback_news' | t }}</span>
              </a>
              <a href="#" class="aico-drawer-row aico-drawer-row-zebra">
                <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                <span class="aico-drawer-row-label">{{ 'nav.fallback_service' | t }}</span>
              </a>
            {% endif %}
          </nav>
          </div>

          {%- comment -%} ── Permanent rows (pinned below scroll; always visible) ── {%- endcomment -%}
          <div class="aico-drawer-permanent">

          {%- comment -%} ── Account contact ── {%- endcomment -%}
          <details class="aico-disclosure aico-drawer-contact" data-aico-contact open>
            <summary class="aico-disclosure-summary aico-drawer-row aico-drawer-row-zebra">
              <span class="aico-drawer-row-icon">
                <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 18a4 4 0 0 0-8 0"></path>
                  <circle cx="12" cy="11" r="3"></circle>
                  <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                </svg>
              </span>
              <span class="aico-drawer-row-label">{{ 'nav.contact_person' | t }}</span>
              <svg class="aico-icon aico-disclosure-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </summary>
            <div class="aico-drawer-contact-card">
              {% if customer.aico_account_contact %}
                <div class="aico-drawer-contact-body">
                  {% if customer.aico_account_contact.photo_url %}
                    <img src="{{ customer.aico_account_contact.photo_url }}" alt="" class="aico-drawer-contact-photo">
                  {% else %}
                    <span class="aico-drawer-contact-photo aico-drawer-contact-photo-empty" aria-hidden="true"></span>
                  {% endif %}
                  <div class="aico-drawer-contact-text">
                    <p class="aico-drawer-contact-name">{{ customer.aico_account_contact.full_name }}</p>
                    {% if customer.aico_account_contact.job_title %}
                      <p class="aico-drawer-contact-job">{{ customer.aico_account_contact.job_title }}</p>
                    {% endif %}
                    {% if customer.aico_account_contact.email %}
                      <p class="aico-drawer-contact-line">{{ customer.aico_account_contact.email }}</p>
                    {% endif %}
                    {% if customer.aico_account_contact.phone %}
                      <p class="aico-drawer-contact-line">{{ customer.aico_account_contact.phone }}</p>
                    {% endif %}
                  </div>
                  <div class="aico-drawer-contact-actions">
                    {% if customer.aico_account_contact.email %}
                      <a class="aico-drawer-contact-action aico-drawer-contact-action-outline" href="mailto:{{ customer.aico_account_contact.email }}" aria-label="{{ 'nav.contact_person_email' | t }}">
                        <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                        </svg>
                      </a>
                    {% endif %}
                    {% if customer.aico_account_contact.phone %}
                      <a class="aico-drawer-contact-action aico-drawer-contact-action-solid" href="tel:{{ customer.aico_account_contact.phone | replace: ' ', '' }}" aria-label="{{ 'nav.contact_person_phone' | t }}">
                        <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                        </svg>
                      </a>
                    {% endif %}
                  </div>
                </div>
              {% else %}
                <p class="aico-drawer-contact-empty">{{ 'nav.contact_person_empty' | t }}</p>
              {% endif %}
            </div>
          </details>

          {%- comment -%} ── Profile + FAQ ── {%- endcomment -%}
          <div class="aico-drawer-perm-split">
            <a href="{{ routes.account_url }}" class="aico-drawer-perm-split-btn">
              <span class="aico-drawer-row-icon">
                <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
              </span>
              <span class="aico-drawer-perm-split-label">{{ 'nav.profile' | t }}</span>
            </a>
            <a href="{{ routes.aico_faq_url }}" class="aico-drawer-perm-split-btn">
              <span class="aico-drawer-row-icon">
                <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                  <path d="M12 17h.01"></path>
                </svg>
              </span>
              <span class="aico-drawer-perm-split-label">{{ 'nav.faq' | t }}</span>
            </a>
          </div>

          {%- comment -%} ── Logout + language (no label row) ── {%- endcomment -%}
          <div class="aico-drawer-perm-footer">
            <a href="{{ routes.account_logout_url }}" class="aico-drawer-perm-footer-logout">
              <span class="aico-drawer-row-icon">
                <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                  <polyline points="16 17 21 12 16 7"></polyline>
                  <line x1="21" x2="9" y1="12" y2="12"></line>
                </svg>
              </span>
              <span>{{ 'nav.logout' | t }}</span>
            </a>
            <span class="aico-locale-pill aico-locale-pill--footer" role="group" aria-label="{{ 'nav.language' | t }}">
              {%- assign current_locale = request.locale | default: shop.default_locale -%}
              <a href="{{ 'en' | aico_locale_url }}" class="aico-locale-pill-option {% if current_locale == 'en' %}aico-locale-pill-active{% endif %}" lang="en">EN</a>
              <a href="{{ 'de_CH' | aico_locale_url }}" class="aico-locale-pill-option {% if current_locale == 'de_CH' %}aico-locale-pill-active{% endif %}" lang="de-CH">DE</a>
            </span>
          </div>

          </div>{%- comment -%} /aico-drawer-permanent {%- endcomment -%}
        </div>
      </aside>
    </div>
    </div>

    {%- comment -%} ─── Mini-cart drawer (Alpine-driven) ─── {%- endcomment -%}
    <div class="aico-mini-cart"
         x-data
         hidden
         :class="{ 'aico-mini-cart-open': $store.cart && $store.cart.drawerOpen }"
         :hidden="!($store.cart && $store.cart.drawerMounted)"
         :aria-hidden="!($store.cart && $store.cart.drawerOpen)"
         @keydown.escape.window="$store.cart && $store.cart.closeDrawer()"
         aria-modal="true"
         role="dialog"
         aria-labelledby="aico-mini-cart-title">
      <div class="aico-mini-cart-backdrop" @click="$store.cart.closeDrawer()"></div>
      <aside class="aico-mini-cart-sheet" tabindex="-1">
        <header class="aico-mini-cart-head">
          <h2 id="aico-mini-cart-title" class="aico-mini-cart-title">{{ 'cart.title' | t }}</h2>
          <button type="button"
                  class="aico-icon-button"
                  @click="$store.cart.closeDrawer()"
                  aria-label="{{ 'nav.close_menu' | t }}">
            <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </header>

        <div class="aico-mini-cart-body">
          <template x-if="!$store.cart.data || $store.cart.data.empty">
            <div class="aico-mini-cart-empty">
              <p>{{ 'cart.empty.heading' | t }}</p>
              <a href="{{ routes.products_url }}" class="aico-button aico-button-outline">
                {{ 'cart.empty.cta' | t }}
              </a>
            </div>
          </template>

          <template x-if="$store.cart.data && !$store.cart.data.empty">
            <ul class="aico-mini-cart-list">
              <template x-for="line in $store.cart.data.items" :key="line.id">
                <li class="aico-mini-cart-line">
                  <a class="aico-mini-cart-line-image" :href="line.url || '#'">
                    <template x-if="line.image"><img :src="line.image" :alt="line.title" loading="lazy"></template>
                    <template x-if="!line.image"><span class="aico-mini-cart-line-image-empty" aria-hidden="true"></span></template>
                  </a>
                  <div class="aico-mini-cart-line-info">
                    <a class="aico-mini-cart-line-title" :href="line.url || '#'" x-text="line.title"></a>
                    <p class="aico-mini-cart-line-meta" x-show="line.aico_variant_label" x-text="line.aico_variant_label"></p>
                    <p class="aico-mini-cart-line-qty">
                      <span x-text="line.quantity"></span> ×
                      <span x-text="$store.cart.formatMoney(line.price)"></span>
                    </p>
                  </div>
                  <button type="button"
                          class="aico-mini-cart-line-remove"
                          @click="$store.cart.setLineQuantity(line.id, 0)"
                          aria-label="{{ 'cart.line.remove' | t }}">×</button>
                </li>
              </template>
            </ul>
          </template>
        </div>

        <footer class="aico-mini-cart-foot" x-show="$store.cart.data && !$store.cart.data.empty" x-cloak>
          <div class="aico-mini-cart-subtotal">
            <span>{{ 'cart.summary.subtotal' | t }}</span>
            <strong x-text="$store.cart.formatMoney($store.cart.data && $store.cart.data.total_price)"></strong>
          </div>
          <a href="{{ routes.cart_url }}" class="aico-button aico-button-outline">{{ 'cart.view_cart' | t }}</a>
          <a href="{{ routes.checkout_url }}"
             class="aico-button aico-button-primary"
             :class="{ 'aico-is-disabled': !$store.cart.canCheckout({% if customer.aico_shipping_block %}true{% else %}false{% endif %}) }"
             @click.prevent="$store.cart.goCheckout($el.getAttribute('href'), {% if customer.aico_shipping_block %}true{% else %}false{% endif %})">
            {{ 'cart.checkout_cta' | t }}
          </a>
        </footer>
      </aside>
    </div>

    {%- comment -%} ─── Toast container (cart feedback) ─── {%- endcomment -%}
    <div class="aico-toast-wrap" x-data aria-live="polite" aria-atomic="true">
      <template x-if="$store.cart && $store.cart.toast">
        <div class="aico-toast"
             :class="'aico-toast-' + $store.cart.toast.kind"
             x-transition.opacity>
          <span x-text="$store.cart.toast.text"></span>
        </div>
      </template>
    </div>

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  {% endif %}
</body>
</html>
