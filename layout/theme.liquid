<!doctype html>
<html lang="{{ request.locale | default: shop.default_locale }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }}</title>
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
  {% if template.directory == 'customers' %}
    <style>:root { --aico-auth-bg-image: url('{{ 'auth-background.webp' | asset_url }}'); }</style>
  {% endif %}
</head>
<body class="{% if template.directory == 'customers' %}aico-template-customers{% endif %}">
  {% if template.directory == 'customers' %}
    <main class="aico-auth-main">
      {{ content_for_layout }}
    </main>
  {% else %}
    <div class="aico-chrome-sticky">
      <div class="aico-welcome-bar">
        <div class="aico-page-container">
          <p class="aico-welcome-text">
            {% if customer %}
              {{ 'nav.welcome_prefix' | t }} {{ customer.first_name }}
            {% else %}
              {{ 'nav.welcome_guest' | t }}
            {% endif %}
          </p>
        </div>
      </div>

      <header class="aico-header" role="banner">
        <div class="aico-page-container aico-header-row">
          <a href="{{ routes.root_url }}" class="aico-header-brand" aria-label="{{ shop.name }}">
            <span class="aico-header-brand-text">
              {%- if customer.aico_selected_brand -%}
                {{ customer.aico_selected_brand.label }}
              {%- else -%}
                {{ shop.name }}
              {%- endif -%}
            </span>
          </a>

          <div class="aico-header-actions">
            <button type="button" class="aico-icon-button" aria-label="{{ 'nav.search_aria' | t }}">
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
              </svg>
            </button>

            <a href="{{ routes.cart_url }}" class="aico-icon-button" aria-label="{{ 'nav.cart_aria' | t }}">
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
                <path d="M3 6h18"></path>
                <path d="M16 10a4 4 0 0 1-8 0"></path>
              </svg>
            </a>

            <button type="button" class="aico-menu-button" data-aico-menu-trigger aria-controls="aico-drawer" aria-expanded="false" aria-label="{{ 'nav.open_menu' | t }}">
              <span class="aico-menu-button-label">{{ 'nav.open_menu' | t }}</span>
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 12h16"></path>
                <path d="M4 6h16"></path>
                <path d="M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>
      </header>
    </div>

    <div class="aico-shell-body">
      {{ content_for_layout }}
    </div>

    <footer class="aico-footer" role="contentinfo">
      <div class="aico-page-container aico-footer-inner">
        <div class="aico-footer-meta">
          <p class="aico-footer-shop-name">
            {%- if customer.aico_selected_brand -%}
              {{ customer.aico_selected_brand.label }}
            {%- else -%}
              {{ shop.name }}
            {%- endif -%}
          </p>
          <p class="aico-footer-tagline">{{ 'footer.tagline' | t }}</p>
        </div>

        {% if linklists.footer.links.size > 0 %}
          <nav class="aico-footer-nav" aria-label="{{ 'footer.menu_aria' | t }}">
            <ul class="aico-footer-link-list">
              {% for link in linklists.footer.links %}
                <li>
                  <a href="{{ link.url }}" class="aico-footer-link">
                    {%- if link.title_key -%}
                      {{ link.title_key | t }}
                    {%- else -%}
                      {{ link.title }}
                    {%- endif -%}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        {% endif %}

        <p class="aico-footer-copy">© {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
      </div>
    </footer>

    {% comment %} Right-side drawer. Hidden by default; theme.js toggles it. {% endcomment %}
    <div id="aico-drawer" class="aico-drawer" data-aico-drawer hidden>
      <div class="aico-drawer-backdrop" data-aico-drawer-close></div>
      <aside class="aico-drawer-sheet" role="dialog" aria-modal="true" aria-labelledby="aico-drawer-title" tabindex="-1">
        <h2 id="aico-drawer-title" class="aico-sr-only">{{ 'nav.menu_title' | t }}</h2>

        <div class="aico-drawer-head">
          <a href="{{ routes.root_url }}" class="aico-header-brand">
            <span class="aico-header-brand-text">
              {%- if customer.aico_selected_brand -%}
                {{ customer.aico_selected_brand.label }}
              {%- else -%}
                {{ shop.name }}
              {%- endif -%}
            </span>
          </a>
          <button type="button" class="aico-icon-button" data-aico-drawer-close aria-label="{{ 'nav.close_menu' | t }}">
            <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>

        <div class="aico-drawer-body">
          {%- comment -%} ── Brand picker ── {%- endcomment -%}
          {% if aico_brands.size > 0 %}
            <p class="aico-drawer-eyebrow">{{ 'nav.current_brand' | t }}</p>
            <div class="aico-drawer-brand-picker">
              <details class="aico-disclosure">
                <summary class="aico-disclosure-summary aico-drawer-brand-summary">
                  <span class="aico-drawer-brand-label">
                    {%- if customer.aico_selected_brand -%}
                      {{ customer.aico_selected_brand.label }}
                    {%- else -%}
                      {{ 'nav.brand_choose' | t }}
                    {%- endif -%}
                  </span>
                  <svg class="aico-icon aico-disclosure-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m6 9 6 6 6-6"></path>
                  </svg>
                </summary>
                <ul class="aico-drawer-brand-list">
                  {% for brand in aico_brands %}
                    <li>
                      <form method="post" action="{{ routes.aico_account_select_brand_url }}" class="aico-drawer-brand-row-form">
                        <input type="hidden" name="_token" value="{{ aico_csrf_token }}">
                        <input type="hidden" name="brand_id" value="{{ brand.id }}">
                        <button type="submit" class="aico-drawer-row aico-drawer-row-zebra">
                          {% if brand.image_url %}
                            <img src="{{ brand.image_url }}" alt="" class="aico-drawer-brand-thumb">
                          {% else %}
                            <span class="aico-drawer-brand-thumb aico-drawer-brand-thumb-empty" aria-hidden="true"></span>
                          {% endif %}
                          <span class="aico-drawer-row-label">{{ brand.label }}</span>
                        </button>
                      </form>
                    </li>
                  {% endfor %}
                </ul>
              </details>
            </div>
          {% endif %}

          {%- comment -%} ── Main nav ── {%- endcomment -%}
          <nav class="aico-drawer-nav" aria-label="{{ 'nav.menu_title' | t }}">
            {% if aico_shop_navigation.size > 0 %}
              {% for item in aico_shop_navigation %}
                {% if item.has_children? %}
                  <details class="aico-disclosure aico-drawer-nav-group">
                    <summary class="aico-disclosure-summary aico-drawer-row aico-drawer-row-zebra">
                      {% if item.custom_svg %}
                        <span class="aico-drawer-row-icon">{{ item.custom_svg }}</span>
                      {% else %}
                        <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                      {% endif %}
                      <span class="aico-drawer-row-label">{{ item.label }}</span>
                      <svg class="aico-icon aico-disclosure-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="m6 9 6 6 6-6"></path>
                      </svg>
                    </summary>
                    <div class="aico-drawer-nav-children">{{ item.subtree_html }}</div>
                  </details>
                {% else %}
                  <a href="{{ item.url }}" class="aico-drawer-row aico-drawer-row-zebra"{% if item.open_in_new_tab %} target="_blank" rel="noopener noreferrer"{% endif %}>
                    {% if item.custom_svg %}
                      <span class="aico-drawer-row-icon">{{ item.custom_svg }}</span>
                    {% else %}
                      <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                    {% endif %}
                    <span class="aico-drawer-row-label">{{ item.label }}</span>
                  </a>
                {% endif %}
              {% endfor %}
            {% else %}
              <a href="{{ routes.root_url }}" class="aico-drawer-row aico-drawer-row-zebra">
                <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                <span class="aico-drawer-row-label">{{ 'nav.fallback_shop' | t }}</span>
              </a>
              <a href="#" class="aico-drawer-row aico-drawer-row-zebra">
                <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                <span class="aico-drawer-row-label">{{ 'nav.fallback_news' | t }}</span>
              </a>
              <a href="#" class="aico-drawer-row aico-drawer-row-zebra">
                <span class="aico-drawer-row-icon aico-drawer-row-icon-dot" aria-hidden="true"></span>
                <span class="aico-drawer-row-label">{{ 'nav.fallback_service' | t }}</span>
              </a>
            {% endif %}
          </nav>

          {%- comment -%} ── Permanent rows (pinned to bottom) ── {%- endcomment -%}
          <div class="aico-drawer-permanent">

          {%- comment -%} ── Account contact ── {%- endcomment -%}
          <details class="aico-disclosure aico-drawer-contact" data-aico-contact open>
            <summary class="aico-disclosure-summary aico-drawer-row aico-drawer-row-zebra">
              <span class="aico-drawer-row-icon">
                <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 18a4 4 0 0 0-8 0"></path>
                  <circle cx="12" cy="11" r="3"></circle>
                  <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                </svg>
              </span>
              <span class="aico-drawer-row-label">{{ 'nav.contact_person' | t }}</span>
              <svg class="aico-icon aico-disclosure-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </summary>
            <div class="aico-drawer-contact-card">
              {% if customer.aico_account_contact %}
                <div class="aico-drawer-contact-body">
                  {% if customer.aico_account_contact.photo_url %}
                    <img src="{{ customer.aico_account_contact.photo_url }}" alt="" class="aico-drawer-contact-photo">
                  {% else %}
                    <span class="aico-drawer-contact-photo aico-drawer-contact-photo-empty" aria-hidden="true"></span>
                  {% endif %}
                  <div class="aico-drawer-contact-text">
                    <p class="aico-drawer-contact-name">{{ customer.aico_account_contact.full_name }}</p>
                    {% if customer.aico_account_contact.job_title %}
                      <p class="aico-drawer-contact-job">{{ customer.aico_account_contact.job_title }}</p>
                    {% endif %}
                    {% if customer.aico_account_contact.email %}
                      <p class="aico-drawer-contact-line">{{ customer.aico_account_contact.email }}</p>
                    {% endif %}
                    {% if customer.aico_account_contact.phone %}
                      <p class="aico-drawer-contact-line">{{ customer.aico_account_contact.phone }}</p>
                    {% endif %}
                  </div>
                  <div class="aico-drawer-contact-actions">
                    {% if customer.aico_account_contact.email %}
                      <a class="aico-drawer-contact-action aico-drawer-contact-action-outline" href="mailto:{{ customer.aico_account_contact.email }}" aria-label="{{ 'nav.contact_person_email' | t }}">
                        <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                        </svg>
                      </a>
                    {% endif %}
                    {% if customer.aico_account_contact.phone %}
                      <a class="aico-drawer-contact-action aico-drawer-contact-action-solid" href="tel:{{ customer.aico_account_contact.phone | replace: ' ', '' }}" aria-label="{{ 'nav.contact_person_phone' | t }}">
                        <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                        </svg>
                      </a>
                    {% endif %}
                  </div>
                </div>
              {% else %}
                <p class="aico-drawer-contact-empty">{{ 'nav.contact_person_empty' | t }}</p>
              {% endif %}
            </div>
          </details>

          {%- comment -%} ── Profile (placeholder, links to /account) ── {%- endcomment -%}
          <a href="{{ routes.account_url }}" class="aico-drawer-row aico-drawer-row-zebra">
            <span class="aico-drawer-row-icon">
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </span>
            <span class="aico-drawer-row-label">{{ 'nav.profile' | t }}</span>
            <svg class="aico-icon aico-drawer-row-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </a>

          {%- comment -%} ── Language pill ── {%- endcomment -%}
          <div class="aico-drawer-row aico-drawer-row-zebra aico-drawer-row-locale">
            <span class="aico-drawer-row-icon">
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 2a14.5 14.5 0 0 0 0 20"></path>
                <path d="M12 2a14.5 14.5 0 0 1 0 20"></path>
                <path d="M2 12h20"></path>
              </svg>
            </span>
            <span class="aico-drawer-row-label">{{ 'nav.language' | t }}</span>
            <span class="aico-locale-pill" role="group" aria-label="{{ 'nav.language' | t }}">
              {%- assign current_locale = request.locale | default: shop.default_locale -%}
              <a href="{{ 'en' | aico_locale_url }}" class="aico-locale-pill-option {% if current_locale == 'en' %}aico-locale-pill-active{% endif %}" lang="en">EN</a>
              <a href="{{ 'de_CH' | aico_locale_url }}" class="aico-locale-pill-option {% if current_locale == 'de_CH' %}aico-locale-pill-active{% endif %}" lang="de-CH">DE</a>
            </span>
          </div>

          {%- comment -%} ── Logout ── {%- endcomment -%}
          <a href="{{ routes.account_logout_url }}" class="aico-drawer-row aico-drawer-row-zebra aico-drawer-row-danger">
            <span class="aico-drawer-row-icon">
              <svg class="aico-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" x2="9" y1="12" y2="12"></line>
              </svg>
            </span>
            <span class="aico-drawer-row-label">{{ 'nav.logout' | t }}</span>
          </a>

          </div>{%- comment -%} /aico-drawer-permanent {%- endcomment -%}
        </div>
      </aside>
    </div>

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  {% endif %}
</body>
</html>
