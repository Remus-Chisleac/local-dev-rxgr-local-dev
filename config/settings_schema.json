  {
    "name": "Branding",
    "settings": [
      { "id": "heading", "type": "text", "label": "Hero heading", "default": "Welcome to your new shop" },
      { "id": "subheading", "type": "text", "label": "Hero subheading", "default": "Customize this from the theme settings." },
      {
        "id": "aico_pdp_size_guide_url",
        "type": "text",
        "label": "Size chart URL (opens in new tab)",
        "default": "",
        "info": "Optional link for “Size chart” on the product page matrix row. Hover shows a short hint (matches aico-commerce)."
      }
    ]
  },
  {
    "name": "Customer accounts",
    "settings": [
      { "id": "aico_auth_heading", "type": "text", "label": "Login heading", "default": "" },
      { "id": "aico_auth_subheading", "type": "text", "label": "Login subheading", "default": "" },
      { "id": "aico_auth_background_image", "type": "image_picker", "label": "Login background image" }
    ]
  },
  {
    "name": "Preorder",
    "info": "Preorder landing fallbacks used only when no live PreorderSession is bound to the page. The countdown is always driven by the active session and shows \"--\" placeholders when none is active.",
    "settings": [
      {
        "id": "aico_preorder_hero_bg_asset",
        "type": "text",
        "label": "Preorder banner image (theme asset filename)",
        "default": "preorder.png",
        "info": "Single decorative image beside the preorder title — not a full-bleed background. Place the file in theme assets (e.g. preorder.png)."
      },
      { "id": "aico_preorder_mock_title", "type": "text", "label": "Fallback preorder title", "default": "PreOrder Ramadan 2027" }
    ]
  },
  {
    "name": "Brand pages",
    "info": "Per-brand campaign content for /brand/<handle>. Keyed by the brand’s PIM url handle. Each entry sets the hero (image / heading / CTA) and pins up to four featured product SKUs. The “Aktuelles” strip pulls the latest news for the brand automatically — no config needed.",
    "settings": [
      {
        "id": "aico_brand_campaigns",
        "type": "paragraph",
        "content": "Edited as JSON in config/settings_data.json under \"aico_brand_campaigns\": { \"<brand-handle>\": { \"hero_title\": \"…\", \"hero_cta_label\": \"…\", \"hero_cta_url\": \"/products/<handle>\", \"hero_image\": \"https://…\", \"featured_skus\": [\"SKU1\",\"SKU2\",\"SKU3\",\"SKU4\"] } }. Omit hero_image to fall back to the brand’s own image; omit a field to hide it."
      }
    ]
  },
  {
    "name": "Search",
    "settings": [
      {
        "id": "aico_search_brand_ids",
        "type": "text",
        "label": "Searchable brands",
        "default": "3,6,7",
        "info": "Comma-separated brand IDs (or names) the search drawer may return — e.g. \"3,6,7\" or \"kybun, Joya, kybunjoya\". Leave empty to allow every brand the shopper can access. Shoppers still only see brands they have access to."
      }
    ]
  },
  {
    "name": "Product reviews",
    "info": "Per-product reviews powered by Yotpo: star ratings on the brand-page product cards and a full reviews widget on the product detail page. Paste the Yotpo store App Key to activate the widget loader; the instance id identifies which Yotpo card widget to show.",
    "settings": [
      {
        "id": "aico_reviews_enabled",
        "type": "checkbox",
        "label": "Show product reviews (stars) on brand-page cards",
        "default": false
      },
      {
        "id": "aico_yotpo_app_key",
        "type": "aico_secret",
        "label": "Yotpo store App Key",
        "info": "Found in your Yotpo account. Required to load the reviews widget — leave unset to keep reviews off. Stored privately on the shop, never in the theme repository."
      },
      {
        "id": "aico_yotpo_widget_instance_id",
        "type": "aico_secret",
        "label": "Yotpo widget instance id",
        "info": "Stored privately on the shop, never in the theme repository."
      }
    ]
  },
